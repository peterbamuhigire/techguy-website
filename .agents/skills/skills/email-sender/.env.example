# Email Sender — PHP + PHPMailer Configuration
# Copy this to .env at project root and fill in YOUR values
# .env is gitignored — never commit secrets

# === SMTP Server Credentials ===
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USERNAME=info@yourdomain.com
SMTP_PASSWORD=your-password-here
SMTP_FROM_EMAIL=info@yourdomain.com
SMTP_FROM_NAME=YourCompany
SMTP_RECIPIENT=info@yourdomain.com

# === CSRF Secret ===
# Generate: openssl rand -hex 32
CSRF_SECRET=change-me-to-a-random-64-char-string

# === Rate Limiting ===
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=3600
