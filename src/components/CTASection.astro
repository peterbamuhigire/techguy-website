---
import { t, type Lang } from '@/utils/i18n';

interface Props {
  lang: Lang;
  title?: string;
  subtitle?: string;
  ctaHref?: string;
  ctaLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const { lang, title, subtitle, ctaHref, ctaLabel, secondaryHref, secondaryLabel } = Astro.props;
const heading = title || (lang === 'en' ? 'Ready to discuss your project?' : 'Prêt à discuter de votre projet ?');
const sub = subtitle || (lang === 'en'
  ? 'Every engagement begins with a conversation. Book a consultation to explore how Peter\'s experience can serve your organisation.'
  : 'Chaque collaboration commence par une conversation. Réservez une consultation pour découvrir comment l\'expérience de Peter peut servir votre organisation.');
const primaryHref = ctaHref || `/${lang}/contact/`;
const primaryLabel = ctaLabel || t('cta.book', lang);
---

<section class="bg-navy-900 py-16 md:py-20 geo-pattern">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-warm-white">{heading}</h2>
    <p class="mt-4 text-navy-200 text-lg">{sub}</p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={primaryHref}
        class="inline-block px-8 py-4 bg-amber-accent hover:bg-gold-600 text-white text-lg font-semibold rounded-lg transition-colors shadow-lg shadow-amber-accent/20"
      >
        {primaryLabel}
      </a>
      {secondaryHref && secondaryLabel && (
        <a
          href={secondaryHref}
          class="inline-block px-8 py-4 border-2 border-gold-400 text-gold-400 hover:bg-gold-400/10 text-lg font-semibold rounded-lg transition-colors"
        >
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
