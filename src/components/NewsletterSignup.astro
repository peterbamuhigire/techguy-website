---
import type { Lang } from '@/utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const formId = `newsletter-${lang}`;
const copy = lang === 'en'
  ? {
      title: 'Get practical insight, not noise.',
      subtitle: 'Join the newsletter for sharp commentary on websites, software, digital strategy, and business systems across Africa.',
      placeholder: 'Your email address',
      button: 'Subscribe',
      note: 'Monthly, useful, and written for decision-makers.',
      success: 'Thank you. You are on the list.',
      error: 'Something went wrong. Please try again or email peter@techguypeter.com.',
    }
  : {
      title: 'Recevez des analyses utiles, pas du bruit.',
      subtitle: "Inscrivez-vous pour recevoir des reflexions concretes sur les sites web, les logiciels, la strategie numerique et les systemes d'entreprise en Afrique.",
      placeholder: 'Votre adresse e-mail',
      button: "S'inscrire",
      note: 'Un envoi par mois, utile et pense pour les decideurs.',
      success: 'Merci. Votre inscription est prise en compte.',
      error: "Une erreur s'est produite. Merci de reessayer ou d'ecrire a peter@techguypeter.com.",
    };
---

<section
  class="rounded-3xl border border-navy-100 bg-white p-8 text-center shadow-sm shadow-navy-900/5"
  x-data={`{
    state: 'idle',
    message: '',
    email: '',
    async submit() {
      this.state = 'loading';
      this.message = '';
      try {
        const res = await fetch('/api/newsletter.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: this.email, lang: '${lang}' })
        });
        const data = await res.json();
        this.state = data.success ? 'success' : 'error';
        this.message = data.message || (data.success ? '${copy.success}' : '${copy.error}');
        if (data.success) this.email = '';
      } catch (error) {
        this.state = 'error';
        this.message = '${copy.error}';
      }
    }
  }`}
>
  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-amber-accent">Newsletter</p>
  <h2 class="mt-3 text-3xl font-bold text-navy-900">{copy.title}</h2>
  <p class="mx-auto mt-4 max-w-2xl text-navy-600">{copy.subtitle}</p>
  <form class="mx-auto mt-8 flex max-w-xl flex-col gap-3 sm:flex-row" @submit.prevent="submit">
    <label class="sr-only" for={formId}>{copy.placeholder}</label>
    <input
      id={formId}
      type="email"
      required
      x-model="email"
      placeholder={copy.placeholder}
      class="w-full rounded-xl border border-navy-200 bg-navy-50 px-4 py-3 text-navy-900 placeholder:text-navy-400 focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/40"
    />
    <button
      type="submit"
      class="rounded-xl bg-amber-accent px-6 py-3 font-semibold text-white transition hover:bg-gold-600 disabled:cursor-not-allowed disabled:opacity-70"
      :disabled="state === 'loading'"
    >
      <span x-show="state !== 'loading'">{copy.button}</span>
      <span x-show="state === 'loading'" x-cloak>...</span>
    </button>
  </form>
  <p class="mt-3 text-sm text-navy-500">{copy.note}</p>
  <p x-show="message" x-cloak class="mt-4 text-sm font-medium" :class="state === 'success' ? 'text-green-700' : 'text-red-700'" x-text="message"></p>
</section>
