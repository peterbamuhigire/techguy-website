---
interface Props {
  name: string;
  price: string;
  description: string;
  bullets: string[];
}

const { name, price, description, bullets } = Astro.props;
---

<article class="flex h-full flex-col rounded-3xl border border-navy-100 bg-white p-6 shadow-sm shadow-navy-900/5">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-2xl font-bold text-navy-900">{name}</h3>
      <p class="mt-2 text-sm font-semibold uppercase tracking-[0.2em] text-amber-accent">{price}</p>
    </div>
  </div>
  <p class="mt-4 text-navy-600 leading-relaxed">{description}</p>
  <ul class="mt-6 space-y-3 text-sm text-navy-700">
    {bullets.map((bullet) => (
      <li class="flex gap-3">
        <svg class="mt-0.5 h-5 w-5 shrink-0 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>{bullet}</span>
      </li>
    ))}
  </ul>
</article>
