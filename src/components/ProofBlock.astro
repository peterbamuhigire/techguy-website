---
interface Props {
  title: string;
  summary: string;
}

const { title, summary } = Astro.props;
---

<div class="rounded-2xl border border-gold-400/20 bg-navy-900 p-5 text-warm-white shadow-lg shadow-navy-950/20">
  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-gold-400">Proof in context</p>
  <h3 class="mt-3 text-xl font-bold">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-navy-200">{summary}</p>
</div>
