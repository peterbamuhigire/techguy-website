---
interface Props {
  title?: string;
  answer: string;
  bullets?: string[];
}

const { title = 'Quick answer', answer, bullets = [] } = Astro.props;
---

<section class="rounded-2xl border border-gold-400/30 bg-gold-50 p-6 md:p-8">
  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-amber-accent">{title}</p>
  <p class="mt-3 text-lg font-medium leading-relaxed text-navy-900">{answer}</p>
  {bullets.length > 0 && (
    <ul class="mt-4 space-y-2 text-sm text-navy-700">
      {bullets.map((item) => (
        <li class="flex gap-2">
          <span class="mt-1.5 h-2 w-2 rounded-full bg-gold-500"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  )}
</section>
