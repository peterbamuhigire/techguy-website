---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const { title, subtitle, align = 'center', light = false } = Astro.props;
---

<div class:list={['mb-10 md:mb-14', align === 'center' ? 'text-center' : 'text-left']}>
  <h2 class:list={[
    'text-3xl md:text-4xl lg:text-5xl font-bold',
    light ? 'text-warm-white' : 'text-navy-900',
  ]}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={[
      'mt-4 text-lg max-w-2xl',
      align === 'center' ? 'mx-auto' : '',
      light ? 'text-navy-200' : 'text-navy-600',
    ]}>
      {subtitle}
    </p>
  )}
  <div class:list={[
    'mt-4 h-1 w-16 rounded-full',
    light ? 'bg-gold-400' : 'bg-gold-500',
    align === 'center' ? 'mx-auto' : '',
  ]}></div>
</div>
