---
interface Props {
  quote: string;
  name: string;
  role: string;
  highlight?: string;
}

const { quote, name, role, highlight } = Astro.props;
---

<article class="rounded-2xl border border-navy-100 bg-white p-6 shadow-sm shadow-navy-900/5">
  <p class="text-lg leading-relaxed text-navy-800">"{quote}"</p>
  <div class="mt-5 border-t border-navy-100 pt-4">
    <p class="font-semibold text-navy-900">{name}</p>
    <p class="text-sm text-navy-500">{role}</p>
    {highlight && <p class="mt-2 text-sm font-medium text-amber-accent">{highlight}</p>}
  </div>
</article>
