---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import type { Lang } from '@/utils/i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogImage?: string;
  page?: string;
  noindex?: boolean;
}

const { title, description, lang, ogImage = '/og-image.jpg', page = '', noindex = false } = Astro.props;
const altLang = lang === 'en' ? 'fr' : 'en';
const currentPath = Astro.url.pathname.replace(`/${lang}`, '');
// Pages with different slugs per language
const slugMap: Record<string, string> = {
  'digital-marketing-strategy': 'strategie-marketing-digital',
  'strategie-marketing-digital': 'digital-marketing-strategy',
  'business-plan-intake': 'devis-plan-affaires',
  'devis-plan-affaires': 'business-plan-intake',
};
const currentSlug = currentPath.replace(/^\//, '').replace(/\/$/, '');
const altUrl = slugMap[currentSlug]
  ? `/${altLang}/${slugMap[currentSlug]}/`
  : `/${altLang}${currentPath || '/'}`;
const siteUrl = 'https://techguypeter.com';
const canonicalUrl = `${siteUrl}/${lang}${currentPath || '/'}`;

// Breadcrumb data
const breadcrumbItems: { name: string; url: string }[] = [
  { name: lang === 'en' ? 'Home' : 'Accueil', url: `${siteUrl}/${lang}/` },
];
if (page && page !== 'home') {
  const pageNames: Record<string, Record<string, string>> = {
    services: { en: 'Services', fr: 'Services' },
    websites: { en: 'Websites', fr: 'Sites Web' },
    portfolio: { en: 'Software', fr: 'Logiciels' },
    about: { en: 'About', fr: 'À Propos' },
    contact: { en: 'Contact', fr: 'Contact' },
    blog: { en: 'Blog', fr: 'Blog' },
  };
  breadcrumbItems.push({
    name: pageNames[page]?.[lang] || page,
    url: canonicalUrl,
  });
}

// ProfessionalService structured data (on every page)
const professionalServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Peter Bamuhigire — IT Consultant & Software Developer",
  "url": siteUrl,
  "logo": `${siteUrl}/og-image.jpg`,
  "image": `${siteUrl}/og-image.jpg`,
  "description": "IT consulting, software development, website design, and business advisory services in Kampala, Uganda. Serving clients across East Africa and internationally.",
  "telephone": "+256784464178",
  "email": "peter@techguypeter.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bukoto",
    "addressLocality": "Kampala",
    "addressCountry": "UG"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 0.3476,
    "longitude": 32.5936
  },
  "areaServed": [
    { "@type": "Country", "name": "Uganda" },
    { "@type": "Country", "name": "Kenya" },
    { "@type": "Country", "name": "Tanzania" },
    { "@type": "Country", "name": "Rwanda" },
    { "@type": "Country", "name": "Democratic Republic of the Congo" },
    { "@type": "Country", "name": "Senegal" },
    { "@type": "Country", "name": "Sierra Leone" },
    { "@type": "Country", "name": "Guinea" },
    { "@type": "Country", "name": "United Kingdom" }
  ],
  "serviceType": [
    "IT Consulting",
    "Software Development",
    "Website Design",
    "Web Development",
    "ICT Strategy",
    "ERP Systems",
    "Business Consulting",
    "Property Management Software"
  ],
  "knowsLanguage": ["en", "fr"],
  "founder": {
    "@type": "Person",
    "name": "Peter Bamuhigire",
    "jobTitle": "IT Consultant & Software Developer",
    "url": `${siteUrl}/en/about/`,
    "sameAs": [
      "https://linkedin.com/in/peterbamuhigire",
      "https://github.com/peterbamuhigire",
      "https://twitter.com/peterbamu"
    ]
  },
  "sameAs": [
    "https://linkedin.com/in/peterbamuhigire",
    "https://github.com/peterbamuhigire",
    "https://twitter.com/peterbamu",
    "https://facebook.com/pbamu",
    "https://instagram.com/peterbamuhigire"
  ]
};

// BreadcrumbList structured data
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.url
  }))
};
---
<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Peter Bamuhigire" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Canonical & Hreflang -->
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang={lang === 'en' ? 'en-GB' : 'fr-FR'} href={`${siteUrl}/${lang}${currentPath || '/'}`} />
  <link rel="alternate" hreflang={altLang === 'en' ? 'en-GB' : 'fr-FR'} href={`${siteUrl}${altUrl}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en${currentPath || '/'}`} />

  <!-- Geo Targeting — Kampala, Uganda -->
  <meta name="geo.region" content="UG-102" />
  <meta name="geo.placename" content="Kampala" />
  <meta name="geo.position" content="0.3476;32.5936" />
  <meta name="ICBM" content="0.3476, 32.5936" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={lang === 'en' ? 'en_GB' : 'fr_FR'} />
  <meta property="og:site_name" content="Peter Bamuhigire — IT Consultant & Software Developer, Kampala" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@peterbamu" />
  <meta name="twitter:creator" content="@peterbamu" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics 4 -->
  <!-- TODO: Replace G-XXXXXXXXXX with your real Measurement ID from https://analytics.google.com -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXXXXX');
  </script>

  <!-- Search Console & Bing Webmaster Verification -->
  <!-- TODO: Replace with token from https://search.google.com/search-console (HTML tag method) -->
  <meta name="google-site-verification" content="REPLACE_WITH_GSC_TOKEN" />
  <!-- TODO: Replace with token from https://www.bing.com/webmasters (HTML meta tag method) -->
  <meta name="msvalidate.01" content="REPLACE_WITH_BING_TOKEN" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</head>
<body class="min-h-screen flex flex-col bg-warm-white text-navy-900">
  <a href="#main-content" class="skip-to-content">Skip to content</a>
  <Header lang={lang} />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />

  <!-- Alpine.js -->
  <script>
    import Alpine from 'alpinejs';
    window.Alpine = Alpine;
    Alpine.start();
  </script>

  <!-- GSAP scroll animations -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('astro:page-load', () => {
      gsap.utils.toArray<HTMLElement>('.fade-up').forEach((el) => {
        gsap.fromTo(el,
          { opacity: 0, y: 30 },
          { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 85%', once: true }
          }
        );
      });

      gsap.utils.toArray<HTMLElement>('.counter').forEach((el) => {
        const target = parseInt(el.dataset.target || '0');
        gsap.fromTo(el, { innerText: 0 }, {
          innerText: target, duration: 2, ease: 'power1.out',
          snap: { innerText: 1 },
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        });
      });
    });
  </script>
</body>
</html>
