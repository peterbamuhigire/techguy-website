---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import TestimonialCard from '@/components/TestimonialCard.astro';
import type { Lang } from '@/utils/i18n';
import { siteConfig } from '@/data/site';

import peterHeadshot from '@/assets/images/team/peter-headshot.jpg';

const lang: Lang = 'en';

const narrativePillars = [
  {
    title: 'Why this practice exists',
    body: 'Across African markets, there is still a recurring gap between the sophistication of the business and the quality of the system representing it. The website looks generic, the software does not fit reality, and the reporting is not trustworthy enough for decisions that matter.',
  },
  {
    title: 'What Peter does differently',
    body: 'Peter works from diagnosis to delivery. That means understanding the commercial pressure, the operational friction, and the trust burden before recommending design, software, or strategy. The output is a system that can be run, measured, and improved after launch.',
  },
  {
    title: 'Who benefits most',
    body: 'The strongest fit is a principal-led business, institution, or high-trust organisation whose current digital presence undersells the quality of its work. That includes firms expanding across borders, seeking funding, or competing for more sophisticated buyers.',
  },
];

const timeline = [
  '2008: Began building websites and supporting business technology in Kampala.',
  '2010-2014: Managed business systems and operational ICT work in Sierra Leone.',
  '2014-2016: Consulted across sectors in Uganda, deepening systems analysis and delivery experience.',
  '2016-present: Built independent products and advisory work through Chwezi Core Systems.',
  '2019-2022: Led regional ICT responsibilities across anglophone and francophone West Africa.',
  '2022-present: Continued strategy, infrastructure, systems, and innovation leadership in Kampala.',
];
---

<BaseLayout
  title="About Peter Bamuhigire | Business Management Systems, Software, and ICT Strategy"
  description="Learn how Peter Bamuhigire builds, deploys, and operates business management systems and custom software for organisations across Africa."
  lang={lang}
  page="about"
>
  <section class="geo-pattern bg-navy-950 pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="fade-up">
          <Image
            src={peterHeadshot}
            alt="Peter Bamuhigire portrait"
            width={720}
            height={860}
            class="w-full rounded-[2rem] border border-gold-400/20 shadow-2xl shadow-black/35"
            loading="eager"
          />
        </div>
        <div class="fade-up">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">About Peter</p>
          <h1 class="mt-4 text-4xl font-bold text-warm-white md:text-6xl">
            A buyer-facing practice built from real operational work, not agency theatre.
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-navy-200">
            Peter Bamuhigire works where digital credibility, software practicality, and business judgement meet.
            Over 15+ years, the work has spanned software development, ICT leadership, ERP and reporting systems, and advisory roles across East Africa and West Africa.
          </p>
          <p class="mt-5 text-lg leading-relaxed text-navy-300">
            That mix matters because most organisations do not need prettier digital assets alone. They need systems that make them look more credible, operate more clearly, and support higher-quality decisions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-3">
        {narrativePillars.map((pillar) => (
          <article class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
            <h2 class="text-2xl font-bold text-navy-900">{pillar.title}</h2>
            <p class="mt-4 leading-relaxed text-navy-600">{pillar.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Career path</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Why the perspective is unusually practical.</h2>
      </div>
      <div class="mt-10 space-y-4">
        {timeline.map((item) => (
          <div class="fade-up rounded-2xl border border-navy-100 bg-white p-5 text-navy-700 shadow-sm shadow-navy-900/5">
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Trust signals</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">How Peter works with clients</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {siteConfig.proof.testimonials.map((testimonial) => (
          <div class="fade-up">
            <TestimonialCard
              quote={testimonial.quoteEn}
              name={testimonial.name}
              role={testimonial.role}
              highlight={testimonial.highlightEn}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    lang={lang}
    title="If the way Peter works matches the kind of guidance you need, start with a diagnostic call."
    subtitle="The most productive next step is a brief conversation about what the current website, message, or system is failing to do."
    ctaHref="/en/contact/"
    ctaLabel="Book a diagnostic call"
    secondaryHref="/en/pricing/"
    secondaryLabel="See pricing and fit"
  />
</BaseLayout>
