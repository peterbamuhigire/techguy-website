---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import { Image } from 'astro:assets';
import { t, type Lang } from '@/utils/i18n';

import imgUxApps from '@/assets/images/ux-team-designing-systems.jpg';
import imgWebsiteUsers from '@/assets/images/website-users--02.jpg';
import imgAgriBusiness from '@/assets/images/photorealistic-goat-farm.jpg';
import imgDigitalBusiness from '@/assets/images/BLOG-MARCH-5-01.jpg';
import imgCustomSoftware from '@/assets/images/blog-images-3.jpg';
import imgItConsultant from '@/assets/images/blog-images-8.jpg';
import imgErp from '@/assets/images/blog-images-1.jpg';
import imgWebsiteCosts from '@/assets/images/blog-images-9.jpg';
import imgBusinessPlan from '@/assets/images/african-entrepreneur-team-analyzing-business-reports.jpg';
import imgFrenchWebsite from '@/assets/images/african-american-business-man-using-laptop-cafe.jpg';
import imgMusicChip from '@/assets/images/music-man-wireless-speaker-orange.jpg';
import imgAiEnterprise from '@/assets/images/businesswoman-interacting-with-ai-hologram-office.jpg';
import imgSoftwareCostUganda from '@/assets/images/blog-images-7.jpg';
import imgEvaluateConsultants from '@/assets/images/blog-images-4.jpg';
import imgCustomVsOffShelf from '@/assets/images/blog-images-2.jpg';
import imgWebsiteCostsEA from '@/assets/images/blog-images-11.jpg';
import imgErpEastAfrica from '@/assets/images/blog-images-6.jpg';
import imgDataViz from '@/assets/images/dataviz-graph-screen.jpg';

const lang: Lang = 'en';

const featuredPost = {
  title: 'AI in Enterprise Software: Five Practical Uses That Cut Costs and Sharpen Decisions',
  slug: 'ai-in-enterprise-software',
  category: 'Technology & AI',
  date: '7 April 2026',
  readTime: '9 min read',
  excerpt: 'Five concrete AI applications — built into the software your team already uses — that reduce manual work, surface problems early, and put better information in front of the people who make decisions.',
  image: imgAiEnterprise,
  imageAlt: 'Business executive interacting with AI hologram — AI in enterprise software for African businesses',
};

const blogPosts = [
  {
    title: 'If You Cannot See It, You Cannot Run It: Data Visualisation in Business Software',
    slug: 'data-visualisation-business-software',
    category: 'Business Software',
    date: '26 April 2026',
    readTime: '10 min read',
    excerpt: 'Charts and dashboards are the user interface of business decision-making. A practical guide for CEOs, managers and IT teams choosing or building software — covering the five charts every business system owes you and the demo checklist that exposes weak software.',
    image: imgDataViz,
    imageAlt: 'Business analyst studying line chart on computer — data visualisation in business software',
  },
  {
    title: 'ERP Software for East African Businesses — What Works and What Fails',
    slug: 'erp-software-east-africa',
    category: 'Technology',
    date: '9 June 2026',
    readTime: '10 min read',
    excerpt: 'Why 60-70% of ERP projects in East Africa fail — and what successful implementation actually requires. Covers SAP, Sage, Odoo, and purpose-built alternatives.',
    image: imgErpEastAfrica,
    imageAlt: 'ERP software implementation across East Africa — Uganda, Kenya, Tanzania business systems',
  },
  {
    title: 'What Does a Website Cost in East Africa? — Honest 2025 Pricing',
    slug: 'website-costs-east-africa',
    category: 'Web Design',
    date: '2 June 2026',
    readTime: '8 min read',
    excerpt: 'Current website pricing in Uganda, Kenya, Tanzania, and Rwanda for 2025. What each price range delivers, what to always include, and how to compare proposals.',
    image: imgWebsiteCostsEA,
    imageAlt: 'East African professional reviewing website costs and proposals on laptop',
  },
  {
    title: 'Custom Software vs. Off-the-Shelf in Uganda — When to Build and When to Buy',
    slug: 'custom-software-vs-off-shelf-uganda',
    category: 'Technology',
    date: '19 May 2026',
    readTime: '9 min read',
    excerpt: 'The honest decision framework for Ugandan businesses: real total cost of ownership for both paths, the Uganda-specific factors that shift the balance, and case examples.',
    image: imgCustomVsOffShelf,
    imageAlt: 'Ugandan business owner evaluating custom software vs off-the-shelf systems',
  },
  {
    title: 'How to Evaluate IT Consultants in Uganda — 7 Questions That Separate Good from Bad',
    slug: 'evaluate-it-consultants-uganda',
    category: 'Business',
    date: '12 May 2026',
    readTime: '9 min read',
    excerpt: 'Seven questions to ask any IT consultant before you hire them in Uganda — what good answers look like, what red flags sound like, and how to avoid the most common mistakes.',
    image: imgEvaluateConsultants,
    imageAlt: 'Business professional interviewing an IT consultant in a Kampala office',
  },
  {
    title: 'How Much Does Software Development Cost in Uganda? — A Transparent Breakdown',
    slug: 'software-development-cost-uganda',
    category: 'Technology',
    date: '5 May 2026',
    readTime: '10 min read',
    excerpt: 'Actual software development prices in Uganda for 2025/2026 — from simple websites to custom ERP systems. UGX and USD price ranges, what proposals usually hide, and how to evaluate quotes.',
    image: imgSoftwareCostUganda,
    imageAlt: 'Software development team working on a custom project in Kampala, Uganda',
  },
  {
    title: "Uganda's Bar Chip Law Will Not Protect Our Musicians — But This Might",
    slug: 'uganda-copyright-chip-music-law',
    category: 'Technology & Policy',
    date: '17 March 2026',
    readTime: '14 min read',
    excerpt: "Minister Mao's plan to install monitoring chips in every Ugandan bar sounds bold. Here's why it won't work — and what government should actually do to protect and export Ugandan music.",
    image: imgMusicChip,
    imageAlt: 'Young man in orange sweater holding wireless speaker — Uganda music copyright law bar chip enforcement debate',
  },
  {
    title: 'Why East African Websites Must Have a French Version',
    slug: 'east-african-websites-need-french-version',
    category: 'Web Design & Strategy',
    date: '3 March 2026',
    readTime: '11 min read',
    excerpt: 'DRC joined the EAC in 2022, adding 109 million French speakers to East Africa\'s market. Your English-only website is invisible to most of them. Here\'s what to do about it.',
    image: imgFrenchWebsite,
    imageAlt: 'African businessman using a laptop — bilingual website East Africa, why East African business websites need French versions',
  },
  {
    title: 'How to Create Apps and Systems That People Love to Use',
    slug: 'how-to-create-apps-people-love',
    category: 'UI/UX Design',
    date: '17 February 2026',
    readTime: '9 min read',
    excerpt: 'Practical UI and UX principles for web and mobile apps — from first impressions to micro-interactions — that turn frustrated users into loyal ones.',
    image: imgUxApps,
    imageAlt: 'UX team designing and reviewing app interface wireframes and prototypes',
  },
  {
    title: 'Why Even Small Businesses Need a Written Business Plan',
    slug: 'why-small-businesses-need-written-business-plan',
    category: 'Strategy',
    date: '3 February 2026',
    readTime: '12 min read',
    excerpt: 'Think a written business plan is only for big companies seeking loans? Here\'s why every small business owner needs one — and what it costs you not to have it.',
    image: imgBusinessPlan,
    imageAlt: 'Business team in East Africa analysing financial reports — why small businesses need a written business plan Uganda',
  },
  {
    title: 'Why Visitors Leave Your Website After 3 Seconds — And How to Stop It',
    slug: 'why-visitors-leave-website-3-seconds',
    category: 'Web Design & UX',
    date: '20 January 2026',
    readTime: '8 min read',
    excerpt: 'Most websites lose 40% of visitors before the page fully loads. Here are the 7 real reasons visitors leave in seconds — and practical fixes for each one.',
    image: imgWebsiteUsers,
    imageAlt: 'Website visitors browsing a business website on laptop — reduce bounce rate and improve user experience',
  },
  {
    title: 'Writing Bankable Business Plans for Agriculture: Coffee, Fish and Goats',
    slug: 'bankable-agricultural-business-plans-coffee-fish-goats-uganda',
    category: 'Agriculture',
    date: '6 January 2026',
    readTime: '15 min read',
    excerpt: 'Most agricultural loan applications in Uganda are rejected not because the farming idea is bad — but because the business plan doesn\'t speak the language of money. Real financial models for coffee, fish farming, and goat enterprises.',
    image: imgAgriBusiness,
    imageAlt: 'Photorealistic goat farm in Uganda — agricultural business planning guide for East Africa',
  },
  {
    title: 'Why Your Business Must Go Digital Today',
    slug: 'business-must-go-digital',
    category: 'Business',
    date: '23 December 2025',
    readTime: '10 min read',
    excerpt: 'Every African SME needs digital POS, inventory, and accounting systems. Prevent stock losses, comply with EFRIS and eTax mandates, and finally know your real numbers.',
    image: imgDigitalBusiness,
    imageAlt: 'Business owner using a digital POS system to manage sales and inventory in an African retail shop',
  },
  {
    title: 'Why African Businesses Need Custom-Built Software Solutions',
    slug: 'custom-software-africa',
    category: 'Technology',
    date: '9 December 2025',
    readTime: '8 min read',
    excerpt: 'Custom software Africa: why off-the-shelf tools fail African businesses and how bespoke solutions built in Kampala deliver real results.',
    image: imgCustomSoftware,
    imageAlt: 'IT professional managing custom software systems in an African data centre',
  },
  {
    title: 'How to Choose an IT Consultant in East Africa',
    slug: 'choose-it-consultant',
    category: 'Business',
    date: '25 November 2025',
    readTime: '10 min read',
    excerpt: 'A practical guide to choosing the right IT consultant in Kampala and East Africa — questions to ask, red flags, and what good engagement looks like.',
    image: imgItConsultant,
    imageAlt: 'IT consultant reviewing technology systems and infrastructure',
  },
  {
    title: 'ERP Implementation: What SMEs Get Wrong and How to Get It Right',
    slug: 'erp-implementation-mistakes',
    category: 'ERP',
    date: '11 November 2025',
    readTime: '9 min read',
    excerpt: 'Avoid costly ERP mistakes African SMEs make. Proven strategies for successful ERP implementation from 15+ years of rollouts across Africa.',
    image: imgErp,
    imageAlt: 'ERP system hologram with business management icons',
  },
  {
    title: 'What a Website Actually Costs in Uganda (And Why It Varies So Much)',
    slug: 'website-costs-uganda',
    category: 'Technology',
    date: '28 October 2025',
    readTime: '10 min read',
    excerpt: 'Honest breakdown of website cost in Uganda — from template sites to custom builds. Real prices in UGX and USD, plus hidden costs.',
    image: imgWebsiteCosts,
    imageAlt: 'Business professionals browsing a website on a tablet',
  },
];
---

<BaseLayout
  title="Tech Insights — Peter Bamuhigire, Kampala"
  description="Articles on software development, IT consulting, and technology solutions for African businesses. Peter Bamuhigire, IT consultant, Kampala."
  lang={lang}
  page="blog"
>
  <!-- Hero Banner -->
  <section class="bg-navy-900 pt-20 md:pt-24 pb-12 md:pb-16 geo-pattern">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white">
        Tech Insights for African Businesses
      </h1>
      <p class="mt-4 text-lg md:text-xl text-navy-200 max-w-2xl mx-auto">
        {t('blog.subtitle', lang)}
      </p>
      <div class="mt-6 h-1 w-20 rounded-full bg-gold-400 mx-auto"></div>
    </div>
  </section>

  <!-- Featured Article -->
  <section class="py-12 md:py-16 bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-amber-accent uppercase tracking-wider mb-6">Featured Article</p>
      <a href={`/${lang}/blog/${featuredPost.slug}/`} class="fade-up group block bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
          <div class="h-64 md:h-full min-h-[280px] overflow-hidden relative">
            <Image
              src={featuredPost.image}
              alt={featuredPost.imageAlt}
              width={1200}
              height={800}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute top-4 left-4">
              <span class="inline-flex items-center px-3 py-1 text-xs font-semibold bg-gold-400 text-navy-900 rounded-full">
                {featuredPost.category}
              </span>
            </div>
          </div>
          <div class="p-6 md:p-8 lg:p-10 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-3 text-sm text-navy-500">
              <time>{featuredPost.date}</time>
              <span class="w-1 h-1 rounded-full bg-navy-300"></span>
              <span>{featuredPost.readTime}</span>
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-navy-900 group-hover:text-amber-accent transition-colors leading-snug">
              {featuredPost.title}
            </h2>
            <p class="mt-3 text-navy-600 line-clamp-3">
              {featuredPost.excerpt}
            </p>
            <div class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-amber-accent group-hover:text-gold-700 transition-colors">
              Read Article
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Blog Articles Section -->
  <section class="py-10 md:py-16 bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-navy-500 uppercase tracking-wider mb-6">More Articles</p>
      <!-- Blog Post Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {blogPosts.map((post) => (
          <a href={`/${lang}/blog/${post.slug}/`} class="fade-up group bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden block">
            <!-- Featured Image -->
            <div class="h-48 md:h-52 overflow-hidden relative">
              <Image
                src={post.image}
                alt={post.imageAlt}
                width={700}
                height={400}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-4 right-4">
                <span class="inline-flex items-center px-3 py-1 text-xs font-semibold bg-white/90 backdrop-blur-sm text-navy-800 rounded-full">
                  {post.category}
                </span>
              </div>
            </div>
            <!-- Card Content -->
            <div class="p-5 md:p-6">
              <div class="flex items-center gap-3 mb-3 text-sm text-navy-500">
                <time>{post.date}</time>
                <span class="w-1 h-1 rounded-full bg-navy-300"></span>
                <span>{post.readTime}</span>
              </div>
              <h3 class="text-lg md:text-xl font-bold text-navy-900 group-hover:text-amber-accent transition-colors leading-snug">
                {post.title}
              </h3>
              <p class="mt-2 text-sm text-navy-600 line-clamp-2">
                {post.excerpt}
              </p>
              <div class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-amber-accent group-hover:text-gold-700 transition-colors">
                Read Article
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 md:py-20 bg-navy-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center" x-data="{ submitted: false }">
      <div class="fade-up">
        <svg class="w-10 h-10 text-gold-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-900">
          Stay Updated
        </h2>
        <p class="mt-3 text-navy-600">
          Subscribe to receive insights on technology, business strategy, and innovation across Africa — delivered straight to your inbox.
        </p>
      </div>

      <!-- Newsletter Form -->
      <div class="mt-8 fade-up" x-show="!submitted" x-transition>
        <form action="#" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" @submit.prevent="submitted = true">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            required
            placeholder="Enter your email address"
            class="flex-1 px-4 py-3 bg-white border border-navy-200 rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-amber-accent hover:bg-gold-600 text-white font-semibold rounded-lg transition-colors whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-gold-500 focus:ring-offset-2"
          >
            Subscribe
          </button>
        </form>
        <p class="mt-3 text-xs text-navy-400">No spam, ever. Unsubscribe at any time.</p>
      </div>

      <!-- Confirmation Message -->
      <div x-show="submitted" x-cloak x-transition class="mt-8">
        <div class="inline-flex items-center gap-3 px-6 py-4 bg-white rounded-xl shadow-sm">
          <svg class="w-6 h-6 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-navy-800 font-medium">Thank you! You will be notified when new articles are published.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection lang={lang} />
</BaseLayout>

<style>
  [x-cloak] { display: none !important; }
</style>
