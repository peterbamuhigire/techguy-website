---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import { Image } from 'astro:assets';
import type { Lang } from '@/utils/i18n';

import heroImg from '@/assets/images/BLOG-MARCH-5-01.jpg';
import imgAnalytics from '@/assets/images/BLOG-MARCH-5-02.jpg';
import imgErp from '@/assets/images/BLOG-MARCH-5-03.jpg';
import imgTeam from '@/assets/images/BLOG-MARCH-5-04.jpg';

const lang: Lang = 'en';
const title = "Why Your Business Must Go Digital Today";
const description = "Why every African SME needs digital POS, inventory, and accounting systems — prevent losses, comply with EFRIS and eTax, and know your customers.";
const date = "2026-03-05";
const category = "Business";
const readTime = "10 min read";
const slug = "business-must-go-digital";
const siteUrl = "https://techguypeter.com";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "author": {
    "@type": "Person",
    "name": "Peter Bamuhigire",
    "url": `${siteUrl}/en/about/`
  },
  "datePublished": date,
  "dateModified": date,
  "publisher": {
    "@type": "Organization",
    "name": "Peter Bamuhigire — Technology & Business Consulting",
    "url": siteUrl
  },
  "description": description,
  "image": `${siteUrl}${heroImg.src}`,
  "inLanguage": "en-GB",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/en/blog/${slug}/`
  }
};
---

<BaseLayout title={title} description={description} lang={lang} page="blog" ogImage={heroImg.src}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Reading Progress Bar -->
