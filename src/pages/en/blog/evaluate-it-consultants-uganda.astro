  "dateModified": date,
  "publisher": {
    "@type": "Organization",
    "name": "Peter Bamuhigire — Technology & Business Consulting",
    "url": siteUrl
  },
  "description": description,
  "image": `${siteUrl}${heroImg.src}`,
  "inLanguage": "en-GB",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/en/blog/${slug}/`
