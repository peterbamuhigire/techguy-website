            width={740}
            height={1111}
            class="article-img-portrait rounded-xl w-full"
            loading="lazy"
          />
          <figcaption>Every tap deserves a response. Silence after an action signals failure to the user's brain — even when nothing went wrong.</figcaption>
        </div>
