import type { Lang } from '@/utils/i18n';

import heroImg from '@/assets/images/ux-team-designing-systems.jpg';
import imgLandscape from '@/assets/images/ux-designs-ui-wireframe.jpg';
import imgPortrait from '@/assets/images/ux-designer-brainstorming-mobile-app.jpg';
import imgLandscape2 from '@/assets/images/ux-notebook-3d-concept.jpg';

const lang: Lang = 'en';
const title = "How to Create Apps and Systems That People Love to Use";
const description = "Practical UI and UX principles for web and mobile apps — from first impressions to micro-interactions — that turn frustrated users into loyal ones.";
const date = "2026-03-23";
const category = "UI/UX Design";
const readTime = "9 min read";
const slug = "how-to-create-apps-people-love";
const siteUrl = "https://techguypeter.com";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "author": {
    "@type": "Person",
    "name": "Peter Bamuhigire",
    "url": `${siteUrl}/en/about/`
  },
  "datePublished": date,
  "dateModified": date,
  "publisher": {
    "@type": "Organization",
    "name": "Peter Bamuhigire — Technology & Business Consulting",
    "url": siteUrl
  },
  "description": description,
  "image": `${siteUrl}${heroImg.src}`,
  "inLanguage": "en-GB",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/en/blog/${slug}/`
  }
};
---

<BaseLayout title={title} description={description} lang={lang} page="blog" ogImage={heroImg.src}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="reading-progress" style="width: 0%"></div>

  <!-- Layout A: Centred Navy Hero -->
  <section class="bg-navy-900 pt-20 md:pt-24 pb-14 geo-pattern">
