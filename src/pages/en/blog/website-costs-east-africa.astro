import heroImg from '@/assets/images/blog-images-9.jpg';
import img10 from '@/assets/images/blog-images-10.jpg';
import img12 from '@/assets/images/blog-images-12.jpg';
import img17 from '@/assets/images/blog-images-17.jpg';

const lang: Lang = 'en';
const title = "What Does a Website Cost in East Africa? — Honest 2025 Pricing";
const description = "Up-to-date website pricing for East Africa in 2025. Costs in Uganda, Kenya, Tanzania, and Rwanda — what each type of website costs, what drives the price, and what to always include.";
const date = "2026-06-02";
const category = "Technology";
const readTime = "8 min read";
const slug = "website-costs-east-africa";
const siteUrl = "https://techguypeter.com";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "author": {
    "@type": "Person",
    "name": "Peter Bamuhigire",
    "url": `${siteUrl}/en/about/`
  },
  "datePublished": date,
  "dateModified": date,
  "publisher": {
    "@type": "Organization",
    "name": "Peter Bamuhigire — Technology & Business Consulting",
    "url": siteUrl
  },
  "description": description,
  "image": `${siteUrl}${heroImg.src}`,
  "inLanguage": "en-GB",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/en/blog/${slug}/`
  }
};

const faqs = [
  {
    question: "How much does a website cost in Kenya?",
    answer: "A professionally built business website in Kenya typically costs KES 80,000–200,000 (approximately USD 600–1,500) for a 5-page static site with SEO setup and mobile-first design. WordPress sites with a CMS run KES 100,000–350,000. Custom web applications are priced individually. Nairobi prices tend to be 20-30% higher than comparable work in Kampala."
  },
  {
    question: "How much does a website cost in Uganda?",
    answer: "A professionally built business website in Uganda starts from UGX 2,000,000–5,000,000 (approximately USD 550–1,400) for a static site with basic SEO. WordPress sites run UGX 3,000,000–8,000,000. These are Kampala market prices for quality-tier work — cheaper proposals exist but typically cut corners on SEO setup, mobile performance, or post-launch support."
  },
  {
    question: "What is the cheapest I can build a business website for in East Africa?",
    answer: "Template-based DIY platforms (Wix, Squarespace) can produce a website for USD 15–50/month in subscription fees, with no upfront cost. The limitation is performance on East African mobile networks (these platforms are built for fast connections), limited SEO customisation, and no local support. For a business that needs to rank in local search results and load quickly on 3G, a professionally built static site is significantly more effective."
  }
];
---

<BaseLayout title={title} description={description} lang={lang} page="blog" ogImage={heroImg.src}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

