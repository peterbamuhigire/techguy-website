---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import type { Lang } from '@/utils/i18n';

import bpImg1 from '@/assets/images/services/business-plan-01.jpg';
import bpImg2 from '@/assets/images/services/business-plan-02.jpg';
import bpImg3 from '@/assets/images/services/business-plan-03.jpg';

const lang: Lang = 'en';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a business plan cost in Uganda?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Business plan preparation fees vary depending on complexity and scope. Contact us for a quote based on your specific requirements."
      }
    },
    {
      "@type": "Question",
      "name": "What makes a business plan bankable in Uganda?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A bankable business plan must be structured around the CAMPARI criteria used by Ugandan lenders — demonstrating Character, Ability, Means, Purpose, Amount, Repayment, and Insurance — with a documented Debt Service Coverage Ratio calculation."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get help with my UDB loan business plan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We prepare business plans specifically structured to meet Uganda Development Bank requirements, including all financial documentation and project feasibility sections required for DFI applications."
      }
    },
    {
      "@type": "Question",
      "name": "Do you prepare pitch decks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Every engagement includes a professional pitch deck — 12 to 15 slides structured as a visual argument, not a condensed plan, designed for your specific audience."
      }
    },
    {
      "@type": "Question",
      "name": "What is included in presentation training?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Six structured sessions covering your business narrative, content mastery, delivery skills, Q&A preparation with the 10 hardest questions your audience will ask, a dress rehearsal, and a day-of briefing."
      }
    }
  ]
};
---

<BaseLayout
  title="Bankable Business Plan Consultant Uganda | Pitch Deck & Presentation Training"
  description="We develop complete, bankable business plans with pitch decks and presentation training for Uganda and East Africa. CAMPARI-structured plans for banks, DFIs, and investors."
  lang={lang}
  page="services"
>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ==============================
       HERO BANNER
       ============================== -->
  <section class="relative bg-navy-950 overflow-hidden">
    <div class="absolute inset-0 geo-pattern opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-950/95 to-navy-900"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-24">
      <div class="py-16 md:py-20 lg:py-24 max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-6">
          <span class="text-gold-400 text-sm font-medium">Business Consulting Service</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white leading-tight">
          Business Planning: Plan. Deck. Delivery.
        </h1>

        <p class="mt-6 text-lg md:text-xl text-navy-200 leading-relaxed max-w-2xl">
          We develop complete, bankable business plans — including a professional pitch deck and personalised training to present and defend your plan with confidence.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/en/contact/"
            class="inline-flex items-center justify-center px-8 py-4 bg-amber-accent hover:bg-amber-accent/90 text-white text-lg font-semibold rounded-lg transition-all duration-300 shadow-lg shadow-amber-accent/20 hover:shadow-xl hover:-translate-y-0.5"
          >
            Book a Free Consultation
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          <a
            href="/en/services/#business-consulting"
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-gold-400 text-gold-400 hover:bg-gold-400/10 text-lg font-semibold rounded-lg transition-all duration-300 hover:-translate-y-0.5"
          >
            View Our Services
          </a>
        </div>

        <div class="mt-4 h-1 w-16 rounded-full bg-gold-400"></div>
      </div>
    </div>

    <!-- Bottom wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 40V10C360 30 720 0 1080 20C1260 30 1380 25 1440 20V40H0Z" fill="var(--color-warm-white)"/>
      </svg>
    </div>
  </section>

  <!-- ==============================
       SECTION 1: THE BUSINESS PLAN
       ============================== -->
  <section class="bg-warm-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">The Complete Package</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">The Business Plan</h2>

          <p class="text-navy-600 leading-relaxed mb-6">
            A complete 15-section plan built to be bankable. We apply the CAMPARI and DSCR frameworks used by Ugandan and East African lenders — so your plan speaks the language of the decision-maker reviewing it. The analysis is MECE, the financial model is stress-tested, and every assumption is documented and defensible. The risk register is real. The implementation timeline has named owners and accounts for regulatory lead times.
          </p>
          <p class="text-navy-600 leading-relaxed mb-8">
            This is not a template. It is evidence-based, strategically sound, and executable.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {[
              'Complete 15-section business plan',
              'Five-year financial projections',
              'DSCR calculation & break-even analysis',
              'Market analysis with sourced data',
              'Risk register with mitigations',
              'Implementation timeline',
              'Assumptions documentation',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/en/contact/"
            class="inline-flex items-center px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            Book a Consultation
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl -rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={bpImg1}
              alt="Business plan document preparation and financial analysis"
              width={640}
              height={427}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SECTION 2: THE PITCH DECK
       ============================== -->
  <section class="bg-warm-cream py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (left on desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={bpImg2}
              alt="Professional pitch deck slides for investor and bank presentations"
              width={640}
              height={464}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">The Complete Package</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">The Pitch Deck</h2>

          <p class="text-navy-600 leading-relaxed mb-6">
            12–15 slides. Not a condensed version of the plan — a visual argument. Each slide is built on an assertion-evidence structure: the headline states the conclusion, the content proves it. The narrative alternates between current reality and the future your business creates. Financial slides are headlined with conclusions, not labels. The ask is specific, confident, and practised.
          </p>
          <p class="text-navy-600 leading-relaxed mb-8">
            Every deck is structured for your specific audience — whether that is a bank credit committee, a DFI officer, or an impact investor.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {[
              '12–15 professionally designed slides',
              'Narrative structured for your specific audience',
              'Financial slides headlined with conclusions',
              'Speaker notes version',
              'Designed for bank committees, DFI officers, or investors',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/en/contact/"
            class="inline-flex items-center px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            Book a Consultation
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SECTION 3: PRESENTATION TRAINING
       ============================== -->
  <section class="bg-warm-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">The Complete Package</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Presentation & Pitch Training</h2>

          <p class="text-navy-600 leading-relaxed mb-6">
            Six structured sessions. We build your narrative first — the story of your business and why this is the right moment. Then the pitch frame: how to position yourself as the prize, not the supplicant. Content mastery ensures you know every number cold. Delivery work covers voice, eye contact, and managing nerves. Q&A preparation covers the 10 hardest questions your audience will ask, with bridging technique to stay in control. The close is practised until it is natural.
          </p>

          <!-- Sessions list -->
          <div class="space-y-2 mb-8">
            {[
              'Session 1: Story & Pitch Frame',
              'Session 2: Content Mastery',
              'Session 3: Delivery Fundamentals',
              'Session 4: Q&A Simulation',
              'Session 5: Dress Rehearsal',
              'Session 6: Day-of Briefing',
            ].map((item, i) => (
              <div class="flex items-start gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-navy-900 text-gold-400 text-xs font-bold flex items-center justify-center mt-0.5">{i + 1}</span>
                <span class="text-navy-700 text-sm pt-0.5">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/en/contact/"
            class="inline-flex items-center px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            Book a Consultation
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl -rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg" style="height: 480px;">
            <Image
              src={bpImg3}
              alt="Presentation coaching and pitch training session"
              width={640}
              height={480}
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SECTION 4: WHO THIS IS FOR
       ============================== -->
  <section class="bg-navy-900 py-16 md:py-24 geo-pattern relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900/95 to-navy-900/90"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <SectionHeading
          title="Who This Is For"
          subtitle="This service is designed for entrepreneurs and professionals who need to be taken seriously by a lender, investor, or partner."
          light
        />
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 fade-up">
        <!-- Card 1 -->
        <div class="bg-navy-800/60 border border-navy-700 rounded-2xl p-6 hover:border-gold-400/30 transition-colors duration-300">
          <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-white mb-2">Bank Loan Applicants</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            Applying to Centenary Bank, Stanbic, ABSA, dfcu, Equity Bank, UDB, or any DFI? A professionally prepared plan structured for the lender's decision framework significantly increases approval probability.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="bg-navy-800/60 border border-navy-700 rounded-2xl p-6 hover:border-gold-400/30 transition-colors duration-300">
          <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-white mb-2">Equity & Impact Investment</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            Raising angel funding, impact investment, or a VC round? Your plan and deck are the primary documents. Most plans are rejected in the first five pages. The difference is the quality of the argument.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="bg-navy-800/60 border border-navy-700 rounded-2xl p-6 hover:border-gold-400/30 transition-colors duration-300">
          <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-white mb-2">Established Businesses Expanding</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            An expansion requiring capital, a joint venture, a government tender, or a strategic partnership almost always requires a formal plan. We build it to the standard the audience expects.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="bg-navy-800/60 border border-navy-700 rounded-2xl p-6 hover:border-gold-400/30 transition-colors duration-300">
          <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-white mb-2">Previously Declined</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            Applied before and been declined? We diagnose exactly what the lender found unconvincing and rebuild from there. A declined application is data — we use it.
          </p>
        </div>

        <!-- Card 5 -->
        <div class="bg-navy-800/60 border border-navy-700 rounded-2xl p-6 hover:border-gold-400/30 transition-colors duration-300 sm:col-span-2 lg:col-span-1">
          <div class="w-10 h-10 rounded-xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-warm-white mb-2">Consulting Professionals</h3>
          <p class="text-navy-300 text-sm leading-relaxed">
            Run a consulting practice and need a structured methodology? This service can be adapted for professional development — equipping consultants with the frameworks to build bankable plans for their own clients.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SECTION 5: OUR PROCESS
       ============================== -->
  <section class="bg-warm-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <SectionHeading
          title="Our Process — Weeks 1 to 6"
          subtitle="A structured six-week engagement from discovery to delivery — plan, deck, and trained presenter."
        />
      </div>

      <!-- Desktop: horizontal timeline -->
      <div class="hidden md:block fade-up">
        <div class="relative">
          <!-- Connecting line -->
          <div class="absolute top-10 left-[8%] right-[8%] h-0.5 bg-gradient-to-r from-gold-400/20 via-gold-400/60 to-gold-400/20"></div>

          <div class="grid grid-cols-6 gap-3 lg:gap-4">
            {[
