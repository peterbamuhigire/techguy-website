---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Lang } from '@/utils/i18n';

const lang: Lang = 'en';

const services = [
  'Business Management Systems',
  'Website Development',
  'ICT Consulting & Strategy',
  'Business Planning',
  'Digital Marketing & Social Media',
  'Other',
];

const contactMethods = [
  { value: 'phone', label: 'Phone call' },
  { value: 'whatsapp', label: 'WhatsApp' },
  { value: 'email', label: 'Email' },
];

const qualificationQuestions = [
  {
    id: 'urgency',
    question: 'How urgent is the decision?',
    answers: [
      { value: '30-days', label: 'Within 30 days', points: 3 },
      { value: 'quarter', label: 'This quarter', points: 2 },
      { value: 'exploring', label: 'Still exploring', points: 1 },
    ],
  },
  {
    id: 'scope',
    question: 'What kind of engagement do you expect?',
    answers: [
      { value: 'strategic', label: 'Strategy plus delivery', points: 3 },
      { value: 'delivery', label: 'Mostly delivery', points: 2 },
      { value: 'small-task', label: 'A small isolated task', points: 0 },
    ],
  },
  {
    id: 'budget',
    question: 'What investment range is realistic?',
    answers: [
      { value: '12k-plus', label: 'USD 12,000+', points: 3 },
      { value: '5k-12k', label: 'USD 5,000-12,000', points: 1 },
      { value: 'under-5k', label: 'Under USD 5,000', points: 0 },
    ],
  },
  {
    id: 'trust',
    question: 'How important is credibility to the buyer journey?',
    answers: [
      { value: 'critical', label: 'Critical', points: 3 },
      { value: 'important', label: 'Important', points: 2 },
      { value: 'basic', label: 'Basic', points: 1 },
    ],
  },
];
---

<BaseLayout
  title="Book a Diagnostic Call | Peter Bamuhigire"
  description="Book a diagnostic call with Peter Bamuhigire to discuss business management systems, software development, websites, ICT consulting, or business planning."
  lang={lang}
  page="contact"
>
  <section class="geo-pattern bg-navy-950 pt-24 pb-14 md:pt-32 md:pb-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl fade-up">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">Diagnostic call</p>
        <h1 class="mt-4 text-4xl font-bold text-warm-white md:text-6xl">
          Start with clarity, not a blind request for a quote.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-navy-200">
          The strongest enquiries explain the business context, the pressure to act, and what a good outcome would look like.
          Use the form below to do exactly that. Peter reviews qualified submissions personally.
        </p>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-navy-700 bg-navy-900/70 p-5 text-sm text-navy-200">
            <p class="font-semibold text-gold-400">Best fit</p>
            <p class="mt-2">Organisations that need cleaner business systems, ERP delivery, or lifecycle ownership of mission-critical software.</p>
          </div>
          <div class="rounded-2xl border border-navy-700 bg-navy-900/70 p-5 text-sm text-navy-200">
            <p class="font-semibold text-gold-400">Response target</p>
            <p class="mt-2">Qualified enquiries are reviewed within 48 hours.</p>
          </div>
          <div class="rounded-2xl border border-navy-700 bg-navy-900/70 p-5 text-sm text-navy-200">
            <p class="font-semibold text-gold-400">Commercial floor</p>
            <p class="mt-2">Project-led systems and software engagements start from USD 12,000.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:gap-12">
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-6 shadow-sm shadow-navy-900/5 md:p-8">
          <div
            x-data={`{
              state: 'idle',
              responseMessage: '',
              fieldErrors: [],
              csrfToken: '',
              csrfTs: 0,
              loadedAt: Math.floor(Date.now() / 1000),
              qualification: { urgency: '', scope: '', budget: '', trust: '' },
              formData: {
                name: '',
                email: '',
                phone: '',
                company: '',
                service: '',
                message: '',
                contact_method: 'email',
                website: ''
              },
              get qualificationScore() {
                const scoring = {
                  urgency: { '30-days': 3, quarter: 2, exploring: 1 },
                  scope: { strategic: 3, delivery: 2, 'small-task': 0 },
                  budget: { '12k-plus': 3, '5k-12k': 1, 'under-5k': 0 },
                  trust: { critical: 3, important: 2, basic: 1 }
                };
                return Object.entries(this.qualification).reduce((total, [key, value]) => total + (scoring[key]?.[value] || 0), 0);
              },
              get qualificationLabel() {
                if (this.qualificationScore >= 10) return 'High-fit enquiry';
                if (this.qualificationScore >= 6) return 'Promising but needs scoping';
                return 'Early-stage or lower-fit enquiry';
              },
              async init() {
                try {
                  const res = await fetch('/api/csrf-token.php');
                  const d = await res.json();
                  this.csrfToken = d.token;
                  this.csrfTs = d.ts;
                } catch (error) {}
              },
              validate() {
                this.fieldErrors = [];
                if (!this.formData.name || this.formData.name.trim().length < 2) this.fieldErrors.push('name');
                if (!this.formData.email || !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(this.formData.email)) this.fieldErrors.push('email');
                if (!this.formData.message || this.formData.message.trim().length < 20) this.fieldErrors.push('message');
                return this.fieldErrors.length === 0;
              },
              hasError(field) { return this.fieldErrors.includes(field); },
              async submitForm() {
                if (!this.validate()) return;
                this.state = 'submitting';
                try {
                  const res = await fetch('/api/contact.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      ...this.formData,
                      qualification_score: this.qualificationScore,
                      qualification_label: this.qualificationLabel,
                      qualification_answers: this.qualification,
                      lang: 'en',
                      _csrf_token: this.csrfToken,
                      _csrf_ts: this.csrfTs,
                      _loaded_at: this.loadedAt
                    })
                  });
                  const data = await res.json();
                  this.responseMessage = data.message;
                  this.state = data.success ? 'success' : 'error';
                  if (data.success && typeof window.gtag === 'function') {
                    window.gtag('event', 'lead_generated', {
                      form_id: 'contact-diagnostic',
                      page_path: window.location.pathname,
                      lead_fit: this.qualificationLabel,
                    });
                  }
                } catch (error) {
                  this.responseMessage = 'Something went wrong. Please email peter@techguypeter.com directly.';
                  this.state = 'error';
                }
              }
            }`}
            x-init="init()"
          >
            <div class="max-w-3xl">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Qualification first</p>
              <h2 class="mt-3 text-3xl font-bold text-navy-900">Help Peter understand the commercial context.</h2>
              <p class="mt-4 text-navy-600">
                The aim is to diagnose fit quickly: what needs solving, why now, what level of engagement makes sense, and how high the trust burden is in your market.
              </p>
            </div>

            <div class="mt-8 rounded-2xl border border-gold-400/25 bg-gold-50 p-5">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-amber-accent">Fit indicator</p>
                  <p class="mt-2 text-lg font-semibold text-navy-900" x-text="qualificationLabel"></p>
                </div>
                <div class="rounded-2xl bg-white px-4 py-3 text-center shadow-sm">
                  <p class="text-xs uppercase tracking-[0.2em] text-navy-400">Score</p>
                  <p class="text-3xl font-bold text-gold-700" x-text="qualificationScore"></p>
                </div>
              </div>
            </div>

            <div class="mt-8 space-y-6">
              {qualificationQuestions.map((question) => (
                <fieldset class="rounded-2xl border border-navy-100 bg-navy-50 p-5">
                  <legend class="text-base font-semibold text-navy-900">{question.question}</legend>
                  <div class="mt-4 grid gap-3 md:grid-cols-3">
                    {question.answers.map((answer) => (
                      <label class="cursor-pointer rounded-2xl border border-navy-200 bg-white p-4 transition hover:border-gold-400">
                        <input
                          type="radio"
                          class="sr-only"
                          name={question.id}
                          value={answer.value}
                          x-model={`qualification.${question.id}`}
                        />
                        <span class="block text-sm font-medium text-navy-900">{answer.label}</span>
                      </label>
                    ))}
                  </div>
                </fieldset>
              ))}
            </div>

            <div x-show="state === 'success'" x-cloak class="mt-8 rounded-2xl border border-green-200 bg-green-50 p-5 text-green-800">
              <p class="font-medium" x-text="responseMessage"></p>
            </div>

            <div x-show="state === 'error'" x-cloak class="mt-8 rounded-2xl border border-red-200 bg-red-50 p-5 text-red-700">
              <p x-text="responseMessage"></p>
            </div>

            <form id="contact-diagnostic" x-show="state !== 'success'" @submit.prevent="submitForm()" class="mt-8 space-y-6" novalidate>
              <div class="absolute -z-10 h-0 overflow-hidden opacity-0" aria-hidden="true">
                <input type="text" name="website" x-model="formData.website" tabindex="-1" autocomplete="off" />
              </div>

              <div class="grid gap-6 md:grid-cols-2">
                <div>
                  <label for="name" class="block text-sm font-medium text-navy-800">Full name</label>
                  <input id="name" type="text" x-model="formData.name" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3" :class="hasError('name') ? 'border-red-400' : ''" />
                  <p x-show="hasError('name')" class="mt-1 text-xs text-red-600">Please enter your full name.</p>
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-navy-800">Email address</label>
                  <input id="email" type="email" x-model="formData.email" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3" :class="hasError('email') ? 'border-red-400' : ''" />
                  <p x-show="hasError('email')" class="mt-1 text-xs text-red-600">Please enter a valid email.</p>
                </div>
              </div>

              <div class="grid gap-6 md:grid-cols-2">
                <div>
                  <label for="phone" class="block text-sm font-medium text-navy-800">Phone or WhatsApp</label>
                  <input id="phone" type="tel" x-model="formData.phone" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3" />
                </div>
                <div>
                  <label for="company" class="block text-sm font-medium text-navy-800">Company or organisation</label>
                  <input id="company" type="text" x-model="formData.company" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3" />
                </div>
              </div>

              <div class="grid gap-6 md:grid-cols-2">
                <div>
                  <label for="service" class="block text-sm font-medium text-navy-800">Primary area of interest</label>
                  <select id="service" x-model="formData.service" class="mt-2 w-full rounded-xl border border-navy-200 bg-white px-4 py-3">
                    <option value="">Select one</option>
                    {services.map((service) => (
                      <option value={service}>{service}</option>
                    ))}
                  </select>
                </div>
                <fieldset>
                  <legend class="block text-sm font-medium text-navy-800">Preferred contact method</legend>
                  <div class="mt-2 flex flex-wrap gap-3">
                    {contactMethods.map((method) => (
                      <label class="rounded-full border border-navy-200 px-4 py-2 text-sm text-navy-700">
                        <input type="radio" name="contact_method" value={method.value} x-model="formData.contact_method" class="mr-2" />
                        {method.label}
                      </label>
                    ))}
                  </div>
                </fieldset>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-navy-800">What needs to change, and why now?</label>
                <textarea
                  id="message"
                  rows="7"
                  x-model="formData.message"
                  class="mt-2 w-full rounded-2xl border border-navy-200 bg-white px-4 py-3"
                  :class="hasError('message') ? 'border-red-400' : ''"
                  placeholder="Describe the business context, the current frustration, who needs to be convinced, and what a successful outcome would look like."
                ></textarea>
                <p x-show="hasError('message')" class="mt-1 text-xs text-red-600">Please provide enough detail for a real diagnostic.</p>
              </div>

              <div class="rounded-2xl border border-navy-100 bg-warm-cream p-5 text-sm text-navy-600">
                Strong submissions explain the pressure to act, the business stakes, and the level of credibility or system improvement required.
              </div>

              <button type="submit" data-cta class="cta-button inline-flex items-center rounded-xl bg-amber-accent px-6 py-4 text-base font-semibold text-white transition hover:bg-gold-600" :disabled="state === 'submitting'">
                <span x-show="state !== 'submitting'">Send diagnostic request</span>
                <span x-show="state === 'submitting'" x-cloak>Sending...</span>
              </button>
            </form>
          </div>
        </div>

        <aside class="fade-up space-y-6">
          <div class="rounded-3xl border border-navy-100 bg-warm-cream p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Direct contact</p>
            <h2 class="mt-3 text-2xl font-bold text-navy-900">Alternative routes</h2>
            <div class="mt-5 space-y-3 text-navy-700">
              <p><a href="mailto:peter@techguypeter.com" class="font-medium text-gold-700 underline underline-offset-4">peter@techguypeter.com</a></p>
              <p><a href="tel:+256784464178" class="font-medium text-gold-700 underline underline-offset-4">+256 784 464178</a></p>
              <p>Bukoto, Kampala, Uganda</p>
            </div>
          </div>

          <div class="rounded-3xl border border-navy-100 bg-white p-6 shadow-sm shadow-navy-900/5">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">What happens next</p>
            <ol class="mt-5 space-y-4 text-sm text-navy-700">
              <li>Peter reviews the enquiry against fit, urgency, and scope.</li>
              <li>Qualified leads receive a reply with a recommended next step, not a vague “let’s talk”.</li>
              <li>If the fit is weak, Peter will say so directly and suggest a better route where possible.</li>
            </ol>
          </div>

          <div class="rounded-3xl border border-gold-400/20 bg-navy-900 p-6 text-warm-white">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">Good to know</p>
            <ul class="mt-5 space-y-3 text-sm text-navy-200">
              <li>Strategy-led website engagements start from USD 12,000.</li>
              <li>Retainers are available for care, SEO, content, CRO, and strategic technical support.</li>
              <li>English and French communication are both supported.</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
