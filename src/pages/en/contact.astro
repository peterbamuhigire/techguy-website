---

<BaseLayout
  title="Contact Peter Bamuhigire — IT Consultant, Kampala Uganda"
  description="Contact Peter Bamuhigire for software development, website design, IT consulting, and ERP systems in Kampala, Uganda. Available for projects across East Africa and internationally."
  lang={lang}
  page="contact"
>
  <!-- Hero Banner -->
  <section class="bg-navy-900 pt-20 md:pt-24 pb-12 md:pb-16 geo-pattern">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white">
        Get in Touch
      </h1>
      <p class="mt-4 text-lg md:text-xl text-navy-200 max-w-2xl mx-auto">
        Whether you have a project in mind, need strategic guidance, or simply wish to explore possibilities — enquiries are always welcome.
      </p>
      <div class="mt-6 h-1 w-20 rounded-full bg-gold-400 mx-auto"></div>
    </div>
  </section>

  <!-- Main Content: Form + Contact Info -->
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">

        <!-- Left Column: Consultation Form (3/5 width) -->
        <div class="lg:col-span-3 fade-up">
          <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
            <h2 class="text-2xl md:text-3xl font-bold text-navy-900">
              Book a Consultation
            </h2>
            <p class="mt-3 text-navy-600 leading-relaxed">
              Every engagement begins with a conversation. Kindly share your details and a brief description of your project.
            </p>

            <div
              x-data="{
                state: 'idle',
                responseMessage: '',
                fieldErrors: [],
                csrfToken: '',
                csrfTs: 0,
                loadedAt: Math.floor(Date.now() / 1000),
                formData: {
                  name: '',
                  email: '',
                  phone: '',
                  company: '',
                  service: '',
                  message: '',
                  contact_method: 'phone',
                  website: ''
                },
                async init() {
                  try {
                    const res = await fetch('/api/csrf-token.php');
                    const d = await res.json();
                    this.csrfToken = d.token;
                    this.csrfTs = d.ts;
                  } catch(e) {}
                },
                validate() {
                  this.fieldErrors = [];
                  if (!this.formData.name || this.formData.name.trim().length < 2) this.fieldErrors.push('name');
                  if (!this.formData.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.formData.email)) this.fieldErrors.push('email');
                  if (!this.formData.message || this.formData.message.trim().length < 5) this.fieldErrors.push('message');
                  return this.fieldErrors.length === 0;
                },
                hasError(field) { return this.fieldErrors.includes(field); },
                async submitForm() {
                  if (!this.validate()) return;
                  this.state = 'submitting';
                  try {
                    const res = await fetch('/api/contact.php', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({
                        ...this.formData,
                        lang: 'en',
                        _csrf_token: this.csrfToken,
                        _csrf_ts: this.csrfTs,
                        _loaded_at: this.loadedAt
                      })
                    });
                    const data = await res.json();
                    this.responseMessage = data.message;
                    this.state = data.success ? 'success' : 'error';
                  } catch(e) {
                    this.responseMessage = 'Something went wrong. Please email peter@techguypeter.com directly.';
                    this.state = 'error';
                  }
                }
              }"
              x-init="init()"
            >
              <!-- Success state -->
              <div x-show="state === 'success'" x-cloak class="mt-8 p-6 bg-green-50 border border-green-200 rounded-xl">
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <p class="text-green-800 font-medium" x-text="responseMessage"></p>
                </div>
              </div>

              <!-- Error banner -->
              <div x-show="state === 'error'" x-cloak class="mt-8 p-4 bg-red-50 border border-red-200 rounded-xl">
                <p class="text-red-700 text-sm" x-text="responseMessage"></p>
              </div>

              <!-- Form -->
              <form
                x-show="state !== 'success'"
                @submit.prevent="submitForm()"
                class="mt-8 space-y-6"
                novalidate
              >
                <!-- Honeypot (hidden from real users) -->
                <div class="absolute opacity-0 -z-10 h-0 overflow-hidden" aria-hidden="true">
                  <input type="text" name="website" x-model="formData.website" tabindex="-1" autocomplete="off" />
                </div>

                <!-- Full Name -->
                <div>
                  <label for="full-name" class="block text-sm font-medium text-navy-800 mb-1.5">
                    Full Name <span class="text-amber-accent" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="text"
                    id="full-name"
                    x-model="formData.name"
                    autocomplete="name"
                    placeholder="e.g. Jane Nakato"
                    :class="hasError('name') ? 'border-red-400 focus:ring-red-500' : 'border-navy-200 focus:ring-gold-500'"
                    class="w-full px-4 py-3 bg-navy-50 border rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:border-transparent transition-colors"
                  />
                  <p x-show="hasError('name')" class="mt-1 text-xs text-red-600">Please enter your full name.</p>
                </div>

                <!-- Email Address -->
                <div>
                  <label for="email" class="block text-sm font-medium text-navy-800 mb-1.5">
                    Email Address <span class="text-amber-accent" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    x-model="formData.email"
                    autocomplete="email"
                    placeholder="jane@company.com"
                    :class="hasError('email') ? 'border-red-400 focus:ring-red-500' : 'border-navy-200 focus:ring-gold-500'"
                    class="w-full px-4 py-3 bg-navy-50 border rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:border-transparent transition-colors"
                  />
                  <p x-show="hasError('email')" class="mt-1 text-xs text-red-600">Please enter a valid email address.</p>
                </div>

                <!-- Phone Number -->
                <div>
                  <label for="phone" class="block text-sm font-medium text-navy-800 mb-1.5">
                    Phone Number <span class="text-navy-400 text-xs font-normal">(optional)</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    x-model="formData.phone"
                    autocomplete="tel"
                    placeholder="+256 7XX XXX XXX"
                    class="w-full px-4 py-3 bg-navy-50 border border-navy-200 rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-colors"
                  />
                </div>

                <!-- Company / Organisation -->
                <div>
                  <label for="company" class="block text-sm font-medium text-navy-800 mb-1.5">
                    Company / Organisation <span class="text-navy-400 text-xs font-normal">(optional)</span>
                  </label>
                  <input
                    type="text"
                    id="company"
                    x-model="formData.company"
                    autocomplete="organization"
                    placeholder="Your company or organisation name"
                    class="w-full px-4 py-3 bg-navy-50 border border-navy-200 rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-colors"
                  />
                </div>

                <!-- Service Interest -->
                <div>
                  <label for="service" class="block text-sm font-medium text-navy-800 mb-1.5">
                    Service Interest
                  </label>
                  <select
                    id="service"
                    x-model="formData.service"
                    class="w-full px-4 py-3 bg-navy-50 border border-navy-200 rounded-lg text-navy-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent transition-colors appearance-none"
                    style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2720%27 height=%2720%27 viewBox=%270 0 20 20%27 fill=%27%237986CB%27%3E%3Cpath fill-rule=%27evenodd%27 d=%27M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z%27 clip-rule=%27evenodd%27/%3E%3C/svg%3E'); background-position: right 0.75rem center; background-repeat: no-repeat; background-size: 1.25rem;"
                  >
                    <option value="">Select a service</option>
                    {serviceOptions.map((option) => (
                      <option value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                <!-- Project Description -->
                <div>
                  <label for="message" class="block text-sm font-medium text-navy-800 mb-1.5">
                    Project Description <span class="text-amber-accent" aria-hidden="true">*</span>
                  </label>
                  <textarea
                    id="message"
                    x-model="formData.message"
                    rows="4"
                    placeholder="Briefly describe your project, goals, and any relevant context..."
                    :class="hasError('message') ? 'border-red-400 focus:ring-red-500' : 'border-navy-200 focus:ring-gold-500'"
                    class="w-full px-4 py-3 bg-navy-50 border rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:border-transparent transition-colors resize-vertical"
                  ></textarea>
                  <p x-show="hasError('message')" class="mt-1 text-xs text-red-600">Please describe your project or requirements.</p>
                </div>

                <!-- Preferred Contact Method -->
                <fieldset>
                  <legend class="block text-sm font-medium text-navy-800 mb-3">
                    Preferred Contact Method
                  </legend>
                  <div class="flex flex-wrap gap-4">
                    {contactMethods.map((method) => (
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input
                          type="radio"
                          name="contact_method"
                          value={method.value}
                          x-model="formData.contact_method"
                          class="w-4 h-4 text-gold-500 border-navy-300 focus:ring-gold-500 focus:ring-2 accent-gold-500"
                        />
                        <span class="text-sm text-navy-700 group-hover:text-navy-900 transition-colors">
                          {method.label}
                        </span>
                      </label>
                    ))}
                  </div>
                </fieldset>

                <!-- Submit Button -->
                <div>
                  <button
                    type="submit"
                    :disabled="state === 'submitting'"
                    class="w-full sm:w-auto px-8 py-4 bg-amber-accent hover:bg-gold-600 disabled:opacity-60 disabled:cursor-not-allowed text-white text-lg font-semibold rounded-lg transition-colors shadow-lg shadow-amber-accent/20 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:ring-offset-2"
                  >
                    <span x-show="state !== 'submitting'">Book a Consultation</span>
                    <span x-show="state === 'submitting'" x-cloak class="flex items-center gap-2">
                      <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                      </svg>
                      Sending…
                    </span>
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- Right Column: Contact Information (2/5 width) -->
        <div class="lg:col-span-2 space-y-6 fade-up">

          <!-- Phone Numbers -->
          <div class="bg-navy-50 rounded-2xl p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-navy-100 rounded-lg">
                <svg class="w-5 h-5 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy-800">Phone</h3>
                <a href="tel:+256784464178" class="mt-1 block text-navy-700 hover:text-gold-600 transition-colors font-medium">
                  +256 784 464178
                </a>
                <span class="inline-flex items-center gap-1 mt-1 px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700 rounded-full">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
                  </svg>
                  WhatsApp
                </span>
                <a href="tel:+256741430561" class="mt-3 block text-sm text-navy-600 hover:text-gold-600 transition-colors">
                  +256 741 430561 <span class="text-navy-400">(alternative)</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="bg-navy-50 rounded-2xl p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-navy-100 rounded-lg">
                <svg class="w-5 h-5 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy-800">Email</h3>
                <a href="mailto:peter@techguypeter.com" class="mt-1 block text-navy-700 hover:text-gold-600 transition-colors font-medium">
                  peter@techguypeter.com
                </a>
              </div>
            </div>
          </div>

          <!-- Location -->
          <div class="bg-navy-50 rounded-2xl p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-navy-100 rounded-lg">
                <svg class="w-5 h-5 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy-800">Location</h3>
                <p class="mt-1 text-navy-700 font-medium">
                  Sserumaga Road, Bukoto
                </p>
                <p class="text-navy-600">Kampala, Uganda</p>
              </div>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="bg-navy-50 rounded-2xl p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-navy-100 rounded-lg">
                <svg class="w-5 h-5 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy-800">Business Hours</h3>
                <p class="mt-1 text-navy-700 font-medium">
                  Monday &ndash; Saturday
                </p>
                <p class="text-navy-600">9:00 AM &ndash; 6:00 PM EAT</p>
              </div>
            </div>
          </div>

          <!-- Response Commitment -->
          <div class="bg-gold-50 rounded-2xl p-6 border border-gold-200">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-gold-100 rounded-lg">
                <svg class="w-5 h-5 text-gold-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy-800">Response Commitment</h3>
                <p class="mt-1 text-navy-700 text-sm leading-relaxed">
                  Consultations typically scheduled within 48 hours.
                </p>
              </div>
            </div>
          </div>

          <!-- International Note -->
          <div class="bg-navy-50 rounded-2xl p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center bg-navy-100 rounded-lg">
                <svg class="w-5 h-5 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy-800">International Clients</h3>
                <p class="mt-1 text-navy-700 text-sm leading-relaxed">
                  Remote consultations available across all time zones.
                </p>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="bg-navy-50 rounded-2xl p-6">
            <h3 class="text-sm font-semibold text-navy-800 mb-4">Connect Online</h3>
            <div class="flex items-center gap-3">
              {socials.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 flex items-center justify-center rounded-full bg-navy-100 hover:bg-gold-500 text-navy-600 hover:text-white transition-colors"
                  aria-label={`Visit Peter on ${s.name}`}
                >
                  <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d={s.icon}/></svg>
                </a>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section class="py-16 md:py-20 bg-warm-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-navy-800 via-navy-900 to-navy-950 h-64 md:h-80 flex items-center justify-center">
          <!-- Decorative grid overlay -->
          <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(240,194,67,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(240,194,67,0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>

          <!-- Location pin and text -->
          <div class="relative text-center px-4">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gold-500/20 rounded-full mb-4">
              <svg class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-warm-white">
              Bukoto, Kampala
            </h3>
            <p class="mt-2 text-navy-300">
              Sserumaga Road, Bukoto &middot; Kampala, Uganda
            </p>
            <a
              href="https://www.google.com/maps/search/Sserumaga+Road+Bukoto+Kampala+Uganda"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 bg-white/10 hover:bg-white/20 text-warm-white text-sm font-medium rounded-lg transition-colors backdrop-blur-sm border border-white/10"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              Open in Google Maps
            </a>
          </div>

          <!-- Decorative ping animation -->
          <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2">
            <div class="w-3 h-3 bg-gold-400 rounded-full animate-ping opacity-30"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection lang={lang} />
</BaseLayout>
