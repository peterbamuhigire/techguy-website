---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { Lang } from '@/utils/i18n';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import OfferTierCard from '@/components/OfferTierCard.astro';
import ProofBlock from '@/components/ProofBlock.astro';
import TestimonialCard from '@/components/TestimonialCard.astro';
import { siteConfig } from '@/data/site';

import heroImage from '@/assets/images/hero/home-page-photo.jpg';
import maduukaImg from '@/assets/images/portfolio/MADUUKASOFTWARE-01.jpg';
import aqarImg from '@/assets/images/portfolio/PROPERTY-MANAGEMENT-01.jpg';
import longhornImg from '@/assets/images/portfolio/ERP-01.jpg';

const lang: Lang = 'en';
const stats = siteConfig.proof.stats;
const tiers = siteConfig.offers.projectTiers;
const retainers = siteConfig.offers.retainers;
const testimonials = siteConfig.proof.testimonials;
const cases = siteConfig.proof.cases;
---

<BaseLayout
  title="Authority Website Systems, Software & ICT Strategy | Peter Bamuhigire"
  description="Authority website systems, software, ICT consulting, and strategic digital delivery for serious organisations in Uganda, East Africa, and francophone Africa."
  lang={lang}
  page="home"
>
  <section id="hero" class="relative overflow-hidden bg-navy-950">
    <div class="absolute inset-0 geo-pattern opacity-30"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(240,194,67,0.18),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(199,91,18,0.22),transparent_30%)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 pt-24 pb-16 sm:px-6 lg:px-8 lg:pt-32 lg:pb-24">
      <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <div class="fade-up">
          <p class="text-sm font-semibold uppercase tracking-[0.26em] text-gold-400">{siteConfig.hero.en.eyebrow}</p>
          <h1 class="mt-5 max-w-4xl text-4xl font-bold leading-tight text-warm-white md:text-6xl">
            {siteConfig.hero.en.title}
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed text-navy-200 md:text-xl">
            {siteConfig.hero.en.subtitle}
          </p>
          <p class="mt-5 max-w-3xl text-base leading-relaxed text-navy-300">
            {siteConfig.categoryClaim.en} {siteConfig.hero.en.qualifier}
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href="/en/contact/" data-cta class="cta-button inline-flex items-center justify-center rounded-xl bg-amber-accent px-7 py-4 text-lg font-semibold text-white transition hover:bg-gold-600">
              Book a diagnostic call
            </a>
            <a href="/en/pricing/" class="inline-flex items-center justify-center rounded-xl border border-gold-400 px-7 py-4 text-lg font-semibold text-gold-400 transition hover:bg-gold-400/10">
              See pricing and fit
            </a>
          </div>
          <div class="mt-8 grid gap-3 text-sm text-navy-200 sm:grid-cols-3">
            <div class="rounded-2xl border border-navy-700 bg-navy-900/60 p-4">
              <p class="font-semibold text-gold-400">Positioning first</p>
              <p class="mt-2 text-navy-300">No generic builds. Every project starts with diagnosis and message clarity.</p>
            </div>
            <div class="rounded-2xl border border-navy-700 bg-navy-900/60 p-4">
              <p class="font-semibold text-gold-400">Built for trust</p>
              <p class="mt-2 text-navy-300">Ideal for firms where reputation, credibility, and stakeholder confidence drive buying decisions.</p>
            </div>
            <div class="rounded-2xl border border-navy-700 bg-navy-900/60 p-4">
              <p class="font-semibold text-gold-400">Measured delivery</p>
              <p class="mt-2 text-navy-300">Analytics, schema, conversion events, and post-launch support are part of the system.</p>
            </div>
          </div>
        </div>

        <div class="fade-up">
          <div class="relative mx-auto max-w-md lg:max-w-lg">
            <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-gold-400/25 via-transparent to-amber-accent/20 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[2rem] border border-gold-400/20 shadow-2xl shadow-black/35">
              <Image
                src={heroImage}
                alt="Peter Bamuhigire working with clients on strategy, software, and digital systems"
                width={640}
                height={760}
                loading="eager"
                class="h-full w-full object-cover"
              />
            </div>
            <div class="absolute -bottom-5 -left-5 rounded-2xl border border-gold-400/30 bg-navy-950/95 px-5 py-4 text-warm-white shadow-xl">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-gold-400">Best fit</p>
              <p class="mt-2 text-sm leading-relaxed">Consultancies, institutions, ambitious SMEs, funded ventures, and teams operating across African markets.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-navy-900 py-12 md:py-16">
    <div class="mx-auto grid max-w-6xl gap-6 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      {stats.map((stat) => (
        <div class="fade-up rounded-2xl border border-navy-700 bg-navy-950/50 p-6 text-center">
          <p class="counter text-4xl font-bold text-gold-400" data-target={parseInt(stat.value, 10) || 0}>{stat.value}</p>
          <p class="mt-3 text-sm leading-relaxed text-navy-200">{stat.labelEn}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">What this practice does</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Three ways Peter creates commercial leverage.</h2>
        <p class="mt-5 text-lg leading-relaxed text-navy-600">
          The work is not sold as disconnected services. It is designed as a system that helps buyers trust you, helps teams operate better, and helps leadership make cleaner decisions.
        </p>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Authority websites</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Websites that carry the reputation, not just the contact form.</h3>
          <p class="mt-4 text-navy-600">
            Strategy-led websites for firms that need to look credible to boards, investors, donors, enterprise buyers, and high-value referrals.
          </p>
          <ul class="mt-5 space-y-3 text-sm text-navy-700">
            <li>Positioning, message, proof architecture, and CTA ladder</li>
            <li>SEO, schema, analytics, and multilingual capability</li>
            <li>Launch handover plus retainer-ready support options</li>
          </ul>
        </div>
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Software and systems</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Custom tools that reduce friction in real operations.</h3>
          <p class="mt-4 text-navy-600">
            From ERP-style workflows to reporting tools and sector-specific applications, the focus stays on practical adoption, not technical theatre.
          </p>
          <ul class="mt-5 space-y-3 text-sm text-navy-700">
            <li>Operationally grounded design and implementation</li>
            <li>Reporting, data visibility, and AI-ready foundations</li>
            <li>Systems that fit African business reality, not imported assumptions</li>
          </ul>
        </div>
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">ICT and business strategy</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Clear direction when the digital stakes are high.</h3>
          <p class="mt-4 text-navy-600">
            Ideal when leadership needs a sober recommendation on systems, digital growth, business planning, or cross-country execution.
          </p>
          <ul class="mt-5 space-y-3 text-sm text-navy-700">
            <li>Technology roadmaps and implementation advice</li>
            <li>Business planning and investor-facing documentation</li>
            <li>Diagnostic clarity before money is wasted on the wrong build</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Proof placement</p>
          <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Recent systems and transformation signals.</h2>
          <p class="mt-5 text-lg text-navy-600">
            The goal is not abstract capability. It is systems and digital assets that become usable, measurable, and commercially credible.
          </p>
        </div>
        <a href="/en/portfolio/" class="text-sm font-semibold text-gold-700 underline underline-offset-4">See portfolio evidence</a>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={maduukaImg} alt="Maduuka SaaS software platform" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[0].titleEn} summary={cases[0].summaryEn} />
          </div>
        </div>
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={aqarImg} alt="Aqar property management platform" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[1].titleEn} summary={cases[1].summaryEn} />
          </div>
        </div>
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={longhornImg} alt="Longhorn ERP dashboard" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[2].titleEn} summary={cases[2].summaryEn} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Offer architecture</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Project tiers built for serious digital work.</h2>
        <p class="mt-5 text-lg text-navy-600">
          These are consulting-led engagement levels. The higher the tier, the more strategic, technical, and cross-functional depth the work demands.
        </p>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {tiers.map((tier) => (
          <div class="fade-up">
            <OfferTierCard
              name={tier.name}
              price={tier.price}
              description={tier.descriptionEn}
              bullets={tier.bulletsEn}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy-950 py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">Retention architecture</p>
        <h2 class="mt-4 text-3xl font-bold text-warm-white md:text-5xl">What happens after launch is now explicit.</h2>
        <p class="mt-5 text-lg text-navy-200">
          Prospects should not wonder whether support exists. They should see the path from project to ongoing partnership immediately.
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {retainers.map((retainer) => (
          <article class="fade-up rounded-3xl border border-navy-800 bg-navy-900 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">{retainer.price}</p>
            <h3 class="mt-3 text-xl font-bold text-warm-white">{retainer.nameEn}</h3>
            <p class="mt-4 text-sm leading-relaxed text-navy-300">{retainer.summaryEn}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Social proof</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">What trust-heavy clients need to hear.</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {testimonials.map((testimonial) => (
          <div class="fade-up">
            <TestimonialCard
              quote={testimonial.quoteEn}
              name={testimonial.name}
              role={testimonial.role}
              highlight={testimonial.highlightEn}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQSection
    title="Questions prospects ask before they enquire"
    subtitle="The site now answers the commercial questions directly, instead of hiding them behind vague claims."
    faqs={siteConfig.faqs.en}
  />

  <section class="bg-navy-50 py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <NewsletterSignup lang={lang} />
      </div>
    </div>
  </section>

  <CTASection
    lang={lang}
    title="If your reputation is stronger than your current digital presence, fix that next."
    subtitle="The first conversation is diagnostic. We identify where the current site, message, or system is costing you trust, time, or opportunity, then recommend one clear direction."
    ctaHref="/en/contact/"
    ctaLabel="Book a diagnostic call"
    secondaryHref="/en/pricing/"
    secondaryLabel="Review pricing and fit"
  />
</BaseLayout>
