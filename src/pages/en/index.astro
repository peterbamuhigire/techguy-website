---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { t } from '@/utils/i18n';
import type { Lang } from '@/utils/i18n';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import StatCard from '@/components/StatCard.astro';

import heroImage from '@/assets/images/hero/home-page-photo.jpg';
import maduukaImg from '@/assets/images/portfolio/MADUUKASOFTWARE-01.jpg';
import aqarImg from '@/assets/images/portfolio/PROPERTY-MANAGEMENT-01.jpg';
import longhornImg from '@/assets/images/portfolio/ERP-01.jpg';

const lang: Lang = 'en';

const services = [
  {
    title: 'Software Development',
    description: 'Custom software solutions — from web applications and mobile apps to full SaaS platforms — built to solve the specific challenges your business faces.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>',
    href: '/en/services/#software-development',
    linkText: t('cta.learn_more', lang),
  },
  {
    title: 'ICT Consulting & Strategy',
    description: 'Strategic technology advisory that helps organisations plan, implement, and manage their ICT infrastructure for long-term reliability and growth.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/></svg>',
    href: '/en/services/#ict-consulting',
    linkText: t('cta.learn_more', lang),
  },
  {
    title: 'Business Consulting',
    description: 'Business advisory services that bridge the gap between organisational goals and the operational processes needed to achieve them.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>',
    href: '/en/services/#business-consulting',
    linkText: t('cta.learn_more', lang),
  },
  {
    title: 'Property Management Technology',
    description: 'Specialised PropTech solutions that help landlords and property managers digitise their operations, track tenants, and manage portfolios efficiently.',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5M3.75 3v18m4.5-18v18m4.5-18v18m4.5-18v18M6 6.75h.008v.008H6V6.75zm0 3.75h.008v.008H6v-.008zm0 3.75h.008v.008H6v-.008zm4.5-7.5h.008v.008h-.008V6.75zm0 3.75h.008v.008h-.008v-.008zm0 3.75h.008v.008h-.008v-.008zm4.5-7.5h.008v.008h-.008V6.75zm0 3.75h.008v.008h-.008v-.008zm0 3.75h.008v.008h-.008v-.008z"/></svg>',
    href: '/en/services/#property-management',
    linkText: t('cta.learn_more', lang),
  },
];
---

<BaseLayout
  title="Peter Bamuhigire — IT Consultant & Software Developer, Kampala Uganda"
  description="IT consultant and software developer in Kampala, Uganda with 15+ years' experience. Custom software development, website design, ICT consulting, and ERP systems across 10+ African countries."
  lang={lang}
  page="home"
>

  <!-- ==============================
       HERO SECTION
       ============================== -->
  <section class="relative bg-navy-950 overflow-hidden">
    <!-- Subtle background pattern -->
    <div class="absolute inset-0 geo-pattern opacity-30"></div>
    <!-- Gradient overlay for depth -->
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900/80 to-navy-950"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-24">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center py-16 md:py-20 lg:py-28">
        <!-- Left: Text content -->
        <div class="order-2 lg:order-1">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-6">
            <span class="w-2 h-2 rounded-full bg-gold-400 animate-pulse"></span>
            <span class="text-gold-400 text-sm font-medium">Available for new projects</span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white leading-tight">
            Building Technology Solutions
            <span class="text-gold-400"> Across Africa</span>
            & Beyond
          </h1>

          <p class="mt-6 text-lg md:text-xl text-navy-200 max-w-xl leading-relaxed">
            15+ years of software development, ICT consulting, and business advisory across 10+ African countries. Practical solutions that deliver real business results.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a
              href="/en/contact/"
              class="inline-flex items-center justify-center px-8 py-4 bg-amber-accent hover:bg-amber-accent/90 text-white text-lg font-semibold rounded-lg transition-all duration-300 shadow-lg shadow-amber-accent/20 hover:shadow-xl hover:shadow-amber-accent/30 hover:-translate-y-0.5"
            >
              {t('cta.book', lang)}
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </a>
            <a
              href="/en/portfolio/"
              class="inline-flex items-center justify-center px-8 py-4 border-2 border-gold-400 text-gold-400 hover:bg-gold-400/10 text-lg font-semibold rounded-lg transition-all duration-300 hover:-translate-y-0.5"
            >
              {t('cta.view_work', lang)}
            </a>
          </div>

          <!-- Quick trust indicators -->
          <div class="mt-10 flex items-center gap-6 text-navy-300 text-sm">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span>Pan-African reach</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span>Full-stack expertise</span>
            </div>
            <div class="hidden sm:flex items-center gap-2">
              <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span>Bilingual (EN/FR)</span>
            </div>
          </div>
        </div>

        <!-- Right: Hero image -->
        <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
          <div class="relative">
            <!-- Decorative frame -->
            <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/20 via-transparent to-gold-400/10 rounded-2xl -rotate-2"></div>
            <div class="absolute -inset-3 border-2 border-gold-400/20 rounded-2xl rotate-1"></div>
            <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-navy-950/50">
              <Image
                src={heroImage}
                alt="Peter Bamuhigire — Technology and Business Consultant"
                width={560}
                height={640}
                loading="eager"
                class="w-full max-w-md lg:max-w-lg object-cover"
              />
            </div>
            <!-- Floating accent -->
            <div class="absolute -bottom-4 -left-4 bg-gold-400 text-navy-950 px-4 py-2 rounded-lg font-bold text-sm shadow-lg">
              15+ Years Experience
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom wave divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60V20C240 0 480 0 720 20C960 40 1200 40 1440 20V60H0Z" fill="var(--color-navy-800)"/>
      </svg>
    </div>
  </section>

  <!-- ==============================
       STATS STRIP
       ============================== -->
  <section class="bg-navy-800 py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 fade-up">
        <StatCard number="15" label={t('stats.years', lang)} />
        <StatCard number="10" label={t('stats.countries', lang)} />
        <StatCard number="3" label={t('stats.products', lang)} suffix="" />
        <StatCard number="6" label={t('stats.industries', lang)} />
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICES SECTION
       ============================== -->
  <section class="bg-warm-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <SectionHeading
          title={t('section.services', lang)}
          subtitle={t('section.services_intro', lang)}
        />
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 fade-up">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
            href={service.href}
            linkText={service.linkText}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ==============================
       FLAGSHIP PRODUCTS SHOWCASE
       ============================== -->
  <section class="bg-warm-cream py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <SectionHeading
          title={t('section.products', lang)}
          subtitle="Proprietary SaaS platforms built to serve real business needs across Africa and beyond."
        />
      </div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 fade-up">
        <!-- Maduuka -->
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-navy-100 transition-all duration-500 hover:-translate-y-1 flex flex-col">
          <div class="relative h-48 md:h-56 overflow-hidden">
            <Image
              src={maduukaImg}
              alt="Maduuka Business Management Software — SaaS platform for SMEs"
              width={600}
              height={400}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute top-3 left-3">
              <span class="px-3 py-1 bg-navy-900/80 backdrop-blur-sm text-gold-400 text-xs font-medium rounded-full">SaaS Platform</span>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-navy-900 font-heading mb-2">Maduuka</h3>
            <p class="text-navy-600 text-sm leading-relaxed mb-4 flex-1">
              Multi-tenant SaaS bookkeeping and business management platform for SMEs. POS, inventory, accounting, and asset management — available in 5 languages.
            </p>
            <a href="/en/portfolio/" class="inline-flex items-center text-sm font-semibold text-gold-600 hover:text-amber-accent transition-colors gap-1.5 group-hover:gap-2">
              View details
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Aqar -->
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-navy-100 transition-all duration-500 hover:-translate-y-1 flex flex-col">
          <div class="relative h-48 md:h-56 overflow-hidden">
            <Image
              src={aqarImg}
              alt="Aqar Property Management Software — PropTech for landlords"
              width={600}
              height={400}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute top-3 left-3">
              <span class="px-3 py-1 bg-navy-900/80 backdrop-blur-sm text-gold-400 text-xs font-medium rounded-full">PropTech</span>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-navy-900 font-heading mb-2">Aqar</h3>
            <p class="text-navy-600 text-sm leading-relaxed mb-4 flex-1">
              Property management software for landlords and managers. Tenant onboarding, rent tracking, maintenance, and financial reporting across Africa and the UK.
            </p>
            <a href="https://aqarproperty.co.uk" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-gold-600 hover:text-amber-accent transition-colors gap-1.5 group-hover:gap-2">
              Visit Aqar
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Longhorn ERP -->
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-navy-100 transition-all duration-500 hover:-translate-y-1 flex flex-col">
          <div class="relative h-48 md:h-56 overflow-hidden">
            <Image
              src={longhornImg}
              alt="Longhorn ERP — Cloud-based enterprise resource planning system"
              width={600}
              height={400}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute top-3 left-3">
              <span class="px-3 py-1 bg-navy-900/80 backdrop-blur-sm text-gold-400 text-xs font-medium rounded-full">ERP</span>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold text-navy-900 font-heading mb-2">Longhorn ERP</h3>
            <p class="text-navy-600 text-sm leading-relaxed mb-4 flex-1">
              Cloud-based ERP system with web and mobile applications. Custom-built enterprise resource planning for businesses requiring integrated operations management.
            </p>
            <a href="https://chwezi.co.za/en/technology/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-gold-600 hover:text-amber-accent transition-colors gap-1.5 group-hover:gap-2">
              Find out more
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       WHY PETER SECTION
       ============================== -->
  <section class="bg-navy-900 py-16 md:py-24 geo-pattern relative overflow-hidden">
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900/95 to-navy-900/90"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <SectionHeading
          title={t('section.why', lang)}
          subtitle="A rare combination of deep technical capability and genuine business understanding, forged across Africa's most dynamic markets."
          light
        />
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12 fade-up">
        <!-- Pan-African Experience -->
        <div class="text-center group">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-6 group-hover:bg-gold-400/20 transition-colors">
            <svg class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-warm-white mb-3">Pan-African Experience</h3>
          <p class="text-navy-200 leading-relaxed">
            Operations spanning East and West Africa — Uganda, Kenya, Tanzania, Rwanda, DRC, Senegal, Sierra Leone, and Guinea. Fluent in English and French business environments. Real understanding of African markets, not theoretical assumptions.
          </p>
        </div>

        <!-- Technical Depth -->
        <div class="text-center group">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-6 group-hover:bg-gold-400/20 transition-colors">
            <svg class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-warm-white mb-3">Technical Depth</h3>
          <p class="text-navy-200 leading-relaxed">
            A full-stack developer who builds, not just advises. From database architecture and API design to mobile applications and SaaS platforms — Peter writes the code, manages the servers, and delivers production-grade systems.
          </p>
        </div>

        <!-- Business Understanding -->
        <div class="text-center group">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-gold-400/10 border border-gold-400/20 flex items-center justify-center mb-6 group-hover:bg-gold-400/20 transition-colors">
            <svg class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-warm-white mb-3">Business Understanding</h3>
          <p class="text-navy-200 leading-relaxed">
            Consulting that starts with business outcomes, not technology assumptions. Peter combines technical capability with genuine business advisory experience — process analysis, strategic planning, M&E frameworks, and data-driven decision-making.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       TESTIMONIALS SECTION
       ============================== -->
  <section class="bg-warm-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <SectionHeading
          title={t('section.testimonials', lang)}
          subtitle="Trusted by organisations across Africa and internationally."
        />
      </div>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-10 fade-up">
        <!-- Testimonial 1 -->
        <div class="relative bg-white rounded-2xl p-8 md:p-10 shadow-sm border border-navy-100">
          <!-- Quotation mark -->
          <div class="absolute -top-4 left-8">
            <div class="w-10 h-10 rounded-full bg-gold-400 flex items-center justify-center shadow-md">
              <svg class="w-5 h-5 text-navy-900" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/>
              </svg>
            </div>
          </div>
          <blockquote class="mt-4">
            <p class="text-navy-700 leading-relaxed italic">
              "When we needed someone to manage our ICT operations across three West African countries, Peter delivered beyond our expectations. He unified our ERP systems, trained our staff in both French and English, and ensured data accuracy across all our regional offices."
            </p>
          </blockquote>
          <div class="mt-6 flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-navy-200 to-navy-300 flex items-center justify-center">
              <span class="text-navy-700 font-bold text-sm">DA</span>
            </div>
            <div>
              <p class="font-semibold text-navy-900 text-sm">Dynapharm Africa</p>
            </div>
          </div>
          <!-- Star rating -->
          <div class="mt-4 flex gap-1">
            {[1,2,3,4,5].map(() => (
