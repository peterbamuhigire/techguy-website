---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import OfferTierCard from '@/components/OfferTierCard.astro';
import type { Lang } from '@/utils/i18n';
import { siteConfig } from '@/data/site';

const lang: Lang = 'en';
---

<BaseLayout
  title="Pricing and Engagement Fit | Peter Bamuhigire"
  description="Transparent pricing guidance for authority websites, strategic digital delivery, and ongoing retainers."
  lang={lang}
  page="pricing"
  altUrl="/fr/tarifs/"
>
  <section class="geo-pattern bg-navy-950 pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl fade-up">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">Pricing transparency</p>
        <h1 class="mt-4 text-4xl font-bold text-warm-white md:text-6xl">Serious digital work deserves serious commercial clarity.</h1>
        <p class="mt-6 text-lg leading-relaxed text-navy-200">
          The point of this page is not to turn strategic work into a price list. It is to help you judge fit quickly:
          the level of work involved, who each tier is for, and what ongoing support looks like after launch.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <h2 class="text-3xl font-bold text-navy-900 md:text-5xl">Project tiers</h2>
        <p class="mt-5 text-lg text-navy-600">Each tier is a complete system. The difference is not whether you get a “real website”; it is the strategic weight, proof burden, and growth architecture involved.</p>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {siteConfig.offers.projectTiers.map((tier) => (
          <div class="fade-up">
            <OfferTierCard name={tier.name} price={tier.price} description={tier.descriptionEn} bullets={tier.bulletsEn} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 md:grid-cols-2">
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">What drives price</p>
          <ul class="mt-5 space-y-3 text-navy-700">
            <li>How much strategy, audience diagnosis, and positioning work is required.</li>
            <li>How many distinct services, markets, or stakeholder groups the site must speak to.</li>
            <li>How much proof, content architecture, multilingual support, and post-launch measurement is needed.</li>
            <li>Whether the website is a brochure, a growth lever, or a reputation-critical business asset.</li>
          </ul>
        </div>
        <div class="fade-up rounded-3xl border border-gold-400/20 bg-navy-900 p-7 text-warm-white">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">What is not sold</p>
          <ul class="mt-5 space-y-3 text-navy-200">
            <li>Hourly “developer for hire” work without strategic ownership.</li>
            <li>Cheap brochure builds for buyers shopping on price alone.</li>
            <li>Vague all-inclusive bundles that hide support, hosting, or future scope.</li>
            <li>Generic websites that ignore proof, differentiation, and conversion responsibility.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <h2 class="text-3xl font-bold text-navy-900 md:text-5xl">Retainers and post-launch support</h2>
        <p class="mt-5 text-lg text-navy-600">If the website or system matters commercially after launch, support should be structured, not improvised.</p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {siteConfig.offers.retainers.map((retainer) => (
          <article class="fade-up rounded-3xl border border-navy-100 bg-white p-6 shadow-sm shadow-navy-900/5">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">{retainer.price}</p>
            <h3 class="mt-3 text-xl font-bold text-navy-900">{retainer.nameEn}</h3>
            <p class="mt-4 text-sm leading-relaxed text-navy-600">{retainer.summaryEn}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy-50 py-16 md:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up rounded-3xl border border-navy-100 bg-white p-8 shadow-sm shadow-navy-900/5">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Who should enquire</p>
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          <div>
            <h2 class="text-2xl font-bold text-navy-900">Strong fit</h2>
            <ul class="mt-4 space-y-3 text-navy-700">
              <li>Your current digital presence understates the quality of your work.</li>
              <li>Trust, credibility, or stakeholder confidence meaningfully affect conversion.</li>
              <li>You want diagnosis, direction, and accountability, not just execution hours.</li>
            </ul>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-navy-900">Weak fit</h2>
            <ul class="mt-4 space-y-3 text-navy-700">
              <li>You need a very small one-off task at the lowest possible price.</li>
              <li>You already know the build spec and only want a pair of hands.</li>
              <li>You want strategic outcomes without the budget or patience for strategy.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    lang={lang}
    title="If the fit is there, the next step is a diagnostic call."
    subtitle="Use the contact page to explain the business context, the pressure to act, and the level of engagement you expect."
    ctaHref="/en/contact/"
    ctaLabel="Book a diagnostic call"
  />
</BaseLayout>
