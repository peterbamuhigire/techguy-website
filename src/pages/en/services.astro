---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { t } from '@/utils/i18n';
import type { Lang } from '@/utils/i18n';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import { siteConfig } from '@/data/site';

import softwareDevImg from '@/assets/images/services/software-dev-1.jpg';
import techSupportImg from '@/assets/images/services/tech-support-1.jpg';
import businessStrategyImg from '@/assets/images/services/business-strategy.jpg';
import socialMediaImg from '@/assets/images/services/social-media-2.jpg';

const lang: Lang = 'en';

const lifecycleStages = [
  {
    label: 'Develop',
    description: 'Requirements engineering, systems analysis, architecture, and build. Full-stack web applications in PHP, Python, and JavaScript; Android apps in Kotlin with Jetpack Compose and offline-first design; multi-tenant SaaS platforms on clean API foundations. Every build is preceded by a thorough understanding of the business processes it must support.',
  },
  {
    label: 'Deploy',
    description: 'Environment setup, secure infrastructure provisioning, data migration from legacy systems and spreadsheets, user training, and phased rollout. Deployment is treated as its own discipline, not an afterthought, because most system failures originate at the handover.',
  },
  {
    label: 'Manage',
    description: "Ongoing administration, user support, performance monitoring, access governance, and security oversight. Once a system is live, the practice can operate it on the client's behalf or work alongside an in-house team — whichever fits the organisation.",
  },
  {
    label: 'Maintain',
    description: 'Updates, feature evolution as the business changes, infrastructure care, and lifecycle planning. Maintenance retainers are SLA-backed and scoped to the criticality of the system, with clear response commitments rather than best-effort promises.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Discovery',
    description: 'An initial consultation to understand your organisation, challenges, and objectives. This is a conversation, not a sales pitch.',
  },
  {
    number: '02',
    title: 'Analysis',
    description: 'A thorough assessment of your current systems, processes, and requirements. Identifying what works, what does not, and where the opportunities lie.',
  },
  {
    number: '03',
    title: 'Proposal',
    description: 'A clear, detailed proposal outlining the recommended approach, timeline, deliverables, and investment. No hidden costs, no vague promises.',
  },
  {
    number: '04',
    title: 'Implementation',
    description: "Hands-on delivery with regular progress updates. The practice works alongside your team, not in isolation.",
  },
  {
    number: '05',
    title: 'Support — Manage & Maintain',
    description: 'For business management systems, software, and websites, the engagement does not end at handover. Ongoing administration, user support, performance monitoring, security oversight, feature evolution, and infrastructure care are offered under SLA-backed maintenance retainers — the develop-deploy-manage-maintain lifecycle delivered in practice.',
  },
];
---

<BaseLayout
  title="Business Management Systems & Software Development — Africa"
  description="Business management systems and custom software developed, deployed, managed, and maintained as a continuous discipline. Complementary websites, ICT consulting, and business advisory across anglophone and francophone Africa."
  lang={lang}
  page="services"
>

  <!-- ==============================
       HERO BANNER
       ============================== -->
  <section class="relative bg-navy-950 overflow-hidden">
    <div class="absolute inset-0 geo-pattern opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-950/95 to-navy-900"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-24">
      <div class="py-16 md:py-20 lg:py-24 max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-6">
          <span class="text-gold-400 text-sm font-medium">What We Offer</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white leading-tight">
          Business Management Systems &amp; Software Development
        </h1>

        <p class="mt-6 text-lg md:text-xl text-navy-200 leading-relaxed max-w-2xl">
          Custom business management systems and software — developed, deployed, managed, and maintained as a single continuous discipline. Complementary website development, ICT consulting, and business advisory sit alongside the systems core, built on more than 15 years of practical experience across over 10 African countries.
        </p>

        <div class="mt-4 h-1 w-16 rounded-full bg-gold-400"></div>
      </div>
    </div>

    <!-- Bottom wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 40V10C360 30 720 0 1080 20C1260 30 1380 25 1440 20V40H0Z" fill="var(--color-warm-white)"/>
      </svg>
    </div>
  </section>

  <!-- ==============================
       SERVICE 1: BUSINESS MANAGEMENT SYSTEMS & SOFTWARE DEVELOPMENT
       ============================== -->
  <section id="business-management-systems" class="bg-warm-white py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Primary Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Business Management Systems &amp; Software Development</h2>

          <p class="text-navy-600 leading-relaxed mb-6">
            Business management systems are at the core of this practice. The work spans ERP implementations, multi-tenant SaaS platforms, custom internal systems, and Android mobile applications — all built to solve specific operational problems rather than to demonstrate technology. Every engagement follows the same lifecycle: develop, deploy, manage, and maintain. That commitment to the full lifecycle is what distinguishes the practice from one-shot project work, and it is demonstrated through in-house systems such as Maduuka (a multi-tenant SaaS business management platform) and Aqar (a property management platform — the practice's PropTech vertical), both developed, operated, and maintained directly by the practice. Regional ERP delivery, including Longhorn ERP implementations, applies the same discipline to third-party systems.
          </p>

          <!-- Deliverables grid -->
          <h3 class="text-sm font-semibold uppercase tracking-wider text-navy-900 mb-3">Key Deliverables</h3>
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'ERP implementation & customisation (incl. regional Longhorn ERP)',
              'Custom business management systems',
              'SaaS platform architecture & multi-tenant design',
              'Android mobile app development (Kotlin, Jetpack Compose)',
              'Full-stack web application development (PHP, Python, JS)',
              'Database design, optimisation & management',
              'REST API design & third-party integration',
              'AI-assisted development workflows',
              'Legacy system modernisation & data migration',
              'Ongoing system management & SLA-backed maintenance retainers',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <p class="text-navy-600 leading-relaxed mt-6 text-sm">
            <span class="font-semibold text-navy-900">Flagship in-house systems:</span> Maduuka (multi-tenant SaaS business management), Aqar (property management — the practice's PropTech vertical), and Longhorn ERP (regional ERP delivery across East and West Africa). These systems serve as proof that the develop-deploy-manage-maintain lifecycle is operated in practice, not merely described.
          </p>

          <a
            href="/en/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl -rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={softwareDevImg}
              alt="Software development workspace with code on screen"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Full Lifecycle mini-grid -->
      <div class="mt-12 md:mt-16 fade-up">
        <div class="flex items-end justify-between flex-wrap gap-4 mb-6">
          <h3 class="text-2xl md:text-3xl font-bold text-navy-900">The Full Lifecycle</h3>
          <p class="text-navy-600 text-sm max-w-md">Develop, deploy, manage, maintain — operated as one continuous discipline, not handed over and forgotten.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {lifecycleStages.map((stage, index) => (
            <article class="relative rounded-2xl border border-navy-100 bg-warm-cream/60 p-6 shadow-sm shadow-navy-900/5 h-full">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-sm font-bold text-amber-accent font-heading">0{index + 1}</span>
                <div class="h-px flex-1 bg-gold-400/40"></div>
              </div>
              <h4 class="text-lg font-bold text-navy-900 mb-2">{stage.label}</h4>
              <p class="text-navy-600 text-sm leading-relaxed">{stage.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 2: WEBSITE DEVELOPMENT
       ============================== -->
  <section id="website-development" class="bg-warm-cream py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (left on desktop) -->
        <!-- [PHOTO NEEDED — website browser or design mockup; currently reusing socialMediaImg as nearest stand-in] -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={socialMediaImg}
              alt="Digital presence and strategy-led website development"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v18m16.5-18v18M3 7.5h18M3 16.5h18M3 12h18M5.625 21h12.75A1.875 1.875 0 0020.25 19.125V4.875A1.875 1.875 0 0018.375 3H5.625A1.875 1.875 0 003.75 4.875v14.25c0 1.036.84 1.875 1.875 1.875z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Website Development</h2>

          <p class="text-navy-600 leading-relaxed mb-6">
            <span class="font-semibold text-navy-900">Strategy-led websites that carry reputation and convert serious enquiries</span> — for organisations whose digital presence has commercial weight.
          </p>

          <p class="text-navy-600 leading-relaxed mb-8">
            Website development remains a meaningful part of the practice, positioned as a complement to the systems work. Every site begins with a diagnosis of positioning, audience, and the commercial role the website is expected to play, and is then built on a performance-first stack — Astro with Tailwind, zero JavaScript by default, and Lighthouse scores in the 95–100 range as a baseline rather than an aspiration. Multilingual capability (English, French, and Kiswahili) is built in from the outset, as is structured SEO, schema markup, and analytics. The work suits consultancies, institutions, technical firms, and funded ventures — organisations for whom a website is operational infrastructure rather than a brochure.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Strategy-led design & development (Astro, Tailwind, zero-JS)',
              'Positioning, messaging & proof architecture',
              'Multilingual capability (EN / FR / SW)',
              'SEO, schema, analytics & conversion tracking',
              'Hosting setup & post-launch retainers',
              'Existing site audits & rebuilds',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/en/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 3: ICT CONSULTING & STRATEGY
       ============================== -->
  <section id="ict-consulting" class="bg-warm-white py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (left on desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={techSupportImg}
              alt="ICT consulting and technology strategy session"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">ICT Consulting & Strategy</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            Many organisations invest in technology without a clear strategy — purchasing systems that do not integrate, building infrastructure that does not scale, or adopting tools that staff cannot use effectively. The practice's ICT consulting addresses this gap. Drawing on experience managing ICT operations across multiple countries and organisations — from multinational health-product distributors operating across eight African countries to national research institutions — it provides strategic guidance grounded in operational reality. Whether the brief is to assess current infrastructure, plan a digital transformation, or select the right vendors, the perspective is that of someone who has built and operated these systems in challenging environments.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'IT infrastructure assessment & planning',
              'Digital transformation roadmaps',
              'Systems analysis & requirements engineering',
              'Technology vendor evaluation',
              'Network & server infrastructure design',
              'MIS setup & optimisation',
              'Cloud migration strategy',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/en/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 4: BUSINESS PLANNING & STRATEGY
       ============================== -->
  <section id="business-planning" class="bg-warm-cream py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Business Planning & Strategy</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            The practice helps organisations and entrepreneurs develop the plans, strategies, and documentation they need to grow, secure funding, and operate with clarity. Drawing on 15 years of experience across diverse industries in Africa and internationally, it offers practical strategic support that goes beyond frameworks — grounded in real business realities, with the analytical rigour and practical insight needed to turn business ideas into fundable, executable plans.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Business plan development (bankable plans for banks, DFIs & investors)',
              'Strategic planning & objective setting',
              'Business proposals & grant applications',
              'Market research & feasibility studies',
              'Pitch deck development & presentation coaching',
              'M&E framework design',
              'Business process analysis & optimisation',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <div class="mt-6 p-5 rounded-xl bg-gold-400/10 border border-gold-400/30">
            <p class="text-navy-700 text-sm font-medium mb-2">Full Business Planning Service</p>
            <p class="text-navy-600 text-sm leading-relaxed mb-3">
              We develop complete, bankable business plans — from market analysis and financial modelling to a professional pitch deck and presentation coaching. A full-service offering that takes you from idea to funded.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/en/business-plan-intake/" class="inline-flex items-center gap-1.5 text-sm font-bold text-navy-900 bg-gold-400 hover:bg-gold-500 px-4 py-2 rounded-lg transition-colors duration-200">
                Get a Quotation →
              </a>
              <a href="/en/business-planning-consulting-service/" class="inline-flex items-center text-sm font-semibold text-amber-accent hover:text-gold-600 gap-1.5 py-2">
                Explore Business Planning →
              </a>
            </div>
          </div>

          <a
            href="/en/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl -rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={businessStrategyImg}
              alt="Business consulting and strategy planning session"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 5: DIGITAL MARKETING & SOCIAL MEDIA STRATEGY
       ============================== -->
  <section id="digital-marketing" class="bg-warm-white py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (left on desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={socialMediaImg}
              alt="Hands holding smartphone with social media concept"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
