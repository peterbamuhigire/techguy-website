---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Lang } from '@/utils/i18n';

const lang: Lang = 'en';

const steps = [
  { number: 1, title: 'Contact Details' },
  { number: 2, title: 'About Your Business' },
  { number: 3, title: 'Audience & Goals' },
  { number: 4, title: 'Current Presence' },
  { number: 5, title: 'Brand Identity' },
  { number: 6, title: 'Budget & Expectations' },
];
---

<BaseLayout
  title="Digital Marketing Intake — Get Your Personalised Quote | Peter Bamuhigire"
  description="Complete our quick 10-question brief and receive a personalised digital marketing and social media strategy quotation from Peter Bamuhigire within 48 hours."
  lang={lang}
  page="services"
>

  <!-- Hero Banner -->
  <section class="bg-navy-900 pt-20 md:pt-24 pb-12 md:pb-16 geo-pattern">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-5">
        <span class="text-gold-400 text-sm font-medium">Digital Marketing & Social Media Strategy</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-warm-white">
        Get Your Personalised Quote
      </h1>
      <p class="mt-4 text-lg text-navy-200 max-w-2xl mx-auto leading-relaxed">
        Answer 10 focused questions about your business and goals. Peter will review your answers and send you a personalised strategy quotation within <strong class="text-gold-300">48 hours</strong>.
      </p>
      <div class="mt-6 h-1 w-20 rounded-full bg-gold-400 mx-auto"></div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <div
        x-data="{
          step: 1,
          totalSteps: 6,
          state: 'idle',
          responseMessage: '',
          fieldErrors: [],
          csrfToken: '',
          csrfTs: 0,
          loadedAt: Math.floor(Date.now() / 1000),
          formData: {
            name: '',
            email: '',
            phone: '',
            company: '',
            q1: '',
            q2: '',
            q3: '',
            q4: '',
            q5: '',
            q6: '',
            q7: '',
            q8: '',
            q9: '',
            q10: '',
            website: ''
          },
          async init() {
            try {
              const res = await fetch('/api/csrf-token.php');
              const d = await res.json();
              this.csrfToken = d.token;
              this.csrfTs = d.ts;
            } catch(e) {}
          },
          validateStep() {
            this.fieldErrors = [];
            if (this.step === 1) {
              if (!this.formData.name || this.formData.name.trim().length < 2) this.fieldErrors.push('name');
              if (!this.formData.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.formData.email)) this.fieldErrors.push('email');
            }
            return this.fieldErrors.length === 0;
          },
          hasError(field) { return this.fieldErrors.includes(field); },
          nextStep() {
            if (!this.validateStep()) return;
            if (this.step < this.totalSteps) {
              this.step++;
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          },
          prevStep() {
            if (this.step > 1) {
              this.step--;
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          },
          async submitForm() {
            if (!this.validateStep()) return;
            this.state = 'submitting';
            try {
              const res = await fetch('/api/intake.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  ...this.formData,
                  lang: 'en',
                  _csrf_token: this.csrfToken,
                  _csrf_ts: this.csrfTs,
                  _loaded_at: this.loadedAt
                })
              });
              const data = await res.json();
              this.responseMessage = data.message;
              this.state = data.success ? 'success' : 'error';
              if (data.success) window.scrollTo({ top: 0, behavior: 'smooth' });
            } catch(e) {
              this.responseMessage = 'Something went wrong. Please email peter@techguypeter.com directly.';
              this.state = 'error';
            }
          }
        }"
        x-init="init()"
      >

        <!-- Success State -->
        <div x-show="state === 'success'" x-cloak class="text-center py-16">
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="text-3xl font-bold text-navy-900 mb-4">Answers Received!</h2>
          <p class="text-navy-600 text-lg leading-relaxed max-w-lg mx-auto mb-4" x-text="responseMessage"></p>
          <p class="text-navy-500 text-sm">A copy of your answers has been sent to your email address for your records.</p>
          <a href="/en/digital-marketing-strategy/" class="mt-8 inline-flex items-center gap-2 text-amber-accent font-semibold hover:underline">
            ← Back to Digital Marketing Services
          </a>
        </div>

        <!-- Form Wizard -->
        <div x-show="state !== 'success'">

          <!-- Error Banner -->
          <div x-show="state === 'error'" x-cloak class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-red-700 text-sm" x-text="responseMessage"></p>
          </div>

          <!-- Progress Bar -->
          <div class="mb-8">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium text-navy-700">
                Step <span x-text="step"></span> of <span x-text="totalSteps"></span>
              </span>
              <span class="text-sm text-navy-500">
                {steps.map(s => s.title).join(' · ')}
              </span>
            </div>
            <div class="h-2 bg-navy-100 rounded-full overflow-hidden">
              <div
                class="h-full bg-gold-400 rounded-full transition-all duration-500"
                :style="`width: ${(step / totalSteps) * 100}%`"
              ></div>
            </div>
            <!-- Step labels -->
            <div class="mt-3 flex gap-1.5">
              {steps.map(s => (
                <div
                  class="flex-1 text-center"
                  :class={`step === ${s.number} ? 'opacity-100' : 'opacity-30'`}
                >
                  <div
                    class="w-6 h-6 rounded-full mx-auto flex items-center justify-center text-xs font-bold transition-colors"
                    :class={`step === ${s.number} ? 'bg-gold-400 text-navy-900' : step > ${s.number} ? 'bg-green-500 text-white' : 'bg-navy-200 text-navy-500'`}
                  >
                    <span x-show={`step <= ${s.number}`}>{s.number}</span>
                    <svg x-show={`step > ${s.number}`} x-cloak class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <p class="text-xs text-navy-600 mt-1 hidden sm:block">{s.title}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Honeypot -->
          <div class="absolute opacity-0 -z-10 h-0 overflow-hidden" aria-hidden="true">
            <input type="text" name="website" x-model="formData.website" tabindex="-1" autocomplete="off" />
          </div>

          <!-- ====== STEP 1: Contact Details ====== -->
          <div x-show="step === 1" class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
            <h2 class="text-2xl font-bold text-navy-900 mb-2">Let's start with your details</h2>
            <p class="text-navy-600 mb-8">We'll use these to send your personalised quotation and to address your brief correctly.</p>

            <div class="space-y-5">
              <!-- Name -->
              <div>
                <label for="intake-name" class="block text-sm font-medium text-navy-800 mb-1.5">
                  Full Name <span class="text-amber-accent" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="intake-name"
                  x-model="formData.name"
                  :class="hasError('name') ? 'border-red-400 bg-red-50' : 'border-navy-200'"
                  class="w-full px-4 py-3 border rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors"
                  placeholder="Your full name"
                  autocomplete="name"
                />
                <p x-show="hasError('name')" x-cloak class="mt-1.5 text-sm text-red-600">Please enter your full name.</p>
              </div>

              <!-- Email -->
              <div>
                <label for="intake-email" class="block text-sm font-medium text-navy-800 mb-1.5">
                  Email Address <span class="text-amber-accent" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="intake-email"
                  x-model="formData.email"
                  :class="hasError('email') ? 'border-red-400 bg-red-50' : 'border-navy-200'"
                  class="w-full px-4 py-3 border rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors"
                  placeholder="you@company.com"
                  autocomplete="email"
                />
                <p x-show="hasError('email')" x-cloak class="mt-1.5 text-sm text-red-600">Please enter a valid email address.</p>
              </div>

              <!-- Phone -->
              <div>
                <label for="intake-phone" class="block text-sm font-medium text-navy-800 mb-1.5">
                  Phone / WhatsApp <span class="text-navy-400 font-normal text-xs ml-1">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="intake-phone"
                  x-model="formData.phone"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors"
                  placeholder="+256 700 000 000"
                  autocomplete="tel"
                />
              </div>

              <!-- Company -->
              <div>
                <label for="intake-company" class="block text-sm font-medium text-navy-800 mb-1.5">
                  Company / Organisation <span class="text-navy-400 font-normal text-xs ml-1">(optional)</span>
                </label>
                <input
                  type="text"
                  id="intake-company"
                  x-model="formData.company"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors"
                  placeholder="Your business name"
                  autocomplete="organization"
                />
              </div>
            </div>
          </div>

          <!-- ====== STEP 2: About Your Business ====== -->
          <div x-show="step === 2" x-cloak class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
            <h2 class="text-2xl font-bold text-navy-900 mb-2">About Your Business</h2>
            <p class="text-navy-600 mb-8 text-sm leading-relaxed">Answer as fully as you can — the more context you give, the more precise your quotation will be. All questions on this and subsequent steps are optional, but the more you answer, the better.</p>

            <div class="space-y-8">
              <div>
                <label for="q1" class="block text-sm font-semibold text-navy-800 mb-1">
                  1. Business Overview
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">Tell us about your business: what you do, what you sell or offer, how long you have been operating, how big your team is, and where you are based.</p>
                <textarea
                  id="q1"
                  x-model="formData.q1"
                  rows="5"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. We are a three-year-old hospitality business in Kampala with a team of eight, operating two boutique guesthouses and a rooftop restaurant..."
                ></textarea>
              </div>

              <div>
                <label for="q2" class="block text-sm font-semibold text-navy-800 mb-1">
                  2. Unique Value Proposition
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">What makes your business different from your competitors? Why should a customer choose you over anyone else in your market?</p>
                <textarea
                  id="q2"
                  x-model="formData.q2"
                  rows="5"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. We are the only guesthouse in the area offering fully personalised check-in times and a locally sourced menu that changes weekly..."
                ></textarea>
              </div>
            </div>
          </div>

          <!-- ====== STEP 3: Audience & Goals ====== -->
          <div x-show="step === 3" x-cloak class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
            <h2 class="text-2xl font-bold text-navy-900 mb-2">Your Audience & Goals</h2>
            <p class="text-navy-600 mb-8 text-sm leading-relaxed">Understanding who you are trying to reach and what you want to achieve is the foundation of any strategy.</p>

            <div class="space-y-8">
              <div>
                <label for="q3" class="block text-sm font-semibold text-navy-800 mb-1">
                  3. Target Audience
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">Describe your ideal customer as a real person. Include their age range, gender (if relevant), location, income level or economic segment, occupation, and the specific problem your business solves for them. If you serve more than one type of customer, describe each.</p>
                <textarea
                  id="q3"
                  x-model="formData.q3"
                  rows="5"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. Our primary audience is professionals aged 28–45 in Kampala, earning UGX 2M+ per month, who want a premium dining experience without driving to a hotel..."
                ></textarea>
              </div>

              <div>
                <label for="q4" class="block text-sm font-semibold text-navy-800 mb-1">
                  4. Social Media Goals
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">What do you want social media to achieve for your business? What has prompted you to focus on this now, and what does success look like for you over the next 6–12 months?</p>
                <textarea
                  id="q4"
                  x-model="formData.q4"
                  rows="5"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. We want to drive reservations directly from Instagram and WhatsApp, reducing our reliance on hotel booking platforms. Success means 30% of bookings coming from social within 12 months..."
                ></textarea>
              </div>
            </div>
          </div>

          <!-- ====== STEP 4: Current Presence ====== -->
          <div x-show="step === 4" x-cloak class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
            <h2 class="text-2xl font-bold text-navy-900 mb-2">Your Current Presence</h2>
            <p class="text-navy-600 mb-8 text-sm leading-relaxed">An honest picture of where you stand today helps us build a strategy that starts from reality, not assumptions.</p>

            <div class="space-y-8">
              <div>
                <label for="q5" class="block text-sm font-semibold text-navy-800 mb-1">
                  5. Current Social Media Presence
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">Which platforms are you currently active on? For each one, tell us your handle, roughly how many followers you have, how often you post, and who manages the account today. How would you honestly rate your current performance — and what has worked or not worked so far?</p>
                <textarea
                  id="q5"
                  x-model="formData.q5"
                  rows="6"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. Instagram @ourguesthouse — 820 followers, posting 2–3 times/week, managed by the owner. Engagement is low. Facebook @ourguesthouselimited — 1,200 followers, rarely post now..."
                ></textarea>
              </div>

              <div>
                <label for="q6" class="block text-sm font-semibold text-navy-800 mb-1">
                  6. Competitors
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">Name your top three to five competitors. For each, tell us which platforms they are on and what their social media presence looks like. Which competitor do you most admire and why — and which do you most want to be clearly different from?</p>
                <textarea
                  id="q6"
                  x-model="formData.q6"
                  rows="6"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. Competitor A — strong on Instagram (5K followers), great photos but no WhatsApp engagement. Competitor B — very active on Facebook but content feels generic. I admire Competitor A's visuals but want to be warmer and more community-focused..."
                ></textarea>
              </div>
            </div>
          </div>

          <!-- ====== STEP 5: Brand Identity ====== -->
          <div x-show="step === 5" x-cloak class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
            <h2 class="text-2xl font-bold text-navy-900 mb-2">Your Brand Identity</h2>
            <p class="text-navy-600 mb-8 text-sm leading-relaxed">How your brand speaks and looks determines whether content feels authentic or generic. Be specific — it helps enormously.</p>

            <div class="space-y-8">
              <div>
                <label for="q7" class="block text-sm font-semibold text-navy-800 mb-1">
                  7. Brand Voice and Personality
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">If your brand were a person walking into a room, how would they speak, dress, and carry themselves? Choose three words that describe how your brand should sound on social media. Name two or three brands whose tone you admire, and two or three you absolutely do not want to sound like.</p>
                <textarea
                  id="q7"
                  x-model="formData.q7"
                  rows="5"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. Three words: warm, authoritative, local. Admire: Serena Hotels (elegant but approachable), Uganda Tourism Board (proud and energetic). Do NOT want to sound like: corporate banks (cold, formal)..."
                ></textarea>
              </div>

              <div>
                <label for="q8" class="block text-sm font-semibold text-navy-800 mb-1">
                  8. Visual Identity
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">Describe your visual brand: your colours (with hex codes if you have them), your fonts, and your logo status. Do you have existing brand guidelines? What overall look and feel do you want your social media content to have — and are there any visual styles you want to avoid?</p>
                <textarea
                  id="q8"
                  x-model="formData.q8"
                  rows="5"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. Brand colours: deep green (#1A4A2E) and warm cream (#F5EDD8). We have a logo but no formal brand guide. We want a clean, earthy aesthetic — real photography, not stock images. Avoid overly busy or text-heavy posts..."
                ></textarea>
              </div>
            </div>
          </div>

          <!-- ====== STEP 6: Budget & Expectations ====== -->
          <div x-show="step === 6" x-cloak class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
            <h2 class="text-2xl font-bold text-navy-900 mb-2">Budget & Expectations</h2>
            <p class="text-navy-600 mb-8 text-sm leading-relaxed">Being open about budget and expectations helps Peter propose something realistic and right-sized for your business — rather than something generic.</p>

            <div class="space-y-8">
              <div>
                <label for="q9" class="block text-sm font-semibold text-navy-800 mb-1">
                  9. Resources, Budget, and Approval
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">What content resources do you have available — photography, video capability, someone willing to appear on camera, a team member who writes well? What is your monthly budget for social media management and/or paid advertising? Who must approve content before it is published, and how quickly can they turn approvals around?</p>
                <textarea
                  id="q9"
                  x-model="formData.q9"
                  rows="6"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. We have a smartphone for photos/video and the owner can appear on camera occasionally. Budget: UGX 1.5M–2M per month for management, plus UGX 500K for paid ads. Approval is just me (owner) — I can respond within 24 hours..."
                ></textarea>
              </div>

              <div>
                <label for="q10" class="block text-sm font-semibold text-navy-800 mb-1">
                  10. Posting Expectations, Restrictions, and Reporting
                </label>
                <p class="text-sm text-navy-500 mb-2 leading-relaxed">Which platforms do you want to prioritise, and how often do you expect content to be posted? Are there any topics, words, or approaches your brand should never use? How often would you like performance reports? Is there anything else — upcoming launches, past challenges, sensitivities — we should know?</p>
                <textarea
                  id="q10"
                  x-model="formData.q10"
                  rows="6"
                  class="w-full px-4 py-3 border border-navy-200 rounded-lg text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/50 focus:border-gold-400 transition-colors resize-none"
                  placeholder="e.g. Priority platforms: Instagram and WhatsApp. Expect 4–5 posts/week on Instagram, 2 WhatsApp broadcasts/week. Never discuss pricing or make political references. Monthly PDF report preferred. We have a new menu launching in March..."
                ></textarea>
              </div>
            </div>
          </div>

          <!-- Navigation Buttons -->
          <div class="mt-6 flex items-center justify-between gap-4">
            <button
              type="button"
              x-show="step > 1"
              @click="prevStep()"
              class="inline-flex items-center gap-2 px-6 py-3 border-2 border-navy-200 text-navy-700 font-semibold rounded-lg hover:border-navy-400 transition-colors duration-200"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
              </svg>
              Previous
            </button>
            <div x-show="step === 1"></div>

            <button
              type="button"
              x-show="step < totalSteps"
              @click="nextStep()"
              class="ml-auto inline-flex items-center gap-2 px-8 py-3 bg-gold-400 hover:bg-gold-500 text-navy-900 font-bold rounded-lg transition-colors duration-200 shadow-md hover:shadow-lg"
            >
              Next Step
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </button>

            <button
              type="button"
              x-show="step === totalSteps"
              x-cloak
              @click="submitForm()"
              :disabled="state === 'submitting'"
              class="ml-auto inline-flex items-center gap-2 px-8 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-bold rounded-lg transition-all duration-200 shadow-md hover:shadow-lg disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <span x-show="state !== 'submitting'">Submit & Get Quote</span>
              <span x-show="state === 'submitting'" x-cloak>Sending...</span>
              <svg x-show="state !== 'submitting'" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </button>
          </div>

          <!-- Trust note -->
          <p class="mt-6 text-center text-sm text-navy-400">
            Your answers are sent securely and used only to prepare your quotation. Peter will respond within 48 hours.
          </p>

        </div><!-- end form wizard -->
      </div><!-- end x-data -->

    </div>
  </section>

</BaseLayout>
