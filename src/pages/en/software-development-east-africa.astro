---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { Lang } from '@/utils/i18n';
import CTASection from '@/components/CTASection.astro';
import ProofBlock from '@/components/ProofBlock.astro';
import FAQSection from '@/components/FAQSection.astro';

import softwareDevImg from '@/assets/images/services/software-dev-1.jpg';
import erpImg from '@/assets/images/portfolio/ERP-01.jpg';

const lang: Lang = 'en';

const products = [
  {
    name: 'Maduuka',
    tagline: 'Business management for East African SMEs',
    description: 'Multi-currency, mobile-first, offline-capable. Handles EAC market requirements natively.',
    href: 'https://maduuka.com',
  },
  {
    name: 'Aqar',
    tagline: 'Property management for East African landlords',
    description: 'Rent in local currency, tenant records, maintenance tracking. Deployed across Uganda and East Africa.',
    href: 'https://aqarproperty.co.uk',
  },
  {
    name: 'Longhorn ERP',
    tagline: 'Enterprise resource planning for multi-country operations',
    description: 'Multi-currency, multi-branch, multilingual. Deployed in Uganda, Kenya, and West Africa.',
    href: '/en/services/',
  },
];

const faqs = [
  {
    question: 'Can you build software that works across multiple East African countries?',
    answer: 'Yes — multi-country deployments are a specific competency of this practice. The Longhorn ERP platform runs across Uganda, Kenya, and West Africa simultaneously, handling multiple currencies, multiple languages, and multiple regulatory environments. Custom projects spanning EAC markets are handled in the same way.',
  },
  {
    question: 'Do your platforms support mobile money payments common in East Africa?',
    answer: 'Yes. Mobile money integration (MTN Mobile Money, Airtel Money, M-Pesa, Orange Money) is built into the practice\'s platforms as a native capability, not an add-on. This reflects the payment reality for East African businesses, not a Western payment infrastructure assumption.',
  },
  {
    question: 'Can you deploy and maintain software remotely across East Africa?',
    answer: 'Yes. Deployments are managed remotely using cloud infrastructure. In-country visits for training and initial setup are scoped into the engagement where required. Most ongoing maintenance and support is handled remotely.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Software Development East Africa — Peter Bamuhigire',
  description: 'Custom software development across East Africa. Web applications, ERP systems, mobile apps, and SaaS platforms built for East African business environments.',
  url: 'https://techguypeter.com/en/software-development-east-africa/',
  areaServed: [
    'Uganda', 'Kenya', 'Tanzania', 'Rwanda', 'Ethiopia',
  ].map((name) => ({ '@type': 'Country', name })),
  serviceType: ['Software Development', 'ERP Systems', 'Mobile App Development', 'Cross-border Software Deployment'],
  provider: {
    '@type': 'Person',
    name: 'Peter Bamuhigire',
    url: 'https://techguypeter.com/en/',
    sameAs: [
      'https://linkedin.com/in/peterbamuhigire',
      'https://github.com/peterbamuhigire',
    ],
  },
};
---

<BaseLayout
  title="Software Developer East Africa — Custom Software & ERP Systems | Peter Bamuhigire"
  description="Custom software development across East Africa. Web applications, ERP systems, mobile apps, and SaaS platforms built for East African business environments. Bilingual in English and French. Based in Kampala, Uganda."
  lang={lang}
  page="services"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- ==============================
       HERO
       ============================== -->
  <section class="relative bg-navy-950 overflow-hidden">
    <div class="absolute inset-0 geo-pattern opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-950/95 to-navy-900"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-24">
      <div class="py-16 md:py-20 lg:py-24 max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-6">
          <span class="text-gold-400 text-sm font-medium">East Africa Software Development</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white leading-tight">
          Software built for East African businesses — not adapted from somewhere else
        </h1>

        <p class="mt-6 text-lg md:text-xl text-navy-200 leading-relaxed max-w-2xl">
          The East African market has specific software requirements that off-the-shelf products rarely meet: mobile-first architecture, offline capability, multi-currency support across EAC markets, and multilingual interfaces. The platforms built by this practice were designed for these requirements from the ground up — not retrofitted to them.
        </p>

        <div class="mt-6 h-1 w-16 rounded-full bg-gold-400"></div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/en/contact/"
            class="inline-block px-8 py-4 bg-amber-accent hover:bg-gold-600 text-white text-lg font-semibold rounded-lg transition-colors shadow-lg shadow-amber-accent/20"
          >
            Describe your requirement
          </a>
          <a
            href="/en/portfolio/"
            class="inline-block px-8 py-4 border-2 border-gold-400 text-gold-400 hover:bg-gold-400/10 text-lg font-semibold rounded-lg transition-colors"
          >
            See the portfolio
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 40L1440 40L1440 0C1200 30 960 40 720 35C480 30 240 10 0 0L0 40Z" fill="rgb(var(--color-warm-white, 250 247 242))" />
      </svg>
    </div>
  </section>

  <!-- ==============================
       BODY COPY
       ============================== -->
  <section class="bg-warm-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">

        <!-- Main prose -->
        <div class="lg:col-span-2 space-y-12">

          <div class="prose prose-navy max-w-none">
            <h2 class="text-2xl md:text-3xl font-bold text-navy-900">What makes East Africa-specific software development different</h2>
            <p class="text-navy-700 leading-relaxed mt-4">
              Software for East African businesses must work on the infrastructure that exists in the region, not the infrastructure that exists in the markets where most enterprise software is built. A Kenyan SME using a business management platform needs it to work on a Safaricom data connection — not a 100Mbps fibre line. A Tanzanian property manager needs rent collected via M-Pesa, not SWIFT. A Rwandan NGO needs reports in both English and Kinyarwanda.
            </p>
            <p class="text-navy-700 leading-relaxed mt-4">
              The three proprietary platforms built by this practice — Maduuka (business management), Aqar (property management), and Longhorn ERP (enterprise resource planning) — handle these requirements natively. They were built from first principles for the East African environment.
            </p>
          </div>

          <div class="prose prose-navy max-w-none">
            <h2 class="text-2xl md:text-3xl font-bold text-navy-900">Custom development for organisations with requirements not covered by existing platforms</h2>
            <p class="text-navy-700 leading-relaxed mt-4">
              Custom development engagements have been delivered for organisations in Uganda, Kenya, and Sierra Leone, covering: staff management and payroll systems for hospitality groups operating across multiple countries, data management and reporting platforms for research institutions, and logistics tracking systems for distribution companies operating across East African borders.
            </p>
            <p class="text-navy-700 leading-relaxed mt-4">
              All custom development uses modern web technologies (PHP, MySQL, Python, or JavaScript as appropriate to the requirement), is documented for handover, and is delivered with a training programme for end users.
            </p>
          </div>

          <!-- Products grid -->
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-navy-900 mb-8">Proprietary platforms for East African businesses</h2>
            <div class="grid sm:grid-cols-3 gap-6">
              {products.map((product) => (
                <div class="bg-warm-cream rounded-2xl p-6 border border-navy-100 flex flex-col">
                  <div class="flex-1">
                    <p class="text-xs font-semibold uppercase tracking-widest text-gold-400 mb-2">{product.tagline}</p>
                    <h3 class="text-xl font-bold text-navy-900">{product.name}</h3>
                    <p class="mt-3 text-sm text-navy-600 leading-relaxed">{product.description}</p>
                  </div>
                  <a href={product.href} class="mt-5 inline-flex items-center text-sm font-semibold text-gold-400 hover:text-amber-500 gap-1">
                    Learn more →
                  </a>
                </div>
              ))}
            </div>
          </div>

          <!-- Cross-link to Uganda -->
          <div class="bg-navy-50 rounded-xl p-6 border border-navy-100">
            <p class="text-sm font-semibold text-navy-900">Uganda-based organisation?</p>
            <p class="text-sm text-navy-600 mt-1">See the dedicated Uganda software development page for Uganda-specific context, UGX pricing guidance, and local case references.</p>
            <a href="/en/software-development-uganda/" class="inline-flex items-center text-sm font-semibold text-gold-400 hover:text-amber-500 mt-3 gap-1.5">Software development Uganda →</a>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <div class="overflow-hidden rounded-2xl shadow-lg">
            <Image
              src={softwareDevImg}
              alt="Custom software development for East African businesses"
              class="w-full h-56 object-cover"
              loading="lazy"
            />
          </div>

          <ProofBlock
            title="Longhorn ERP — multi-country deployment"
            summary="ERP system deployed across Uganda, Kenya, and West Africa. Multi-currency (UGX, KES, SLL), multilingual interface, offline-capable. Deployed to active users across 3 countries."
          />

          <div class="bg-warm-cream rounded-2xl p-6 border border-navy-100">
            <h3 class="text-sm font-semibold uppercase tracking-widest text-navy-500 mb-4">Technologies used</h3>
            <ul class="space-y-3 text-sm text-navy-700">
              <li class="flex items-start gap-2">
                <span class="text-gold-400 mt-0.5 shrink-0">▸</span>
                PHP, MySQL — backend systems
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gold-400 mt-0.5 shrink-0">▸</span>
                Python — data pipelines and analytics
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gold-400 mt-0.5 shrink-0">▸</span>
                JavaScript / TypeScript — web applications
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gold-400 mt-0.5 shrink-0">▸</span>
                Mobile money API integration
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gold-400 mt-0.5 shrink-0">▸</span>
                Offline-first architecture
              </li>
            </ul>
          </div>

          <div class="overflow-hidden rounded-2xl shadow-lg">
            <Image
              src={erpImg}
              alt="Longhorn ERP — enterprise resource planning system deployed across East Africa"
              class="w-full h-48 object-cover"
              loading="lazy"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ==============================
       FAQ
       ============================== -->
  <FAQSection
    title="Common questions about East Africa software development"
    subtitle="Multi-country deployments, mobile money, and remote delivery across the EAC region."
    faqs={faqs}
  />

  <!-- ==============================
       CTA
       ============================== -->
  <CTASection
    lang={lang}
    title="Describe your requirement"
    subtitle="The first step is a 30-minute diagnostic to establish whether your requirement is better served by an existing platform or a custom build — and what a realistic budget and timeline look like."
    ctaLabel="Start the conversation"
  />

</BaseLayout>
