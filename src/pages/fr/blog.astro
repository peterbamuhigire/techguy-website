---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import { t, type Lang } from '@/utils/i18n';

const lang: Lang = 'fr';

const blogPosts = [
  {
    title: 'Pourquoi les Entreprises Africaines Ont Besoin de Logiciels Sur Mesure',
    category: 'Technologie',
    gradient: 'from-navy-700 via-navy-800 to-navy-900',
  },
  {
    title: 'Leçons Tirées de la Gestion des TIC dans Trois Pays d\'Afrique de l\'Ouest',
    category: 'Affaires',
    gradient: 'from-navy-800 via-gold-900 to-navy-900',
  },
  {
    title: 'Le Cas des Applications Mobiles Offline-First sur les Marchés Africains',
    category: 'Afrique',
    gradient: 'from-navy-900 via-navy-700 to-gold-800',
  },
  {
    title: 'Implémentation ERP : Ce Que les PME Font Mal et Comment Bien Faire',
    category: 'ERP',
    gradient: 'from-gold-800 via-navy-800 to-navy-900',
  },
];
---

<BaseLayout
  title="Perspectives Tech — Peter Bamuhigire, Kampala"
  description="Articles sur le développement logiciel, le conseil IT et les solutions technologiques pour les entreprises africaines. Perspectives de Peter Bamuhigire, consultant IT à Kampala."
  lang={lang}
  page="blog"
  noindex
>
  <!-- Hero Banner -->
  <section class="bg-navy-900 pt-20 md:pt-24 pb-12 md:pb-16 geo-pattern">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white">
        {t('blog.title', lang)}
      </h1>
      <p class="mt-4 text-lg md:text-xl text-navy-200 max-w-2xl mx-auto">
        {t('blog.subtitle', lang)}
      </p>
      <div class="mt-6 h-1 w-20 rounded-full bg-gold-400 mx-auto"></div>
    </div>
  </section>

  <!-- Coming Soon Section -->
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-up text-center mb-12 md:mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gold-50 rounded-full mb-6">
          <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm font-medium text-gold-700">Bientôt Disponible</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900">
          Articles en Préparation
        </h2>
        <p class="mt-4 text-lg text-navy-600 max-w-2xl mx-auto">
          Peter prépare une collection de réflexions tirées de plus de 15 années d'expérience dans la création de solutions technologiques et le conseil à travers l'Afrique. Voici un aperçu de ce qui vous attend.
        </p>
      </div>

      <!-- Blog Post Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {blogPosts.map((post, index) => (
          <article class="fade-up group bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 overflow-hidden">
            <!-- Gradient Placeholder Image -->
            <div class={`h-48 md:h-52 bg-gradient-to-br ${post.gradient} relative overflow-hidden`}>
              <div class="absolute inset-0 flex items-center justify-center opacity-20">
                <svg class="w-20 h-20 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
              <!-- Coming Soon Badge -->
              <div class="absolute top-4 right-4">
                <span class="inline-flex items-center px-3 py-1 text-xs font-semibold bg-white/90 backdrop-blur-sm text-navy-800 rounded-full">
                  Bientôt Disponible
                </span>
              </div>
            </div>
            <!-- Card Content -->
            <div class="p-5 md:p-6">
              <div class="mb-3">
                <span class="inline-block px-3 py-1 text-xs font-medium bg-navy-50 text-navy-600 rounded-full">
                  {post.category}
                </span>
              </div>
              <h3 class="text-lg md:text-xl font-bold text-navy-900 group-hover:text-navy-700 transition-colors leading-snug">
                {post.title}
              </h3>
              <div class="mt-4 flex items-center gap-2 text-sm text-navy-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
                <span>Article en cours de rédaction</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 md:py-20 bg-navy-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center" x-data="{ submitted: false }">
      <div class="fade-up">
        <svg class="w-10 h-10 text-gold-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-900">
          Restez Informé
        </h2>
        <p class="mt-3 text-navy-600">
          Abonnez-vous pour recevoir des analyses sur la technologie, la stratégie d'entreprise et l'innovation à travers l'Afrique — directement dans votre boîte de réception.
        </p>
      </div>

      <!-- Newsletter Form -->
      <div class="mt-8 fade-up" x-show="!submitted" x-transition>
        <form action="#" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" @submit.prevent="submitted = true">
          <label for="newsletter-email" class="sr-only">Adresse e-mail</label>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            required
            placeholder="Entrez votre adresse e-mail"
            class="flex-1 px-4 py-3 bg-white border border-navy-200 rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-amber-accent hover:bg-gold-600 text-white font-semibold rounded-lg transition-colors whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-gold-500 focus:ring-offset-2"
          >
            S'abonner
          </button>
        </form>
        <p class="mt-3 text-xs text-navy-400">Aucun spam, jamais. Désabonnez-vous à tout moment.</p>
      </div>

      <!-- Confirmation Message -->
      <div x-show="submitted" x-cloak x-transition class="mt-8">
        <div class="inline-flex items-center gap-3 px-6 py-4 bg-white rounded-xl shadow-sm">
          <svg class="w-6 h-6 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-navy-800 font-medium">Merci ! Vous serez informé dès la publication de nouveaux articles.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection lang={lang} />
</BaseLayout>

<style>
  [x-cloak] { display: none !important; }
</style>
