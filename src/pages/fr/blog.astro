---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import { Image } from 'astro:assets';
import { t, type Lang } from '@/utils/i18n';

import imgWebsiteUsers from '@/assets/images/website-users--02.jpg';
import imgAgriBusiness from '@/assets/images/photorealistic-goat-farm.jpg';
import imgDigitalBusiness from '@/assets/images/BLOG-MARCH-5-01.jpg';
import imgCustomSoftware from '@/assets/images/blog-images-3.jpg';
import imgItConsultant from '@/assets/images/blog-images-8.jpg';
import imgErp from '@/assets/images/blog-images-1.jpg';
import imgWebsiteCosts from '@/assets/images/blog-images-9.jpg';
import imgBusinessPlan from '@/assets/images/african-entrepreneur-team-analyzing-business-reports.jpg';

const lang: Lang = 'fr';

const featuredPost = {
  title: 'Même les Petites Entreprises ont Besoin d\'un Plan d\'Affaires Écrit',
  slug: 'why-small-businesses-need-written-business-plan',
  category: 'Stratégie',
  date: '17 mars 2026',
  readTime: '14 min de lecture',
  excerpt: 'Un plan d\'affaires n\'est pas un document pour les banques — c\'est un outil de réflexion pour le dirigeant. Voici pourquoi toute petite entreprise en Afrique francophone en a besoin.',
  image: imgBusinessPlan,
  imageAlt: 'Équipe d\'entrepreneurs africains analysant des rapports financiers — pourquoi les petites entreprises ont besoin d\'un plan d\'affaires écrit',
};

const blogPosts = [
  {
    title: 'Pourquoi Vos Visiteurs Quittent Votre Site en 3 Secondes — Et Comment Les Retenir',
    slug: 'why-visitors-leave-website-3-seconds',
    category: 'Design Web & UX',
    date: '13 mars 2026',
    readTime: '10 min de lecture',
    excerpt: 'La plupart des sites web perdent 40 % de leurs visiteurs avant même que la page soit chargée. Les 7 vraies raisons qui font fuir vos visiteurs — et des solutions concrètes pour chacune d\'elles.',
    image: imgWebsiteUsers,
    imageAlt: 'Visiteurs d\'un site web consultant une entreprise en ligne — réduire le taux de rebond et améliorer l\'expérience utilisateur',
  },
  {
    title: 'Plans d\'Affaires Bancables pour l\'Agriculture : Café, Pisciculture et Chèvres',
    slug: 'bankable-agricultural-business-plans-coffee-fish-goats-uganda',
    category: 'Agriculture',
    date: '9 mars 2026',
    readTime: '18 min de lecture',
    excerpt: 'La plupart des demandes de prêts agricoles en Ouganda sont rejetées non pas parce que l\'idée agricole est mauvaise — mais parce que le plan d\'affaires ne parle pas le langage de l\'argent. Modèles financiers réels pour le café, la pisciculture et l\'élevage de chèvres.',
    image: imgAgriBusiness,
    imageAlt: 'Ferme caprine photorealistic en Ouganda — guide de planification d\'entreprise agricole pour l\'Afrique de l\'Est',
  },
  {
    title: 'Pourquoi Votre Entreprise Doit Passer au Numérique Dès Aujourd\'hui',
    slug: 'business-must-go-digital',
    category: 'Affaires',
    date: '5 mars 2026',
    readTime: '12 min de lecture',
    excerpt: 'Chaque PME africaine a besoin de systèmes numériques de point de vente, d\'inventaire et de comptabilité. Prévenez les pertes de stock, conformez-vous aux exigences fiscales EFRIS et eTax, et connaissez enfin vos vrais chiffres.',
    image: imgDigitalBusiness,
    imageAlt: 'Propriétaire d\'entreprise utilisant un système de point de vente numérique pour gérer les ventes et l\'inventaire',
  },
  {
    title: 'Pourquoi les Entreprises Africaines Ont Besoin de Logiciels Sur Mesure',
    slug: 'custom-software-africa',
    category: 'Technologie',
    date: '1 mars 2026',
    readTime: '10 min de lecture',
    excerpt: 'Logiciel sur mesure en Afrique : pourquoi les solutions prêtes à l\'emploi échouent et comment les logiciels personnalisés produisent des résultats.',
    image: imgCustomSoftware,
    imageAlt: 'Professionnel africain des TI gérant des systèmes dans un centre de données',
  },
  {
    title: 'Comment Choisir un Consultant IT en Afrique de l\'Est',
    slug: 'choose-it-consultant',
    category: 'Affaires',
    date: '15 février 2026',
    readTime: '12 min de lecture',
    excerpt: 'Guide pratique pour choisir le bon consultant IT à Kampala et en Afrique — questions à poser, signaux d\'alerte et bonnes pratiques.',
    image: imgItConsultant,
    imageAlt: 'Consultant IT évaluant les systèmes technologiques et l\'infrastructure',
  },
  {
    title: 'Implémentation ERP : Ce Que les PME Font Mal et Comment Bien Faire',
    slug: 'erp-implementation-mistakes',
    category: 'ERP',
    date: '1 février 2026',
    readTime: '11 min de lecture',
    excerpt: 'Évitez les erreurs coûteuses d\'implémentation ERP que commettent les PME africaines. Stratégies éprouvées pour réussir votre déploiement.',
    image: imgErp,
    imageAlt: 'Hologramme de système ERP avec des icônes de gestion d\'entreprise',
  },
  {
    title: 'Ce Que Coûte Réellement un Site Web en Ouganda',
    slug: 'website-costs-uganda',
    category: 'Technologie',
    date: '15 janvier 2026',
    readTime: '12 min de lecture',
    excerpt: 'Combien coûte un site web en Ouganda ? Ventilation honnête des prix en UGX, USD et FCFA — des sites modèles aux constructions sur mesure.',
    image: imgWebsiteCosts,
    imageAlt: 'Des professionnels examinent un site web sur une tablette',
  },
];
---

<BaseLayout
  title="Perspectives Tech — Peter Bamuhigire, Kampala"
  description="Articles sur le développement logiciel, le conseil IT et les solutions tech pour entreprises africaines. Peter Bamuhigire, consultant IT à Kampala."
  lang={lang}
  page="blog"
>
  <!-- Hero Banner -->
  <section class="bg-navy-900 pt-20 md:pt-24 pb-12 md:pb-16 geo-pattern">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white">
        Perspectives Tech pour les Entreprises Africaines
      </h1>
      <p class="mt-4 text-lg md:text-xl text-navy-200 max-w-2xl mx-auto">
        {t('blog.subtitle', lang)}
      </p>
      <div class="mt-6 h-1 w-20 rounded-full bg-gold-400 mx-auto"></div>
    </div>
  </section>

  <!-- Featured Article -->
  <section class="py-12 md:py-16 bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-amber-accent uppercase tracking-wider mb-6">Article en Vedette</p>
      <a href={`/${lang}/blog/${featuredPost.slug}/`} class="fade-up group block bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
          <div class="h-64 md:h-full min-h-[280px] overflow-hidden relative">
            <Image
              src={featuredPost.image}
              alt={featuredPost.imageAlt}
              width={1200}
              height={800}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute top-4 left-4">
              <span class="inline-flex items-center px-3 py-1 text-xs font-semibold bg-gold-400 text-navy-900 rounded-full">
                {featuredPost.category}
              </span>
            </div>
          </div>
          <div class="p-6 md:p-8 lg:p-10 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-3 text-sm text-navy-500">
              <time>{featuredPost.date}</time>
              <span class="w-1 h-1 rounded-full bg-navy-300"></span>
              <span>{featuredPost.readTime}</span>
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-navy-900 group-hover:text-amber-accent transition-colors leading-snug">
              {featuredPost.title}
            </h2>
            <p class="mt-3 text-navy-600 line-clamp-3">
              {featuredPost.excerpt}
            </p>
            <div class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-amber-accent group-hover:text-gold-700 transition-colors">
              Lire l'Article
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Blog Articles Section -->
  <section class="py-10 md:py-16 bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-navy-500 uppercase tracking-wider mb-6">Plus d'Articles</p>
      <!-- Blog Post Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {blogPosts.map((post) => (
          <a href={`/${lang}/blog/${post.slug}/`} class="fade-up group bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden block">
            <!-- Featured Image -->
            <div class="h-48 md:h-52 overflow-hidden relative">
              <Image
                src={post.image}
                alt={post.imageAlt}
                width={700}
                height={400}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-4 right-4">
                <span class="inline-flex items-center px-3 py-1 text-xs font-semibold bg-white/90 backdrop-blur-sm text-navy-800 rounded-full">
                  {post.category}
                </span>
              </div>
            </div>
            <!-- Card Content -->
            <div class="p-5 md:p-6">
              <div class="flex items-center gap-3 mb-3 text-sm text-navy-500">
                <time>{post.date}</time>
                <span class="w-1 h-1 rounded-full bg-navy-300"></span>
                <span>{post.readTime}</span>
              </div>
              <h3 class="text-lg md:text-xl font-bold text-navy-900 group-hover:text-amber-accent transition-colors leading-snug">
                {post.title}
              </h3>
              <p class="mt-2 text-sm text-navy-600 line-clamp-2">
                {post.excerpt}
              </p>
              <div class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-amber-accent group-hover:text-gold-700 transition-colors">
                Lire l'Article
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 md:py-20 bg-navy-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center" x-data="{ submitted: false }">
      <div class="fade-up">
        <svg class="w-10 h-10 text-gold-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <h2 class="text-2xl md:text-3xl font-bold text-navy-900">
          Restez Informé
        </h2>
        <p class="mt-3 text-navy-600">
          Abonnez-vous pour recevoir des analyses sur la technologie, la stratégie d'entreprise et l'innovation à travers l'Afrique — directement dans votre boîte de réception.
        </p>
      </div>

      <!-- Newsletter Form -->
      <div class="mt-8 fade-up" x-show="!submitted" x-transition>
        <form action="#" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" @submit.prevent="submitted = true">
          <label for="newsletter-email-fr" class="sr-only">Adresse e-mail</label>
          <input
            type="email"
            id="newsletter-email-fr"
            name="email"
            required
            placeholder="Entrez votre adresse e-mail"
            class="flex-1 px-4 py-3 bg-white border border-navy-200 rounded-lg text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-amber-accent hover:bg-gold-600 text-white font-semibold rounded-lg transition-colors whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-gold-500 focus:ring-offset-2"
          >
            S'abonner
          </button>
        </form>
        <p class="mt-3 text-xs text-navy-400">Aucun spam, jamais. Désabonnez-vous à tout moment.</p>
      </div>

      <!-- Confirmation Message -->
      <div x-show="submitted" x-cloak x-transition class="mt-8">
        <div class="inline-flex items-center gap-3 px-6 py-4 bg-white rounded-xl shadow-sm">
          <svg class="w-6 h-6 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-navy-800 font-medium">Merci ! Vous serez informé dès la publication de nouveaux articles.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection lang={lang} />
</BaseLayout>

<style>
  [x-cloak] { display: none !important; }
</style>
