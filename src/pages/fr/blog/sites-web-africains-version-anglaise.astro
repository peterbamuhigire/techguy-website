const category = "Stratégie Numérique";
const readTime = "12 min de lecture";
const slug = "sites-web-africains-version-anglaise";
const siteUrl = "https://techguypeter.com";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "author": {
    "@type": "Person",
    "name": "Peter Bamuhigire",
    "url": `${siteUrl}/fr/about/`
  },
  "datePublished": date,
  "dateModified": date,
  "publisher": {
    "@type": "Organization",
    "name": "Peter Bamuhigire — Technology & Business Consulting",
    "url": siteUrl
  },
  "description": description,
  "image": `${siteUrl}${heroImg.src}`,
  "inLanguage": "fr-FR",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/fr/blog/${slug}/`
