import type { Lang } from '@/utils/i18n';

import heroImg from '@/assets/images/business-man-laptop-office-coffee.jpg';
import imgLandscape1 from '@/assets/images/financial-forex-business-chart-report.jpg';
import imgPortrait from '@/assets/images/african-american-business-woman-with-phone.jpg';
import imgLandscape2 from '@/assets/images/african-entrepreneur-team-analyzing-business-reports.jpg';

const lang: Lang = 'fr';
const title = "Pourquoi Votre Site Web Africain a Besoin d'une Version Anglaise";
const description = "Pour concurrencer à l'échelle mondiale, les entreprises africaines francophones ont besoin d'un site web bilingue. Voici comment construire un site français-anglais qui convertit.";
