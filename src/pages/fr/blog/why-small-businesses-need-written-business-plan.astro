const lang: Lang = 'fr';
const title = "Même les Petites Entreprises ont Besoin d'un Plan d'Affaires Écrit";
const description = "Un plan d'affaires n'est pas un document pour les banques — c'est un outil de réflexion pour le dirigeant. Voici pourquoi toute petite entreprise en Afrique francophone en a besoin, et ce qu'il vous en coûte de ne pas en avoir.";
const date = "2026-03-17";
const category = "Stratégie";
const readTime = "14 min de lecture";
