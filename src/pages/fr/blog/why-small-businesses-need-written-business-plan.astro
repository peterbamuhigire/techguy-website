        </span>
      </div>
      <h1 class="bp-headline">{title}</h1>
      <div class="bp-byline">
        <span>Par Peter Bamuhigire</span>
        <span class="bp-dot"></span>
        <time datetime={date}>17 mars 2026</time>
        <span class="bp-dot"></span>
        <a href="/fr/services/" class="bp-byline-link">Conseil en Planification d'Entreprise</a>
      </div>
