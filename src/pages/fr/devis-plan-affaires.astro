              @click="submitForm()"
              :disabled="state === 'submitting'"
              class="ml-auto inline-flex items-center gap-2 px-8 py-3.5 bg-amber-accent hover:bg-amber-accent/90 text-white font-bold rounded-xl transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5 disabled:opacity-60 disabled:cursor-not-allowed text-base"
            >
              <span x-show="state !== 'submitting'">Soumettre mon dossier &amp; demander un devis</span>
              <span x-show="state === 'submitting'" x-cloak class="flex items-center gap-2">
                <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                Envoi en cours...
              </span>
              <svg x-show="state !== 'submitting'" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </button>
          </div>

          <!-- Note de confiance -->
          <p class="mt-5 text-center text-sm text-navy-400">
            Votre dossier est envoyé de manière sécurisée et utilisé uniquement pour préparer votre devis. Minimum 3 questions requises pour soumettre.
            <a href="/fr/business-planning-consulting-service/" class="underline hover:text-navy-600 ml-1">En savoir plus sur notre service →</a>
          </p>

        </div><!-- fin formulaire -->
      </div><!-- fin x-data -->

    </div>
  </section>

</BaseLayout>
