---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Lang } from '@/utils/i18n';

const lang: Lang = 'fr';

const steps = [
  {
    number: 1,
    title: 'Vos coordonnées',
    description: 'Nom, e-mail et téléphone pour vous envoyer votre devis.',
  },
  {
    number: 2,
    title: 'Votre entreprise',
    description: 'Ce que fait votre entreprise, depuis combien de temps et sa structure juridique.',
  },
  {
    number: 3,
    title: 'Offre & marché',
    description: 'Ce que vous proposez, qui sont vos clients et la taille de votre marché.',
  },
  {
    number: 4,
    title: 'Revenus & concurrence',
    description: 'Comment vous gagnez de l\'argent, votre tarification et vos concurrents.',
  },
  {
    number: 5,
    title: 'Finances & le document',
    description: 'Vos besoins en financement et le type de document dont vous avez besoin.',
  },
  {
    number: 6,
    title: 'Équipe & notes finales',
    description: 'Les personnes derrière l\'entreprise et tout ce qu\'il faut savoir.',
  },
];
---

<BaseLayout
  title="Devis Plan d'Affaires — Répondez à 10 Questions | Peter Bamuhigire"
  description="Répondez à 10 questions ciblées sur votre entreprise et vos objectifs de financement. Peter examinera votre dossier et vous enverra un devis personnalisé pour un plan d'affaires bancable dans les 48 heures."
  lang={lang}
  page="services"
>

  <!-- ==============================
       HERO
       ============================== -->
  <section class="bg-navy-950 pt-20 md:pt-24 pb-14 md:pb-18 geo-pattern relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/60 to-navy-950/90"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-5">
        <svg class="w-3.5 h-3.5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
        </svg>
        <span class="text-gold-400 text-sm font-medium">Planification Stratégique &amp; Plan d'Affaires</span>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-warm-white leading-tight">
        Démarrez votre dossier de plan d'affaires
      </h1>
      <p class="mt-4 text-lg text-navy-200 max-w-2xl mx-auto leading-relaxed">
        Répondez à 10 questions ciblées sur votre entreprise. Peter examinera votre dossier et vous enverra un devis personnalisé, sans engagement, dans les <strong class="text-gold-300">48 heures</strong>.
      </p>

      <!-- Badges de confiance -->
      <div class="mt-7 flex flex-wrap items-center justify-center gap-4 text-sm text-navy-300">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
          </svg>
          Confidentiel
        </span>
        <span class="text-navy-600">·</span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Environ 15 minutes
        </span>
        <span class="text-navy-600">·</span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Sans engagement
        </span>
        <span class="text-navy-600">·</span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          Réponse sous 48 heures
        </span>
      </div>

      <div class="mt-6 h-1 w-20 rounded-full bg-gold-400 mx-auto"></div>
    </div>
  </section>

  <!-- ==============================
       SECTION FORMULAIRE
       ============================== -->
  <section class="py-14 md:py-20 bg-warm-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div
        x-data="{
          step: 1,
          totalSteps: 6,
          state: 'idle',
          responseMessage: '',
          fieldErrors: [],
          csrfToken: '',
          csrfTs: 0,
          loadedAt: Math.floor(Date.now() / 1000),
          formData: {
            name: '',
            email: '',
            phone: '',
            company: '',
            q1: '',
            q2: '',
            q3: '',
            q4: '',
            q5: '',
            q6: '',
            q7: '',
            q8: '',
            q9: '',
            q10: '',
            website: ''
          },
          async init() {
            try {
              const res = await fetch('/api/csrf-token.php');
              const d = await res.json();
              this.csrfToken = d.token;
              this.csrfTs = d.ts;
            } catch(e) {}
          },
          validateStep() {
            this.fieldErrors = [];
            if (this.step === 1) {
              if (!this.formData.name || this.formData.name.trim().length < 2) this.fieldErrors.push('name');
              if (!this.formData.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.formData.email)) this.fieldErrors.push('email');
            }
            return this.fieldErrors.length === 0;
          },
          hasError(field) { return this.fieldErrors.includes(field); },
          nextStep() {
            if (!this.validateStep()) return;
            if (this.step < this.totalSteps) {
              this.step++;
              this.$nextTick(() => window.scrollTo({ top: document.getElementById('form-anchor-fr').offsetTop - 80, behavior: 'smooth' }));
            }
          },
          prevStep() {
            if (this.step > 1) {
              this.step--;
              this.$nextTick(() => window.scrollTo({ top: document.getElementById('form-anchor-fr').offsetTop - 80, behavior: 'smooth' }));
            }
          },
          answeredCount() {
            const fields = ['q1','q2','q3','q4','q5','q6','q7','q8','q9','q10'];
            return fields.filter(f => this.formData[f] && this.formData[f].trim().length >= 20).length;
          },
          async submitForm() {
            if (!this.validateStep()) return;
            this.state = 'submitting';
            try {
              const res = await fetch('/api/business-plan-intake.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  ...this.formData,
                  lang: 'fr',
                  _csrf_token: this.csrfToken,
                  _csrf_ts: this.csrfTs,
                  _loaded_at: this.loadedAt
                })
              });
              const data = await res.json();
              this.responseMessage = data.message;
              this.state = data.success ? 'success' : 'error';
              if (data.success) window.scrollTo({ top: 0, behavior: 'smooth' });
            } catch(e) {
              this.responseMessage = 'Une erreur est survenue. Veuillez envoyer un e-mail directement à peter@techguypeter.com.';
              this.state = 'error';
            }
          }
        }"
        x-init="init()"
        id="form-anchor-fr"
      >

        <!-- ======= SUCCÈS ======= -->
        <div x-show="state === 'success'" x-cloak class="text-center py-16 max-w-xl mx-auto">
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="text-3xl font-bold text-navy-900 mb-3">Dossier reçu !</h2>
          <p class="text-navy-600 text-lg leading-relaxed mb-3" x-text="responseMessage"></p>
          <p class="text-navy-500 text-sm mb-2">Une copie de vos réponses vous a été envoyée par e-mail pour vos archives.</p>
          <p class="text-navy-500 text-sm mb-8">Peter vous contactera dans les 48 heures. Pour toute urgence, WhatsApp <strong>+256 784 464178</strong>.</p>
          <a href="/fr/business-planning-consulting-service/" class="inline-flex items-center gap-2 text-amber-accent font-semibold hover:underline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
            </svg>
            Retour à nos services Plan d'Affaires
          </a>
        </div>

        <!-- ======= FORMULAIRE ======= -->
        <div x-show="state !== 'success'">

          <!-- Bannière d'erreur -->
          <div x-show="state === 'error'" x-cloak class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-red-700 text-sm" x-text="responseMessage"></p>
          </div>

          <!-- Barre de progression -->
          <div class="mb-8">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-navy-800">
                Étape <span x-text="step"></span> sur <span x-text="totalSteps"></span>
              </span>
              <span class="text-xs text-navy-500 bg-navy-50 px-2.5 py-1 rounded-full">
                <span x-text="answeredCount()"></span> questions répondues sur 10
              </span>
            </div>
            <div class="h-2 bg-navy-100 rounded-full overflow-hidden">
              <div
                class="h-full bg-gold-400 rounded-full transition-all duration-500 ease-in-out"
                :style="`width: ${(step / totalSteps) * 100}%`"
              ></div>
            </div>
            <!-- Indicateurs d'étapes -->
            <div class="mt-3 hidden sm:flex gap-1">
              {steps.map(s => (
                <div
                  class="flex-1 text-center"
                  :class={`step === ${s.number} ? 'opacity-100' : step > ${s.number} ? 'opacity-70' : 'opacity-30'`}
                >
                  <div
                    class="w-7 h-7 rounded-full mx-auto flex items-center justify-center text-xs font-bold transition-all duration-300"
                    :class={`step === ${s.number} ? 'bg-gold-400 text-navy-900 ring-2 ring-gold-400/30' : step > ${s.number} ? 'bg-green-500 text-white' : 'bg-navy-200 text-navy-500'`}
                  >
                    <span x-show={`step <= ${s.number}`} class="leading-none">{s.number}</span>
                    <svg x-show={`step > ${s.number}`} x-cloak class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <p class="text-xs text-navy-600 mt-1.5 leading-tight hidden md:block">{s.title}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Honeypot -->
          <div class="absolute opacity-0 -z-10 h-0 overflow-hidden" aria-hidden="true">
            <input type="text" name="website" x-model="formData.website" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Mise en page desktop: barre latérale + carte -->
          <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-8 lg:items-start">

            <!-- ===== BARRE LATÉRALE (desktop uniquement) ===== -->
            <aside class="hidden lg:block sticky top-28">
              <nav aria-label="Étapes du formulaire" class="space-y-1">
                {steps.map(s => (
                  <div
                    class="flex items-start gap-3 px-3 py-3 rounded-xl transition-all duration-200"
                    :class={`step === ${s.number} ? 'bg-navy-900 shadow-sm' : step > ${s.number} ? 'opacity-60' : 'opacity-40'`}
                  >
                    <div
                      class="w-7 h-7 shrink-0 rounded-full flex items-center justify-center text-xs font-bold mt-0.5 transition-all duration-200"
                      :class={`step === ${s.number} ? 'bg-gold-400 text-navy-900' : step > ${s.number} ? 'bg-green-500 text-white' : 'bg-navy-200 text-navy-500'`}
                    >
                      <span x-show={`step <= ${s.number}`} class="leading-none">{s.number}</span>
                      <svg x-show={`step > ${s.number}`} x-cloak class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <div>
                      <p
                        class="text-sm font-semibold leading-tight transition-colors duration-200"
                        :class={`step === ${s.number} ? 'text-gold-400' : step > ${s.number} ? 'text-green-400' : 'text-navy-400'`}
                      >{s.title}</p>
                      <p
                        class="text-xs leading-snug mt-0.5 hidden xl:block"
                        :class={`step === ${s.number} ? 'text-navy-300' : 'text-navy-500'`}
                      >{s.description}</p>
                    </div>
                  </div>
                ))}
              </nav>

              <div class="mt-6 p-4 bg-navy-50 rounded-xl border border-navy-100">
                <p class="text-xs text-navy-600 leading-relaxed">
                  <strong class="text-navy-800 block mb-1">Vos réponses sont confidentielles.</strong>
                  Elles sont utilisées uniquement pour préparer votre devis personnalisé. Peter ne les communiquera pas à des tiers.
                </p>
              </div>
            </aside>

            <!-- ===== ZONE PRINCIPALE ===== -->
            <div>

              <!-- ====== ÉTAPE 1 : Coordonnées ====== -->
              <div x-show="step === 1" class="bg-white rounded-2xl shadow-sm border border-navy-100 p-6 md:p-8">
                <div class="mb-6">
                  <h2 class="text-2xl font-bold text-navy-900">Commençons par vos coordonnées</h2>
                  <p class="mt-1.5 text-navy-500 text-sm leading-relaxed">Nous les utiliserons pour rédiger votre dossier correctement et vous envoyer votre devis personnalisé.</p>
                </div>

                <div class="space-y-5">
                  <div>
                    <label for="bp-fr-name" class="block text-sm font-semibold text-navy-800 mb-1.5">
                      Nom complet <span class="text-amber-accent" aria-hidden="true">*</span>
                    </label>
                    <input
                      type="text"
                      id="bp-fr-name"
                      x-model="formData.name"
                      :class="hasError('name') ? 'border-red-400 bg-red-50' : 'border-navy-200 focus:border-gold-400'"
                      class="w-full px-4 py-3 border rounded-xl text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/30 transition-all duration-200 text-base"
                      placeholder="Votre nom complet"
                      autocomplete="name"
                    />
                    <p x-show="hasError('name')" x-cloak class="mt-1.5 text-sm text-red-600">Veuillez entrer votre nom complet.</p>
                  </div>

                  <div>
                    <label for="bp-fr-email" class="block text-sm font-semibold text-navy-800 mb-1.5">
                      Adresse e-mail <span class="text-amber-accent" aria-hidden="true">*</span>
                    </label>
                    <input
                      type="email"
                      id="bp-fr-email"
                      x-model="formData.email"
                      :class="hasError('email') ? 'border-red-400 bg-red-50' : 'border-navy-200 focus:border-gold-400'"
                      class="w-full px-4 py-3 border rounded-xl text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/30 transition-all duration-200 text-base"
                      placeholder="vous@entreprise.com"
                      autocomplete="email"
                    />
                    <p x-show="hasError('email')" x-cloak class="mt-1.5 text-sm text-red-600">Veuillez entrer une adresse e-mail valide.</p>
                  </div>

                  <div>
                    <label for="bp-fr-phone" class="block text-sm font-semibold text-navy-800 mb-1.5">
                      Téléphone / WhatsApp
                      <span class="text-navy-400 font-normal text-xs ml-1">(facultatif — pour vous joindre plus rapidement)</span>
                    </label>
                    <input
                      type="tel"
                      id="bp-fr-phone"
                      x-model="formData.phone"
                      class="w-full px-4 py-3 border border-navy-200 rounded-xl text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/30 focus:border-gold-400 transition-all duration-200 text-base"
                      placeholder="+225 07 00 00 00 00"
                      autocomplete="tel"
                    />
                  </div>

                  <div>
                    <label for="bp-fr-company" class="block text-sm font-semibold text-navy-800 mb-1.5">
                      Nom de l'entreprise / organisation
                      <span class="text-navy-400 font-normal text-xs ml-1">(facultatif)</span>
                    </label>
                    <input
                      type="text"
                      id="bp-fr-company"
                      x-model="formData.company"
                      class="w-full px-4 py-3 border border-navy-200 rounded-xl text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/30 focus:border-gold-400 transition-all duration-200 text-base"
                      placeholder="Nom de votre entreprise (ou laissez vide si pas encore nommée)"
                      autocomplete="organization"
                    />
                  </div>
                </div>
              </div>

              <!-- ====== ÉTAPE 2 : Votre entreprise & le problème ====== -->
              <div x-show="step === 2" x-cloak class="space-y-5">
                <div class="bg-white rounded-2xl shadow-sm border border-navy-100 p-6 md:p-8">
                  <div class="mb-5">
                    <span class="inline-block text-xs font-bold text-gold-600 uppercase tracking-wider mb-2">Question 1 sur 10</span>
                    <h2 class="text-xl md:text-2xl font-bold text-navy-900">Parlez-nous de votre entreprise</h2>
                    <p class="mt-2 text-navy-500 text-sm leading-relaxed">
                      Que fait votre entreprise ? Depuis combien de temps fonctionne-t-elle — ou s'agit-il d'une nouvelle idée ? Dans quel secteur opère-t-elle, où est-elle basée, combien de personnes y travaillent, et quelle est sa structure juridique — par exemple, entreprise individuelle, SARL, SA, coopérative ? Si elle a déjà un nom, veuillez l'inclure.
                    </p>
                  </div>
                  <textarea
                    id="fr-q1"
                    x-model="formData.q1"
                    rows="7"
                    class="w-full px-4 py-3 border border-navy-200 rounded-xl text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/30 focus:border-gold-400 transition-all duration-200 resize-none text-base leading-relaxed"
                    placeholder="Ex. : Abidjan Fresh SARL est une entreprise de distribution de produits frais créée il y a deux ans à Abidjan, en Côte d'Ivoire. Nous approvisionnons huit hôtels et quinze restaurants. Nous sommes une SARL avec quatre employés permanents..."
                  ></textarea>
                  <div class="mt-4 flex gap-3 p-4 bg-amber-50 border border-amber-100 rounded-xl">
                    <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>
                    </svg>
                    <p class="text-xs text-amber-800 leading-relaxed">
                      <strong>Pourquoi nous posons cette question :</strong> Plus vous donnez de contexte sur le stade de développement et la structure de votre entreprise, plus Peter peut adapter le plan à l'audience ciblée — comité de crédit bancaire, IFD ou investisseurs.
                    </p>
                  </div>
                </div>

                <div class="bg-white rounded-2xl shadow-sm border border-navy-100 p-6 md:p-8">
                  <div class="mb-5">
                    <span class="inline-block text-xs font-bold text-gold-600 uppercase tracking-wider mb-2">Question 2 sur 10</span>
                    <h2 class="text-xl md:text-2xl font-bold text-navy-900">Quel problème résolvez-vous ?</h2>
                    <p class="mt-2 text-navy-500 text-sm leading-relaxed">
                      Quelle lacune du marché votre entreprise comble-t-elle ? Qui rencontre ce problème et pourquoi n'est-il pas bien servi aujourd'hui ? Qu'est-ce qui vous a amené à identifier cette opportunité — une expérience personnelle, une étude, un manque que vous avez observé — et pourquoi est-ce le bon moment d'agir ?
                    </p>
                  </div>
                  <textarea
                    id="fr-q2"
                    x-model="formData.q2"
                    rows="6"
                    class="w-full px-4 py-3 border border-navy-200 rounded-xl text-navy-900 placeholder-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-400/30 focus:border-gold-400 transition-all duration-200 resize-none text-base leading-relaxed"
                    placeholder="Ex. : Les hôtels à Abidjan peinent à obtenir des produits frais de qualité de manière régulière car les fournisseurs existants sont peu fiables. J'ai identifié ce manque après trois ans en tant que chef de cuisine au Sofitel..."
                  ></textarea>
                  <div class="mt-4 flex gap-3 p-4 bg-amber-50 border border-amber-100 rounded-xl">
                    <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>
                    </svg>
                    <p class="text-xs text-amber-800 leading-relaxed">
