---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { Lang } from '@/utils/i18n';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import OfferTierCard from '@/components/OfferTierCard.astro';
import ProofBlock from '@/components/ProofBlock.astro';
import TestimonialCard from '@/components/TestimonialCard.astro';
import { siteConfig } from '@/data/site';

import heroImage from '@/assets/images/hero/home-page-photo.jpg';
import maduukaImg from '@/assets/images/portfolio/MADUUKASOFTWARE-01.jpg';
import aqarImg from '@/assets/images/portfolio/PROPERTY-MANAGEMENT-01.jpg';
import longhornImg from '@/assets/images/portfolio/ERP-01.jpg';

const lang: Lang = 'fr';
const stats = siteConfig.proof.stats;
const tiers = siteConfig.offers.projectTiers;
const retainers = siteConfig.offers.retainers;
const testimonials = siteConfig.proof.testimonials;
const cases = siteConfig.proof.cases;
---

<BaseLayout
  title="Sites d'autorite, logiciels et strategie TIC | Peter Bamuhigire"
  description="Sites d'autorite, logiciels, conseil TIC et systemes numeriques pour entreprises serieuses en Ouganda, Afrique de l'Est et Afrique francophone."
  lang={lang}
  page="home"
>
  <section id="hero" class="relative overflow-hidden bg-navy-950">
    <div class="absolute inset-0 geo-pattern opacity-30"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(240,194,67,0.18),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(199,91,18,0.22),transparent_30%)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 pt-24 pb-16 sm:px-6 lg:px-8 lg:pt-32 lg:pb-24">
      <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <div class="fade-up">
          <p class="text-sm font-semibold uppercase tracking-[0.26em] text-gold-400">{siteConfig.hero.fr.eyebrow}</p>
          <h1 class="mt-5 max-w-4xl text-4xl font-bold leading-tight text-warm-white md:text-6xl">
            {siteConfig.hero.fr.title}
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed text-navy-200 md:text-xl">
            {siteConfig.hero.fr.subtitle}
          </p>
          <p class="mt-5 max-w-3xl text-base leading-relaxed text-navy-300">
            {siteConfig.categoryClaim.fr} {siteConfig.hero.fr.qualifier}
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href="/fr/contact/" data-cta class="cta-button inline-flex items-center justify-center rounded-xl bg-amber-accent px-7 py-4 text-lg font-semibold text-white transition hover:bg-gold-600">
              Reserver un appel diagnostic
            </a>
            <a href="/fr/tarifs/" class="inline-flex items-center justify-center rounded-xl border border-gold-400 px-7 py-4 text-lg font-semibold text-gold-400 transition hover:bg-gold-400/10">
              Voir les tarifs et le fit
            </a>
          </div>
        </div>

        <div class="fade-up">
          <div class="relative mx-auto max-w-md lg:max-w-lg">
            <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-gold-400/25 via-transparent to-amber-accent/20 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[2rem] border border-gold-400/20 shadow-2xl shadow-black/35">
              <Image
                src={heroImage}
                alt="Peter Bamuhigire travaillant sur des systemes et strategies numeriques"
                width={640}
                height={760}
                loading="eager"
                class="h-full w-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-navy-900 py-12 md:py-16">
    <div class="mx-auto grid max-w-6xl gap-6 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      {stats.map((stat) => (
        <div class="fade-up rounded-2xl border border-navy-700 bg-navy-950/50 p-6 text-center">
          <p class="counter text-4xl font-bold text-gold-400" data-target={parseInt(stat.value, 10) || 0}>{stat.value}</p>
          <p class="mt-3 text-sm leading-relaxed text-navy-200">{stat.labelFr}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Ce que fait la pratique</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Trois leviers pour creer de la confiance et de la clarte.</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Sites d'autorite</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Des sites qui portent la reputation, pas seulement un formulaire.</h3>
          <p class="mt-4 text-navy-600">Concu pour les cabinets, institutions et entreprises qui doivent convaincre des acheteurs exigeants ou des parties prenantes.</p>
        </div>
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Logiciels et systemes</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Des outils qui reduisent la friction dans les operations reelles.</h3>
          <p class="mt-4 text-navy-600">Applications sur mesure, reporting, ERP et systemes qui tiennent compte des realites africaines.</p>
        </div>
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Conseil TIC et business</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Une direction claire quand les enjeux numeriques sont eleves.</h3>
          <p class="mt-4 text-navy-600">Diagnostic, feuille de route, systemes de reporting, business planning et recommandations qui tiennent commercialement.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Preuves</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Des systemes reels, pas des promesses abstraites.</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={maduukaImg} alt="Plateforme Maduuka" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[0].titleFr} summary={cases[0].summaryFr} />
          </div>
        </div>
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={aqarImg} alt="Plateforme Aqar" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[1].titleFr} summary={cases[1].summaryFr} />
          </div>
        </div>
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={longhornImg} alt="ERP Longhorn" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[2].titleFr} summary={cases[2].summaryFr} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Architecture de l'offre</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Des niveaux de projet penses comme des systemes complets.</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {tiers.map((tier) => (
          <div class="fade-up">
            <OfferTierCard name={tier.name} price={tier.price} description={tier.descriptionFr} bullets={tier.bulletsFr} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy-950 py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">Retainers</p>
        <h2 class="mt-4 text-3xl font-bold text-warm-white md:text-5xl">Le support post-lancement est structure.</h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {retainers.map((retainer) => (
          <article class="fade-up rounded-3xl border border-navy-800 bg-navy-900 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">{retainer.price}</p>
            <h3 class="mt-3 text-xl font-bold text-warm-white">{retainer.nameFr}</h3>
            <p class="mt-4 text-sm leading-relaxed text-navy-300">{retainer.summaryFr}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Temoignages</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Des signaux de confiance utiles aux prospects exigeants.</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {testimonials.map((testimonial) => (
          <div class="fade-up">
            <TestimonialCard
              quote={testimonial.quoteFr}
              name={testimonial.name}
              role={testimonial.role}
              highlight={testimonial.highlightFr}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQSection
    title="Questions que les prospects posent avant de vous contacter"
    subtitle="Le site repond maintenant aux vraies questions commerciales de facon directe."
    faqs={siteConfig.faqs.fr}
  />

  <section class="bg-navy-50 py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <NewsletterSignup lang={lang} />
      </div>
    </div>
  </section>

  <CTASection
    lang={lang}
    title="Si votre reputation est plus forte que votre presence numerique actuelle, corrigez cela maintenant."
    subtitle="Le premier appel est un diagnostic. Nous identifions les points ou le site, le message ou le systeme vous coute de la confiance, du temps ou des opportunites."
    ctaHref="/fr/contact/"
    ctaLabel="Reserver un appel diagnostic"
    secondaryHref="/fr/tarifs/"
    secondaryLabel="Voir les tarifs"
  />
</BaseLayout>
