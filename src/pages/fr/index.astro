---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { Lang } from '@/utils/i18n';
import CTASection from '@/components/CTASection.astro';
import FAQSection from '@/components/FAQSection.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import OfferTierCard from '@/components/OfferTierCard.astro';
import ProofBlock from '@/components/ProofBlock.astro';
import TestimonialCard from '@/components/TestimonialCard.astro';
import { siteConfig } from '@/data/site';

import heroImage from '@/assets/images/hero/home-page-photo.jpg';
import maduukaImg from '@/assets/images/portfolio/MADUUKASOFTWARE-01.jpg';
import aqarImg from '@/assets/images/portfolio/PROPERTY-MANAGEMENT-01.jpg';
import longhornImg from '@/assets/images/portfolio/ERP-01.jpg';

const lang: Lang = 'fr';
const stats = siteConfig.proof.stats;
const tiers = siteConfig.offers.projectTiers;
const retainers = siteConfig.offers.retainers;
const testimonials = siteConfig.proof.testimonials;
const cases = siteConfig.proof.cases;
---

<BaseLayout
  title="Systèmes de gestion d'entreprise et développement logiciel | Peter Bamuhigire"
  description="Systèmes de gestion d'entreprise sur mesure, ERP et logiciels — développés, déployés et maintenus pour les organisations à travers l'Ouganda, l'Afrique de l'Est et l'Afrique francophone."
  lang={lang}
  page="home"
>
  <section id="hero" class="relative overflow-hidden bg-navy-950">
    <div class="absolute inset-0 geo-pattern opacity-30"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(240,194,67,0.18),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(199,91,18,0.22),transparent_30%)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 pt-24 pb-16 sm:px-6 lg:px-8 lg:pt-32 lg:pb-24">
      <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:gap-16">
        <div class="fade-up">
          <p class="text-sm font-semibold uppercase tracking-[0.26em] text-gold-400">{siteConfig.hero.fr.eyebrow}</p>
          <h1 class="mt-5 max-w-4xl text-4xl font-bold leading-tight text-warm-white md:text-6xl">
            {siteConfig.hero.fr.title}
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed text-navy-200 md:text-xl">
            {siteConfig.hero.fr.subtitle}
          </p>
          <p class="mt-5 max-w-3xl text-base leading-relaxed text-navy-300">
            {siteConfig.categoryClaim.fr} {siteConfig.hero.fr.qualifier}
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href="/fr/contact/" data-cta class="cta-button inline-flex items-center justify-center rounded-xl bg-amber-accent px-7 py-4 text-lg font-semibold text-white transition hover:bg-gold-600">
              Réserver un appel diagnostic
            </a>
            <a href="/fr/tarifs/" class="inline-flex items-center justify-center rounded-xl border border-gold-400 px-7 py-4 text-lg font-semibold text-gold-400 transition hover:bg-gold-400/10">
              Voir les tarifs et le profil
            </a>
          </div>
        </div>

        <div class="fade-up">
          <div class="relative mx-auto max-w-md lg:max-w-lg">
            <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-gold-400/25 via-transparent to-amber-accent/20 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-[2rem] border border-gold-400/20 shadow-2xl shadow-black/35">
              <Image
                src={heroImage}
                alt="Peter Bamuhigire travaillant sur des systèmes et stratégies numériques"
                width={640}
                height={760}
                loading="eager"
                class="h-full w-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-navy-900 py-12 md:py-16">
    <div class="mx-auto grid max-w-6xl gap-6 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      {stats.map((stat) => (
        <div class="fade-up rounded-2xl border border-navy-700 bg-navy-950/50 p-6 text-center">
          <p class="counter text-4xl font-bold text-gold-400" data-target={parseInt(stat.value, 10) || 0}>{stat.value}</p>
          <p class="mt-3 text-sm leading-relaxed text-navy-200">{stat.labelFr}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Comment le cabinet crée du levier</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Trois manières dont le cabinet crée un levier opérationnel.</h2>
        <p class="mt-5 text-lg leading-relaxed text-navy-600">
          Le travail n'est pas vendu comme des services déconnectés. Il est conçu autour d'un seul pivot &mdash; des logiciels qui sont développés, déployés et maintenus comme une discipline continue, complétés par le travail web et le conseil lorsque l'activité en a besoin.
        </p>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Systèmes de gestion d'entreprise</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Des systèmes construits, déployés et exploités pour les opérations africaines réelles.</h3>
          <p class="mt-4 text-navy-600">
            ERP, systèmes de gestion d'entreprise sur mesure, applications mobiles et plateformes SaaS &mdash; y compris les technologies de gestion immobilière. Le cabinet ne se contente pas de les construire : il les déploie, les exploite et les maintient sous contrats de service (SLA), pour que le système continue de produire bien après la mise en production.
          </p>
          <ul class="mt-5 space-y-3 text-sm text-navy-700">
            <li>Architecture ERP et SaaS pour des flux opérationnels réels</li>
            <li>Déploiement, migration des données et reprise opérationnelle</li>
            <li>Gestion continue sous SLA et évolution des fonctionnalités</li>
          </ul>
        </div>
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Sites web stratégiques</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Des sites web pour les organisations dont la réputation a un poids commercial.</h3>
          <p class="mt-4 text-navy-600">
            Conception orientée positionnement, performance technique sur Astro avec des scores Lighthouse de 95 à 100, livraison multilingue, SEO et analytics intégrés. Pensé pour les cabinets, les institutions et les structures financées dont le site doit convaincre conseils d'administration, investisseurs et acheteurs entreprises.
          </p>
          <ul class="mt-5 space-y-3 text-sm text-navy-700">
            <li>Positionnement, architecture du message et hiérarchie des CTA</li>
            <li>Livraison statique Astro, Lighthouse 95&ndash;100, multilingue</li>
            <li>SEO, schema, analytics et support en retainer</li>
          </ul>
        </div>
        <div class="fade-up rounded-3xl border border-navy-100 bg-white p-7 shadow-sm shadow-navy-900/5">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-600">Stratégie TIC et conseil business</p>
          <h3 class="mt-3 text-2xl font-bold text-navy-900">Une direction claire quand les décisions systèmes et stratégiques comptent vraiment.</h3>
          <p class="mt-4 text-navy-600">
            Stratégie d'infrastructure TIC, feuilles de route de transformation digitale, business planning pour banques, IFD et investisseurs, et marketing digital &mdash; pour les directions qui ont besoin d'un second avis solide avant d'engager des dépenses.
          </p>
          <ul class="mt-5 space-y-3 text-sm text-navy-700">
            <li>Stratégie d'infrastructure TIC et feuilles de route de transformation</li>
            <li>Business planning et documentation destinée aux investisseurs</li>
            <li>Orientation marketing digital et clarté diagnostique avant tout développement</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Preuves</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Des systèmes que le cabinet a livrés &mdash; et qu'il continue d'exploiter.</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={maduukaImg} alt="Plateforme Maduuka" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[0].titleFr} summary={cases[0].summaryFr} />
          </div>
        </div>
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={aqarImg} alt="Plateforme Aqar" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[1].titleFr} summary={cases[1].summaryFr} />
          </div>
        </div>
        <div class="fade-up rounded-3xl overflow-hidden border border-navy-100 bg-white shadow-sm shadow-navy-900/5">
          <Image src={longhornImg} alt="ERP Longhorn" width={720} height={480} class="h-56 w-full object-cover" />
          <div class="p-6">
            <ProofBlock title={cases[2].titleFr} summary={cases[2].summaryFr} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-warm-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Architecture de l'offre</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Des niveaux d'engagement pour les systèmes, les logiciels et le travail numérique stratégique.</h2>
        <p class="mt-5 text-lg text-navy-600">
          Ces niveaux couvrent l'ensemble du cycle de vie &mdash; d'un site web ciblé ou d'un brief stratégique jusqu'à un système de gestion d'entreprise sur mesure que le cabinet développe, déploie et exploite avec vous. Les niveaux supérieurs reflètent une profondeur systèmes, et non simplement un budget marketing plus important.
        </p>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {tiers.map((tier) => (
          <div class="fade-up">
            <OfferTierCard name={tier.name} price={tier.price} description={tier.descriptionFr} bullets={tier.bulletsFr} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-navy-950 py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">Architecture du cycle de vie</p>
        <h2 class="mt-4 text-3xl font-bold text-warm-white md:text-5xl">Après la mise en production, le cabinet exploite les systèmes avec vous.</h2>
        <p class="mt-5 text-lg text-navy-200">
          Les retainers sont la manière concrète dont le cycle développer&ndash;déployer&ndash;gérer&ndash;maintenir est livré. Chaque niveau définit le SLA, la posture de réponse et la façon dont le système continue de produire de la valeur mois après mois.
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {retainers.map((retainer) => (
          <article class="fade-up rounded-3xl border border-navy-800 bg-navy-900 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-gold-400">{retainer.price}</p>
            <h3 class="mt-3 text-xl font-bold text-warm-white">{retainer.nameFr}</h3>
            <p class="mt-4 text-sm leading-relaxed text-navy-300">{retainer.summaryFr}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-warm-cream py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-accent">Témoignages</p>
        <h2 class="mt-4 text-3xl font-bold text-navy-900 md:text-5xl">Ce que disent les clients qui exploitent ces systèmes.</h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {testimonials.map((testimonial) => (
          <div class="fade-up">
            <TestimonialCard
              quote={testimonial.quoteFr}
              name={testimonial.name}
              role={testimonial.role}
              highlight={testimonial.highlightFr}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQSection
    title="Questions que les prospects posent avant de vous contacter"
    subtitle="Les questions qui reviennent le plus souvent quand la direction se demande s'il faut commander un nouveau système, un site web ou un accompagnement stratégique."
    faqs={siteConfig.faqs.fr}
  />

  <section class="bg-navy-50 py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="fade-up">
        <NewsletterSignup lang={lang} />
      </div>
    </div>
  </section>

  <CTASection
    lang={lang}
    title="Si vos opérations ont dépassé les systèmes qui les soutiennent, c'est ce qu'il faut corriger ensuite."
    subtitle="Le premier appel est un diagnostic. Le cabinet identifie les zones où les opérations perdent du temps, de l'argent ou de la visibilité, puis recommande une direction unique : un nouveau système, une mise à niveau d'un système existant, ou une clarification stratégique avant tout développement."
    ctaHref="/fr/contact/"
    ctaLabel="Réserver un appel diagnostic"
    secondaryHref="/fr/tarifs/"
    secondaryLabel="Voir les tarifs"
  />
</BaseLayout>
