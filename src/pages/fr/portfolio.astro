---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import { t, type Lang } from '@/utils/i18n';

const lang: Lang = 'fr';
---

<BaseLayout
  title="Réalisations — Peter Bamuhigire"
  description="Produits développés, contributions open source et missions de conseil réalisées à travers l'Afrique et à l'international par Peter Bamuhigire."
  lang={lang}
>
  <!-- ═══════════════════════════════════════════════════════
       HERO BANNER
       ═══════════════════════════════════════════════════════ -->
  <section class="bg-navy-900 geo-pattern pt-20 md:pt-24 pb-14 md:pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white fade-up">
        Réalisations
      </h1>
      <div class="mt-4 h-1 w-20 rounded-full bg-gold-400 mx-auto"></div>
      <p class="mt-6 max-w-3xl mx-auto text-lg md:text-xl text-navy-200 leading-relaxed fade-up">
        Une sélection de produits développés, de projets open source et de missions
        de conseil réalisées à travers l'Afrique et à l'international. Ce portfolio reflète
        l'étendue du travail de Peter Bamuhigire &mdash; des plateformes SaaS servant
        des entreprises dans plusieurs pays à la gestion institutionnelle des TIC et au conseil stratégique.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FLAGSHIP PRODUCTS
       ═══════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Produits Phares"
        subtitle="Des plateformes SaaS conçues à partir de problèmes réels d'entreprise, servant des clients à travers l'Afrique et au-delà."
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        <!-- Maduuka -->
        <article class="bg-white rounded-2xl shadow-lg shadow-navy-900/5 overflow-hidden border border-navy-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 fade-up">
          <div class="bg-gradient-to-br from-navy-800 to-navy-600 rounded-xl h-48 flex items-center justify-center m-4">
            <span class="text-2xl md:text-3xl font-heading font-bold text-gold-400">Maduuka</span>
          </div>
          <div class="p-6 pt-2">
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gold-100 text-gold-800">SaaS</span>
              <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-navy-100 text-navy-700">Gestion d'Entreprise</span>
            </div>
            <h3 class="text-xl font-bold text-navy-900">Maduuka</h3>
            <p class="mt-2 text-navy-600 text-sm leading-relaxed">
              Une plateforme SaaS multi-tenant de comptabilité et de gestion d'entreprise conçue pour
              les PME à travers l'Afrique. Les modules incluent le Point de Vente, la Gestion des Stocks,
              les Ventes, la Comptabilité, la Pharmacie, la Restauration et la Gestion des Actifs.
            </p>
            <ul class="mt-4 space-y-1.5 text-sm text-navy-600">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Multilingue : anglais, français, arabe, swahili, espagnol
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Application Android hors ligne (Kotlin/Jetpack Compose)
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Multi-tenant : du commerce individuel aux franchises
              </li>
            </ul>
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-50 text-navy-600 border border-navy-200">PHP</span>
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-50 text-navy-600 border border-navy-200">MySQL</span>
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-50 text-navy-600 border border-navy-200">Kotlin</span>
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-50 text-navy-600 border border-navy-200">REST API</span>
            </div>
          </div>
        </article>

        <!-- Aqar -->
        <article class="bg-white rounded-2xl shadow-lg shadow-navy-900/5 overflow-hidden border border-navy-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 fade-up">
          <div class="bg-gradient-to-br from-navy-800 to-navy-600 rounded-xl h-48 flex items-center justify-center m-4">
            <span class="text-2xl md:text-3xl font-heading font-bold text-gold-400">Aqar</span>
          </div>
          <div class="p-6 pt-2">
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gold-100 text-gold-800">PropTech</span>
              <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-navy-100 text-navy-700">Gestion Immobilière</span>
            </div>
            <h3 class="text-xl font-bold text-navy-900">Aqar Property Management</h3>
            <p class="mt-2 text-navy-600 text-sm leading-relaxed">
              Logiciel de gestion immobilière pour propriétaires et gestionnaires de biens &mdash; gestion
              des locataires, suivi des loyers et planification de la maintenance dans un seul système.
              Dessert des clients au-delà des frontières, y compris au Royaume-Uni.
            </p>
            <ul class="mt-4 space-y-1.5 text-sm text-navy-600">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Gestion complète des locataires et suivi des baux
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Suivi de la collecte des loyers et rapports sur les arriérés
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Planification de la maintenance et rapports financiers
              </li>
            </ul>
            <div class="mt-5 flex flex-wrap items-center gap-2">
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-50 text-navy-600 border border-navy-200">PHP</span>
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-50 text-navy-600 border border-navy-200">MySQL</span>
              <a
                href="https://aqarproperty.co.uk"
                target="_blank"
                rel="noopener noreferrer"
                class="ml-auto inline-flex items-center gap-1.5 text-xs font-medium text-amber-accent hover:text-gold-600 transition-colors"
              >
                Visiter le Site
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            </div>
          </div>
        </article>

        <!-- Chwezi Server Manager -->
        <article class="bg-white rounded-2xl shadow-lg shadow-navy-900/5 overflow-hidden border border-navy-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 fade-up">
          <div class="bg-gradient-to-br from-navy-800 to-navy-600 rounded-xl h-48 flex items-center justify-center m-4">
            <span class="text-xl md:text-2xl font-heading font-bold text-gold-400 text-center px-4">Chwezi<br/>Server Manager</span>
          </div>
          <div class="p-6 pt-2">
            <div class="flex flex-wrap gap-2 mb-3">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gold-100 text-gold-800">DevOps</span>
              <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-navy-100 text-navy-700">Administration Serveur</span>
            </div>
            <h3 class="text-xl font-bold text-navy-900">Chwezi Server Manager</h3>
            <p class="mt-2 text-navy-600 text-sm leading-relaxed">
              Un outil auto-hébergé de gestion de serveurs offrant une administration complète
              depuis un tableau de bord unique &mdash; domaines, SSL, bases de données, cron, Git et
              déploiement WordPress.
            </p>
            <ul class="mt-4 space-y-1.5 text-sm text-navy-600">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Gestion des domaines et configuration DNS
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Provisionnement SSL, opérations de bases de données, surveillance d'activité
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Connexions Git et déploiement WordPress
              </li>
            </ul>
            <div class="mt-5 flex flex-wrap items-center gap-2">
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-navy-50 text-navy-600 border border-navy-200">PHP</span>
              <a
                href="https://github.com/peterbamuhigire/server-manager"
                target="_blank"
                rel="noopener noreferrer"
                class="ml-auto inline-flex items-center gap-1.5 text-xs font-medium text-amber-accent hover:text-gold-600 transition-colors"
              >
                GitHub
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       OPEN-SOURCE PROJECTS
       ═══════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 bg-warm-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Projets Open Source"
        subtitle="Outils et utilitaires partagés avec la communauté des développeurs sur GitHub."
      />

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- MyWampSSL -->
        <a
          href="https://github.com/peterbamuhigire/MyWampSSL"
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-navy-50 rounded-xl p-6 border border-navy-100 hover:border-gold-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 fade-up"
        >
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-lg font-bold text-navy-900 group-hover:text-navy-700">MyWampSSL</h3>
            <svg class="w-5 h-5 text-navy-400 group-hover:text-amber-accent transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <p class="mt-2 text-sm text-navy-600 leading-relaxed">
            Un outil C# WinForms qui automatise la création de certificats SSL de confiance
            et configure Apache et Windows pour les environnements de serveur WAMP locaux.
          </p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">C#</span>
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">WinForms</span>
          </div>
        </a>

        <!-- pyPDFLibrarianSort -->
        <a
          href="https://github.com/peterbamuhigire/pyPDFLibrarianSort"
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-navy-50 rounded-xl p-6 border border-navy-100 hover:border-gold-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 fade-up"
        >
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-lg font-bold text-navy-900 group-hover:text-navy-700">pyPDFLibrarianSort</h3>
            <svg class="w-5 h-5 text-navy-400 group-hover:text-amber-accent transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <p class="mt-2 text-sm text-navy-600 leading-relaxed">
            Une interface web moderne pour la gestion de fichiers PDF avec des capacités
            d'organisation alimentées par l'apprentissage automatique. Simplifie le tri et la catégorisation de grandes collections de PDF.
          </p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">Python</span>
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">ML</span>
          </div>
        </a>

        <!-- SRS Skills -->
        <a
          href="https://github.com/peterbamuhigire/srs-skills"
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-navy-50 rounded-xl p-6 border border-navy-100 hover:border-gold-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 fade-up"
        >
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-lg font-bold text-navy-900 group-hover:text-navy-700">SRS Skills</h3>
            <svg class="w-5 h-5 text-navy-400 group-hover:text-amber-accent transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <p class="mt-2 text-sm text-navy-600 leading-relaxed">
            Utilitaires d'IA pour la création de documentation formelle de Spécification des Exigences Logicielles.
            Rationalise le processus de production de documents SRS structurés et professionnels.
          </p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">Python</span>
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">AI</span>
          </div>
        </a>

        <!-- MySQLDevAssistant -->
        <a
          href="https://github.com/peterbamuhigire/MySQLDevAssistant"
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-navy-50 rounded-xl p-6 border border-navy-100 hover:border-gold-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 fade-up"
        >
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-lg font-bold text-navy-900 group-hover:text-navy-700">MySQLDevAssistant</h3>
            <svg class="w-5 h-5 text-navy-400 group-hover:text-amber-accent transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <p class="mt-2 text-sm text-navy-600 leading-relaxed">
            Une boîte à outils d'assistant de développement de bases de données pour MySQL avec
            gestion de données de test et opérations de schéma. Accélère les flux de travail de développement de bases de données.
          </p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">Python</span>
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-white text-navy-600 border border-navy-200">MySQL</span>
          </div>
        </a>

        <!-- Skills Web Dev -->
        <a
          href="https://github.com/peterbamuhigire/skills-web-dev"
          target="_blank"
          rel="noopener noreferrer"
