---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { t } from '@/utils/i18n';
import type { Lang } from '@/utils/i18n';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';
import { siteConfig } from '@/data/site';

import softwareDevImg from '@/assets/images/services/software-dev-1.jpg';
import techSupportImg from '@/assets/images/services/tech-support-1.jpg';
import businessStrategyImg from '@/assets/images/services/business-strategy.jpg';
import socialMediaImg from '@/assets/images/services/social-media-2.jpg';

const lang: Lang = 'fr';

const lifecycleStages = [
  {
    label: 'Développer',
    description: 'Ingénierie des exigences, analyse des systèmes, architecture et construction. Applications web full-stack en PHP, Python et JavaScript ; applications mobiles Android en Kotlin avec Jetpack Compose et conception offline-first ; plateformes SaaS multi-tenants reposant sur des fondations API propres. Toute construction est précédée d\'une compréhension approfondie des processus métier qu\'elle doit soutenir.',
  },
  {
    label: 'Déployer',
    description: 'Mise en place des environnements, provisionnement d\'infrastructures sécurisées, migration des données depuis les systèmes existants et les tableurs, formation des utilisateurs et déploiement par phases. Le déploiement est traité comme une discipline à part entière, car la plupart des échecs de système trouvent leur origine au moment de la bascule.',
  },
  {
    label: 'Exploiter',
    description: 'Administration courante, support utilisateurs, supervision des performances, gouvernance des accès et surveillance de la sécurité. Une fois le système en production, le cabinet peut l\'exploiter pour le compte du client ou travailler aux côtés d\'une équipe interne — selon ce qui convient à l\'organisation.',
  },
  {
    label: 'Maintenir',
    description: 'Mises à jour, évolution fonctionnelle au rythme du changement de l\'activité, entretien de l\'infrastructure et planification du cycle de vie. Les forfaits de maintenance sont assortis d\'un engagement de service (SLA) et dimensionnés selon la criticité du système, avec des délais de réponse contractuels.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Découverte',
    description: 'Une consultation initiale pour comprendre votre organisation, vos défis et vos objectifs. Un échange, pas un argumentaire commercial.',
  },
  {
    number: '02',
    title: 'Analyse',
    description: 'Une évaluation approfondie de vos systèmes, processus et besoins actuels. Identifier ce qui fonctionne, ce qui ne fonctionne pas, et où se situent les opportunités.',
  },
  {
    number: '03',
    title: 'Proposition',
    description: 'Une proposition claire et détaillée décrivant l\'approche recommandée, le calendrier, les livrables et l\'investissement. Pas de coûts cachés, pas de promesses vagues.',
  },
  {
    number: '04',
    title: 'Mise en œuvre',
    description: 'Une exécution concrète avec des points d\'avancement réguliers. Le cabinet travaille aux côtés de votre équipe, jamais en vase clos.',
  },
  {
    number: '05',
    title: 'Accompagnement — Exploiter & maintenir',
    description: 'Pour les systèmes de gestion d\'entreprise, les logiciels et les sites web, la mission ne s\'arrête pas à la livraison. Administration courante, support utilisateurs, supervision des performances, surveillance de la sécurité, évolution fonctionnelle et entretien de l\'infrastructure sont assurés sous contrats de maintenance avec engagement de service (SLA) — le cycle développer-déployer-exploiter-maintenir concrétisé.',
  },
];
---

<BaseLayout
  title="Systèmes de gestion d'entreprise & développement logiciel — Afrique"
  description="Systèmes de gestion d'entreprise et logiciels sur mesure développés, déployés, exploités et maintenus comme une seule discipline continue. Développement de sites web, conseil TIC et conseil aux entreprises en complément, à travers l'Afrique francophone et anglophone."
  lang={lang}
  page="services"
>

  <!-- ==============================
       HERO BANNER
       ============================== -->
  <section class="relative bg-navy-950 overflow-hidden">
    <div class="absolute inset-0 geo-pattern opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-950/95 to-navy-900"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-24">
      <div class="py-16 md:py-20 lg:py-24 max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-6">
          <span class="text-gold-400 text-sm font-medium">Ce que nous proposons</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white leading-tight">
          Systèmes de gestion d'entreprise &amp; développement logiciel
        </h1>

        <p class="mt-6 text-lg md:text-xl text-navy-200 leading-relaxed max-w-2xl">
          Systèmes de gestion d'entreprise et logiciels sur mesure — développés, déployés, exploités et maintenus comme une seule discipline continue. Le développement de sites web, le conseil TIC et le conseil aux entreprises viennent compléter ce socle, fort de plus de 15 ans d'expérience dans plus de 10 pays africains.
        </p>

        <div class="mt-4 h-1 w-16 rounded-full bg-gold-400"></div>
      </div>
    </div>

    <!-- Bottom wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 40V10C360 30 720 0 1080 20C1260 30 1380 25 1440 20V40H0Z" fill="var(--color-warm-white)"/>
      </svg>
    </div>
  </section>

  <!-- ==============================
       SERVICE 1: SYSTÈMES DE GESTION D'ENTREPRISE & DÉVELOPPEMENT LOGICIEL
       ============================== -->
  <section id="business-management-systems" class="bg-warm-white py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service principal</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Systèmes de gestion d'entreprise &amp; développement logiciel</h2>

          <p class="text-navy-600 leading-relaxed mb-6">
            Les systèmes de gestion d'entreprise sont au cœur de cette pratique. Le travail couvre les mises en œuvre d'ERP, les plateformes SaaS multi-tenants, les systèmes internes sur mesure et les applications mobiles Android — tous conçus pour résoudre des problèmes opérationnels précis plutôt que pour faire étalage de technologie. Chaque mission suit le même cycle de vie : développer, déployer, exploiter et maintenir. Cet engagement sur le cycle de vie complet distingue le cabinet du travail au coup par coup, et il se vérifie à travers des systèmes développés en interne tels que Maduuka (plateforme SaaS multi-tenants de gestion d'entreprise) et Aqar (plateforme de gestion immobilière — le pôle PropTech du cabinet), toutes deux développées, exploitées et maintenues directement par le cabinet. La livraison d'ERP régionaux, notamment Longhorn ERP, applique la même discipline aux systèmes tiers.
          </p>

          <!-- Deliverables grid -->
          <h3 class="text-sm font-semibold uppercase tracking-wider text-navy-900 mb-3">Livrables clés</h3>
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Mise en œuvre & personnalisation d\'ERP (dont Longhorn ERP régional)',
              'Systèmes de gestion d\'entreprise sur mesure',
              'Architecture de plateformes SaaS multi-tenants',
              'Applications mobiles Android (Kotlin, Jetpack Compose)',
              'Applications web full-stack (PHP, Python, JavaScript)',
              'Conception, optimisation & administration de bases de données',
              'Conception d\'API REST & intégration de services tiers',
              'Flux de développement assistés par l\'IA',
              'Modernisation de systèmes existants & migration des données',
              'Exploitation continue & contrats de maintenance avec SLA',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <p class="text-navy-600 leading-relaxed mt-6 text-sm">
            <span class="font-semibold text-navy-900">Systèmes phares développés en interne :</span> Maduuka (SaaS multi-tenants de gestion d'entreprise), Aqar (gestion immobilière — le pôle PropTech du cabinet) et Longhorn ERP (livraison d'ERP régionaux en Afrique de l'Est et de l'Ouest). Ces systèmes apportent la preuve que le cycle développer-déployer-exploiter-maintenir est réellement opéré, et pas seulement décrit.
          </p>

          <a
            href="/fr/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl -rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={softwareDevImg}
              alt="Espace de travail de développement logiciel avec du code à l'écran"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Cycle complet mini-grid -->
      <div class="mt-12 md:mt-16 fade-up">
        <div class="flex items-end justify-between flex-wrap gap-4 mb-6">
          <h3 class="text-2xl md:text-3xl font-bold text-navy-900">Le cycle complet</h3>
          <p class="text-navy-600 text-sm max-w-md">Développer, déployer, exploiter, maintenir — une seule discipline continue, et non une remise et un oubli.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {lifecycleStages.map((stage, index) => (
            <article class="relative rounded-2xl border border-navy-100 bg-warm-cream/60 p-6 shadow-sm shadow-navy-900/5 h-full">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-sm font-bold text-amber-accent font-heading">0{index + 1}</span>
                <div class="h-px flex-1 bg-gold-400/40"></div>
              </div>
              <h4 class="text-lg font-bold text-navy-900 mb-2">{stage.label}</h4>
              <p class="text-navy-600 text-sm leading-relaxed">{stage.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 2: DÉVELOPPEMENT WEB
       ============================== -->
  <section id="website-development" class="bg-warm-cream py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (gauche en desktop) -->
        <!-- [PHOTO NEEDED — website browser or design mockup; currently reusing socialMediaImg as nearest stand-in] -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={socialMediaImg}
              alt="Présence numérique et développement de sites web pilotés par la stratégie"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Texte -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v18m16.5-18v18M3 7.5h18M3 16.5h18M3 12h18M5.625 21h12.75A1.875 1.875 0 0020.25 19.125V4.875A1.875 1.875 0 0018.375 3H5.625A1.875 1.875 0 003.75 4.875v14.25c0 1.036.84 1.875 1.875 1.875z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Développement web</h2>

          <p class="text-navy-600 leading-relaxed mb-6">
            <span class="font-semibold text-navy-900">Des sites web pilotés par la stratégie, qui portent la réputation et convertissent les demandes sérieuses</span> — pour les organisations dont la présence numérique a un poids commercial.
          </p>

          <p class="text-navy-600 leading-relaxed mb-8">
            Le développement web demeure une composante significative du cabinet, positionnée en complément du travail sur les systèmes. Chaque site démarre par un diagnostic du positionnement, des audiences et du rôle commercial que le site est censé jouer, puis se construit sur une pile orientée performance — Astro avec Tailwind, zéro JavaScript par défaut, et des scores Lighthouse compris entre 95 et 100 traités comme un prérequis et non une ambition. La capacité multilingue (français, anglais et kiswahili) est intégrée dès la conception, tout comme le SEO structuré, le balisage schema et la mesure analytique. Cette approche convient aux cabinets de conseil, aux institutions, aux entreprises techniques et aux jeunes entreprises financées par des investisseurs — des organisations pour lesquelles un site web constitue un outil opérationnel à part entière, et non une simple plaquette.
          </p>

          <!-- Livrables -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Conception & développement pilotés par la stratégie (Astro, Tailwind, zéro JS)',
              'Positionnement, message & architecture des preuves',
              'Capacité multilingue (FR / EN / SW)',
              'SEO, schema, analytique & suivi des conversions',
              'Mise en place de l\'hébergement & forfaits post-lancement',
              'Audits & refontes de sites existants',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/fr/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 3: CONSEIL & STRATÉGIE TIC
       ============================== -->
  <section id="ict-consulting" class="bg-warm-white py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (left on desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={techSupportImg}
              alt="Session de conseil en TIC et stratégie technologique"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Conseil & stratégie TIC</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            De nombreuses organisations investissent dans la technologie sans stratégie claire — en acquérant des systèmes qui ne s'intègrent pas, en bâtissant des infrastructures qui ne passent pas à l'échelle, ou en adoptant des outils que les équipes ne peuvent pas utiliser efficacement. Le conseil TIC du cabinet comble cette lacune. Fort de l'expérience acquise dans la gestion d'opérations TIC à travers plusieurs pays et plusieurs organisations — depuis des distributeurs multinationaux de produits de santé présents dans huit pays africains, notamment en Afrique de l'Ouest francophone, jusqu'à des institutions nationales de recherche —, le cabinet fournit un accompagnement stratégique ancré dans la réalité opérationnelle. Qu'il s'agisse d'évaluer l'infrastructure existante, de planifier une transformation numérique, de sélectionner les bons fournisseurs ou de cadrer une démarche de conformité (notamment dans les environnements régis par l'OHADA), la perspective est celle d'un praticien qui a construit et exploité ces systèmes dans des environnements exigeants.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Évaluation & planification de l\'infrastructure IT',
              'Feuilles de route de transformation numérique',
              'Analyse des systèmes & ingénierie des besoins',
              'Évaluation des fournisseurs technologiques',
              'Conception d\'infrastructure réseau & serveur',
              'Mise en place & optimisation de SIG',
              'Stratégie de migration vers le cloud',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/fr/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 4: PLANIFICATION & STRATÉGIE D'ENTREPRISE
       ============================== -->
  <section id="business-planning" class="bg-warm-cream py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Planification & stratégie d'entreprise</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            Le cabinet accompagne entrepreneurs, PME et organisations établies dans l'élaboration des plans, des cadres et de la réflexion stratégique nécessaires pour avancer avec confiance. Que l'objectif soit d'obtenir un financement auprès d'une banque commerciale (Ecobank, Bank of Africa) ou d'une institution de financement du développement (BCEAO, BDEAC, AFD, BAD), de répondre à un appel à subventions, de présenter un projet à des investisseurs ou de construire une feuille de route crédible, les livrables sont ancrés dans la réalité du marché et conformes aux exigences applicables (notamment le référentiel SYSCOHADA dans les pays OHADA).
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Élaboration de plans d\'affaires bancables (banques, IFD & investisseurs)',
              'Planification stratégique & définition d\'objectifs',
              'Propositions commerciales & dossiers de subvention',
              'Études de marché & études de faisabilité',
              'Développement de pitch decks & coaching à la présentation',
              'Conception de cadres de suivi-évaluation',
              'Analyse & optimisation des processus métier',
