---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { t } from '@/utils/i18n';
import type { Lang } from '@/utils/i18n';
import SectionHeading from '@/components/SectionHeading.astro';
import CTASection from '@/components/CTASection.astro';

import softwareDevImg from '@/assets/images/services/software-dev-1.jpg';
import techSupportImg from '@/assets/images/services/tech-support-1.jpg';
import businessStrategyImg from '@/assets/images/services/business-strategy.jpg';
import businessDevImg from '@/assets/images/services/business-dev-1.jpg';
import socialMediaImg from '@/assets/images/services/social-media-2.jpg';

const lang: Lang = 'fr';

const processSteps = [
  {
    number: '01',
    title: 'Découverte',
    description: 'Une consultation initiale pour comprendre votre organisation, vos défis et vos objectifs. C\'est une conversation, pas un argumentaire de vente.',
  },
  {
    number: '02',
    title: 'Analyse',
    description: 'Une évaluation approfondie de vos systèmes, processus et besoins actuels. Identifier ce qui fonctionne, ce qui ne fonctionne pas, et où se trouvent les opportunités.',
  },
  {
    number: '03',
    title: 'Proposition',
    description: 'Une proposition claire et détaillée décrivant l\'approche recommandée, le calendrier, les livrables et l\'investissement. Pas de coûts cachés, pas de promesses vagues.',
  },
  {
    number: '04',
    title: 'Mise en Œuvre',
    description: 'Une exécution concrète avec des mises à jour régulières sur l\'avancement. Peter travaille aux côtés de votre équipe, pas de manière isolée.',
  },
  {
    number: '05',
    title: 'Accompagnement',
    description: 'Un accompagnement continu, une formation et des conseils pour garantir que vos solutions continuent à apporter de la valeur bien après la mission initiale.',
  },
];
---

<BaseLayout
  title="Développement Logiciel & Conseil TIC — Afrique Francophone"
  description="Développement logiciel, conseil TIC et systèmes ERP en Afrique francophone. Plus de 15 ans d'expérience dans plus de 10 pays africains."
  lang={lang}
  page="services"
>

  <!-- ==============================
       HERO BANNER
       ============================== -->
  <section class="relative bg-navy-950 overflow-hidden">
    <div class="absolute inset-0 geo-pattern opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-950/95 to-navy-900"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 md:pt-24">
      <div class="py-16 md:py-20 lg:py-24 max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gold-400/10 border border-gold-400/20 mb-6">
          <span class="text-gold-400 text-sm font-medium">Ce Que Nous Offrons</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-warm-white leading-tight">
          Développement Logiciel &amp; Conseil IT en Afrique
        </h1>

        <p class="mt-6 text-lg md:text-xl text-navy-200 leading-relaxed max-w-2xl">
          Peter Bamuhigire propose des services complets en technologie et conseil aux entreprises, fondés sur plus de 15 ans d'expérience pratique dans plus de 10 pays africains. Chaque mission repose sur un principe simple : la technologie doit servir les résultats de l'entreprise.
        </p>

        <div class="mt-4 h-1 w-16 rounded-full bg-gold-400"></div>
      </div>
    </div>

    <!-- Bottom wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 40V10C360 30 720 0 1080 20C1260 30 1380 25 1440 20V40H0Z" fill="var(--color-warm-white)"/>
      </svg>
    </div>
  </section>

  <!-- ==============================
       SERVICE 1: SOFTWARE DEVELOPMENT
       ============================== -->
  <section id="software-development" class="bg-warm-white py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Développement Logiciel</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            Le développement logiciel est au cœur de cette pratique. Fort d'une expérience approfondie en développement web full-stack, en développement d'applications mobiles et en architecture de plateformes SaaS, Peter conçoit des systèmes pensés pour une utilisation concrète. Chaque projet commence par la compréhension de vos processus métier, l'identification des domaines où la technologie peut créer une véritable valeur, et la conception de solutions que votre équipe peut réellement utiliser. L'approche privilégie des stacks technologiques éprouvés et maintenables, une conception rigoureuse des bases de données et une architecture API propre — car les systèmes fiables reposent sur des fondations solides.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Développement d\'applications web full-stack',
              'Développement d\'applications mobiles Android',
              'Architecture de plateformes SaaS',
              'Implémentation & personnalisation d\'ERP',
              'Conception & optimisation de bases de données',
              'Conception & intégration d\'API REST',
              'Workflows de développement assistés par l\'IA',
              'Modernisation de systèmes existants',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/fr/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl -rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={softwareDevImg}
              alt="Espace de travail de développement logiciel avec du code à l'écran"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 2: ICT CONSULTING & STRATEGY
       ============================== -->
  <section id="ict-consulting" class="bg-warm-cream py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (left on desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={techSupportImg}
              alt="Session de conseil en TIC et stratégie technologique"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Conseil & Stratégie TIC</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            De nombreuses organisations investissent dans la technologie sans stratégie claire — en achetant des systèmes qui ne s'intègrent pas, en construisant une infrastructure qui ne passe pas à l'échelle, ou en adoptant des outils que le personnel ne peut pas utiliser efficacement. Le conseil en TIC de Peter comble cette lacune. S'appuyant sur une expérience de gestion des opérations TIC dans plusieurs pays et organisations — des entreprises multinationales de produits de santé aux institutions nationales de recherche — la pratique fournit des orientations stratégiques ancrées dans la réalité opérationnelle.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Évaluation & planification de l\'infrastructure IT',
              'Feuilles de route de transformation numérique',
              'Analyse des systèmes & ingénierie des besoins',
              'Évaluation des fournisseurs technologiques',
              'Conception d\'infrastructure réseau & serveur',
              'Mise en place & optimisation de SIG',
              'Stratégie de migration vers le cloud',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <a
            href="/fr/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 3: BUSINESS CONSULTING
       ============================== -->
  <section id="planification-entreprise" class="bg-warm-white py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Planification & Stratégie d'Entreprise</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            La pratique de conseil aux entreprises de Peter se concentre sur l'accompagnement des organisations et entrepreneurs dans l'élaboration des plans, stratégies et documents dont ils ont besoin pour croître, obtenir des financements et opérer avec clarté. Fort de 15 ans d'expérience dans des secteurs variés en Afrique et à l'international, la pratique propose un accompagnement stratégique concret qui va au-delà des cadres théoriques — ancré dans les réalités concrètes des entreprises africaines.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Élaboration de plans d\'affaires bancables (banques, IFD & investisseurs)',
              'Planification stratégique & définition d\'objectifs',
              'Propositions commerciales & dossiers de subvention',
              'Études de marché & études de faisabilité',
              'Développement de pitch decks & coaching à la présentation',
              'Conception de cadres de suivi-évaluation',
              'Analyse & optimisation des processus métier',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <div class="mt-6 p-5 rounded-xl bg-navy-950 border border-gold-400/20 relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-gold-400/5 via-transparent to-navy-800/30 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-1.5 h-1.5 rounded-full bg-gold-400"></div>
                <p class="text-gold-400 text-xs font-semibold uppercase tracking-widest">Service Complet — Plan d'Affaires</p>
              </div>
              <p class="text-navy-300 text-sm leading-relaxed mb-4">
                Nous élaborons des plans d'affaires complets et bancables — de l'analyse de marché et la modélisation financière jusqu'au pitch deck professionnel et au coaching de présentation. Un service clé en main qui vous accompagne de l'idée au financement.
              </p>
              <a
                href="/fr/business-planning-consulting-service/"
                class="inline-flex items-center gap-2 text-sm font-semibold text-gold-400 hover:text-gold-300 group/link transition-colors duration-200"
              >
                <span>Découvrir notre service Plan d'Affaires →</span>
              </a>
            </div>
          </div>

          <a
            href="/fr/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl -rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={businessStrategyImg}
              alt="Session de conseil aux entreprises et planification stratégique"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
       SERVICE 4: MARKETING DIGITAL & STRATÉGIE DES RÉSEAUX SOCIAUX
       ============================== -->
  <section id="marketing-digital" class="bg-warm-cream py-16 md:py-24 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up">
        <!-- Image (left on desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="absolute -inset-3 bg-gradient-to-bl from-gold-400/10 via-transparent to-navy-200/20 rounded-2xl rotate-1"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={socialMediaImg}
              alt="Mains tenant un smartphone avec concept de médias sociaux"
              width={640}
              height={480}
              loading="lazy"
              class="w-full object-cover"
            />
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-navy-50 border border-navy-100 mb-5">
            <svg class="w-4 h-4 text-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46"/>
            </svg>
            <span class="text-navy-700 text-xs font-semibold uppercase tracking-wider">Service</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-5">Marketing Digital & Stratégie des Réseaux Sociaux</h2>

          <p class="text-navy-600 leading-relaxed mb-8">
            La plupart des entreprises publient de manière irrégulière, suivent les tendances sans plan défini et n'ont aucun moyen de mesurer l'efficacité de leur présence numérique. Peter conçoit des stratégies de marketing digital et de réseaux sociaux adaptées spécifiquement aux entreprises d'Afrique francophone — en tenant compte des plateformes réellement utilisées par vos clients, des contenus qui suscitent l'engagement local, et d'un cadre de mesure ancré dans les résultats business concrets, et non dans les métriques de vanité.
          </p>

          <!-- Deliverables grid -->
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Stratégie réseaux sociaux & planification de contenu',
              'Stratégie de marketing digital complète (full-funnel)',
              'Playbooks de plateformes (WhatsApp, Facebook, Instagram, LinkedIn, TikTok)',
              'Systèmes de marketing WhatsApp Business',
              'Feuilles de route de marketing de contenu',
              'Cadres de mesure du ROI',
              'Formation & renforcement des capacités',
            ].map((item) => (
              <div class="flex items-start gap-2.5">
                <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-navy-700 text-sm">{item}</span>
              </div>
            ))}
          </div>

          <!-- Cool link to dedicated page -->
          <div class="mt-6 p-5 rounded-xl bg-navy-950 border border-gold-400/20 relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-gold-400/5 via-transparent to-navy-800/30 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-1.5 h-1.5 rounded-full bg-gold-400"></div>
                <p class="text-gold-400 text-xs font-semibold uppercase tracking-widest">Service Complet</p>
              </div>
              <p class="text-warm-white font-semibold mb-1.5">Marketing Digital & Stratégie des Réseaux Sociaux</p>
              <p class="text-navy-300 text-sm leading-relaxed mb-4">
                Une stratégie de marketing digital complète et cohérente — pas une collection de tactiques déconnectées. Stratégie réseaux sociaux, playbooks de plateformes, marketing WhatsApp et formation pour les entreprises d'Afrique francophone.
              </p>
              <a
                href="/fr/strategie-marketing-digital/"
                class="inline-flex items-center gap-2 text-sm font-semibold text-gold-400 hover:text-gold-300 group/link transition-colors duration-200"
              >
                <span>Découvrir nos services Marketing Digital</span>
                <svg class="w-4 h-4 transition-transform duration-200 group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
              </a>
            </div>
          </div>

          <a
            href="/fr/contact/"
            class="inline-flex items-center mt-8 px-6 py-3 bg-amber-accent hover:bg-amber-accent/90 text-white font-semibold rounded-lg transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            {t('cta.book', lang)}
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==============================
