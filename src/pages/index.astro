---
// src/pages/index.astro
// Root redirect — detects browser language, sends to /fr/ or /en/
// No body content: prevents any flash before redirect fires
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <script is:inline>
      (function () {
        var langs = [];
        if (navigator.languages && navigator.languages.length) {
          langs = Array.prototype.slice.call(navigator.languages);
        } else if (navigator.language) {
          langs = [navigator.language];
        } else if (navigator.userLanguage) {
          langs = [navigator.userLanguage];
        }
        // startsWith('fr') catches fr, fr-FR, fr-BE, fr-CD, fr-CI, fr-CM, fr-SN, fr-RW …
        var lang = (langs[0] || 'en').toLowerCase();
        var dest = lang.startsWith('fr') ? '/fr/' : '/en/';
        window.location.replace(dest);
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0;url=/en/" />
    </noscript>
  </head>
  <body></body>
</html>
